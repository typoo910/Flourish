<Window
  x:Class="Vistara.Wpf.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Title="Vistara"
  Width="1100"
  Height="720"
  MinWidth="820"
  MinHeight="560"
  Background="{StaticResource AppBackgroundBrush}"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  mc:Ignorable="d">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="0"
      CornerRadius="0"
      GlassFrameThickness="0"
      ResizeBorderThickness="6"
      UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#E7EDF5" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#D8E3F2" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="White" />
                <Setter TargetName="Chrome" Property="Background" Value="#DC2626" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Foreground" Value="White" />
                <Setter TargetName="Chrome" Property="Background" Value="#B91C1C" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="7">
              <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#EEF3F8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="NavigationItemStyle" TargetType="{x:Type RadioButton}">
      <Setter Property="Height" Value="44" />
      <Setter Property="Margin" Value="8,3" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type RadioButton}">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="7">
              <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="#F2F6FB" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                <Setter TargetName="Chrome" Property="BorderBrush" Value="#BBD3FF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid
        x:Name="AppTitleBar"
        Grid.Row="0"
        Height="54"
        Margin="6,4,6,0"
        Background="Transparent">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button
          x:Name="BackButton"
          Grid.Column="0"
          Margin="2,8"
          Click="TitleBar_BackRequested"
          IsEnabled="False"
          Style="{StaticResource IconButtonStyle}"
          ToolTip="Back">
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE72B;" />
        </Button>

        <Button
          x:Name="PaneToggleButton"
          Grid.Column="1"
          Margin="2,8"
          Click="TitleBar_PaneToggleRequested"
          Style="{StaticResource IconButtonStyle}"
          ToolTip="Toggle navigation">
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE700;" />
        </Button>

        <StackPanel
          Grid.Column="2"
          Margin="10,0,16,0"
          VerticalAlignment="Center"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
          Orientation="Horizontal">
          <Border
            Width="32"
            Height="32"
            Background="{StaticResource AccentSoftBrush}"
            CornerRadius="8">
            <Image Margin="5" Source="/Assets/Square44x44Logo.scale-200.png" />
          </Border>
          <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock
              FontSize="15"
              FontWeight="SemiBold"
              Foreground="{StaticResource PrimaryTextBrush}"
              Text="Vistara" />
            <TextBlock
              Margin="0,1,0,0"
              FontSize="11"
              Foreground="{StaticResource MutedTextBrush}"
              Text="Image Manager" />
          </StackPanel>
        </StackPanel>

        <Border
          Grid.Column="3"
          Background="Transparent"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

        <Border
          Grid.Column="4"
          Width="320"
          Height="34"
          Margin="8,0,12,0"
          Padding="10,0"
          VerticalAlignment="Center"
          Background="White"
          BorderBrush="{StaticResource CardBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
              VerticalAlignment="Center"
              FontFamily="Segoe MDL2 Assets"
              Foreground="{StaticResource MutedTextBrush}"
              Text="&#xE721;" />
            <TextBox
              Grid.Column="1"
              Margin="8,0,0,0"
              VerticalContentAlignment="Center"
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource PrimaryTextBrush}"
              Text="What are you looking for?" />
          </Grid>
        </Border>

        <Border
          Grid.Column="5"
          Width="30"
          Height="30"
          Margin="0,0,12,0"
          VerticalAlignment="Center"
          Background="#E0F2FE"
          CornerRadius="15">
          <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="12"
            FontWeight="SemiBold"
            Foreground="#0369A1"
            Text="JD" />
        </Border>

        <Button
          Grid.Column="6"
          Click="MinimizeButton_Click"
          Style="{StaticResource IconButtonStyle}"
          ToolTip="Minimize">
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE921;" />
        </Button>

        <Button
          Grid.Column="7"
          Click="MaximizeButton_Click"
          Style="{StaticResource IconButtonStyle}"
          ToolTip="Maximize">
          <TextBlock
            x:Name="MaximizeButtonIcon"
            FontFamily="Segoe MDL2 Assets"
            FontSize="11"
            Text="&#xE922;" />
        </Button>

        <Button
          Grid.Column="8"
          Click="CloseButton_Click"
          Style="{StaticResource CloseButtonStyle}"
          ToolTip="Close">
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE8BB;" />
        </Button>
      </Grid>

      <Border
        Grid.Row="1"
        Margin="12,0,12,8"
        Padding="6"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource ToolbarButtonStyle}">
            <StackPanel Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Text="&#xE8E5;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="打开" />
            </StackPanel>
          </Button>
          <Button Margin="6,0,0,0" Style="{StaticResource ToolbarButtonStyle}">
            <StackPanel Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Text="&#xE74E;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="保存" />
            </StackPanel>
          </Button>
          <Button Margin="6,0,0,0" Style="{StaticResource ToolbarButtonStyle}">
            <StackPanel Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Text="&#xE898;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="导入" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <Border
        Grid.Row="2"
        Margin="12,0,12,8"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        ClipToBounds="True"
        CornerRadius="8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PaneColumn" Width="220" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border
            Grid.Column="0"
            Background="#FBFCFE"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
              <TextBlock
                x:Name="PaneTitle"
                Margin="20,16,16,8"
                DockPanel.Dock="Top"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource MutedTextBrush}"
                Text="NAVIGATION" />

              <StackPanel DockPanel.Dock="Top">
                <RadioButton
                  x:Name="HomeItem"
                  Click="NavigationItem_Click"
                  GroupName="RootNavigation"
                  Style="{StaticResource NavigationItemStyle}"
                  Tag="Home">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FontFamily="Segoe MDL2 Assets"
                      FontSize="16"
                      Text="&#xE80F;" />
                    <TextBlock
                      x:Name="HomeLabel"
                      Grid.Column="1"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Text="首页" />
                  </Grid>
                </RadioButton>

                <RadioButton
                  x:Name="GalleryItem"
                  Click="NavigationItem_Click"
                  GroupName="RootNavigation"
                  Style="{StaticResource NavigationItemStyle}"
                  Tag="Gallery">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FontFamily="Segoe MDL2 Assets"
                      FontSize="16"
                      Text="&#xE91B;" />
                    <TextBlock
                      x:Name="GalleryLabel"
                      Grid.Column="1"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Text="图库" />
                  </Grid>
                </RadioButton>

                <RadioButton
                  x:Name="EditorItem"
                  Click="NavigationItem_Click"
                  GroupName="RootNavigation"
                  Style="{StaticResource NavigationItemStyle}"
                  Tag="Editor">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FontFamily="Segoe MDL2 Assets"
                      FontSize="16"
                      Text="&#xE70F;" />
                    <TextBlock
                      x:Name="EditorLabel"
                      Grid.Column="1"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Text="编辑" />
                  </Grid>
                </RadioButton>

                <RadioButton
                  x:Name="SettingsItem"
                  Click="NavigationItem_Click"
                  GroupName="RootNavigation"
                  Style="{StaticResource NavigationItemStyle}"
                  Tag="Settings">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="24" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      FontFamily="Segoe MDL2 Assets"
                      FontSize="16"
                      Text="&#xE713;" />
                    <TextBlock
                      x:Name="SettingsLabel"
                      Grid.Column="1"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Text="设置" />
                  </Grid>
                </RadioButton>
              </StackPanel>
            </DockPanel>
          </Border>

          <Frame
            x:Name="RootFrame"
            Grid.Column="1"
            Focusable="False"
            JournalOwnership="OwnsJournal"
            NavigationUIVisibility="Hidden" />
        </Grid>
      </Border>

      <Border
        Grid.Row="3"
        Padding="12,10"
        Background="{StaticResource CardSecondaryBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="0,1,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock
            VerticalAlignment="Center"
            Foreground="{StaticResource MutedTextBrush}"
            Text="就绪" />

          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <StackPanel Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Foreground="{StaticResource MutedTextBrush}"
                Text="&#xE823;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="12:45" />
            </StackPanel>

            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Foreground="{StaticResource MutedTextBrush}"
                Text="&#xE701;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="已连接" />
            </StackPanel>

            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                Foreground="{StaticResource MutedTextBrush}"
                Text="&#xE850;" />
              <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="82%" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
