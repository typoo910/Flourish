<Application
  x:Class="Vistara.Wpf.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:Vistara.Wpf">
  <Application.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FA" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CardSecondaryBackgroundBrush" Color="#EEF3F8" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#D8E0EA" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1D2939" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DBEAFE" />
  </Application.Resources>
</Application>
