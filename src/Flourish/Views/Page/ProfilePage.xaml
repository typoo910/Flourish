<Page
  x:Class="ArkheideSystem.Flourish.Views.Page.FlourishProfilePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:flourish="clr-namespace:ArkheideSystem.Flourish.Controls"
  x:ClassModifier="internal"
  Background="Transparent"
  Focusable="False"
  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
  ScrollViewer.VerticalScrollBarVisibility="Disabled"
>
  <Grid x:Name="RootGrid" Margin="16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Width="52" Height="52" HorizontalAlignment="Center">
      <Border
        Background="{DynamicResource FlourishProfileBackgroundBrush}"
        CornerRadius="26"
      />
      <Ellipse x:Name="AvatarImage" Visibility="Collapsed" />
      <flourish:FlourishTextBlock
        x:Name="AvatarInitials"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        FontSize="{DynamicResource FlourishFontSizeStandard}"
        FontWeight="Regular"
        Foreground="{DynamicResource FlourishProfileForegroundBrush}"
      />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,8,0,0">
      <flourish:FlourishTextBlock
        x:Name="DisplayNameText"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeStandard}"
        FontWeight="Bold"
        Foreground="{DynamicResource FlourishNeutralForeground1Brush}"
        TextTrimming="CharacterEllipsis"
      />
      <flourish:FlourishTextBlock
        x:Name="LoginStateText"
        Margin="0,2,0,0"
        HorizontalAlignment="Center"
        FontFamily="{DynamicResource FlourishFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeStandard}"
        Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
      />
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,14,0,0">
      <flourish:Button
        x:Name="LoginButton"
        Variant="Filled"
        HorizontalAlignment="Center"
        Click="LoginButton_Click"
      />

      <StackPanel x:Name="LoginForm" Visibility="Collapsed">
        <Grid x:Name="NameFieldsGrid">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel x:Name="FirstNameField" Grid.Column="0">
            <flourish:FlourishTextBlock
              x:Name="FirstNameLabel"
              Margin="0,0,0,4"
              FontSize="{DynamicResource FlourishFontSizeStandard}"
              Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
            />
            <flourish:FlourishTextBox
              x:Name="FirstNameInput"
              TextChanged="NameInput_TextChanged"
            />
          </StackPanel>

          <StackPanel x:Name="LastNameField" Grid.Column="2">
            <flourish:FlourishTextBlock
              x:Name="LastNameLabel"
              Margin="0,0,0,4"
              FontSize="{DynamicResource FlourishFontSizeStandard}"
              Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
            />
            <flourish:FlourishTextBox
              x:Name="LastNameInput"
              TextChanged="NameInput_TextChanged"
            />
          </StackPanel>
        </Grid>

        <flourish:FlourishTextBlock
          x:Name="ProfileImageLabel"
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeStandard}"
          Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
        />
        <flourish:IconButton
          x:Name="UploadImageButton"
          Variant="Outlined"
          HorizontalAlignment="Stretch"
          Click="UploadImageButton_Click"
        >
          <flourish:IconButton.Icon>
            <Viewbox Width="15" Height="15">
              <Path
                Data="M 3,16 L 3,20 L 21,20 L 21,16 M 12,3 L 12,16 M 7,8 L 12,3 L 17,8"
                Fill="Transparent"
                Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type flourish:IconButton}}}"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="2"
              />
            </Viewbox>
          </flourish:IconButton.Icon>
          <flourish:FlourishTextBlock
            x:Name="UploadImageText"
            VerticalAlignment="Center"
          />
        </flourish:IconButton>

        <flourish:FlourishTextBlock
          x:Name="PasswordLabel"
          Margin="0,9,0,4"
          FontSize="{DynamicResource FlourishFontSizeStandard}"
          Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
        />
        <flourish:FlourishPasswordBox x:Name="PasswordInput" />

        <flourish:FlourishTextBlock
          x:Name="ErrorText"
          MinHeight="16"
          Margin="0,6,0,0"
          FontSize="{DynamicResource FlourishFontSizeStandard}"
          Foreground="{DynamicResource FlourishDangerForegroundBrush}"
          TextWrapping="Wrap"
        />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
          <flourish:Button
            x:Name="CancelLoginButton"
            Variant="Outlined"
            Margin="0,0,7,0"
            Click="CancelLoginButton_Click"
          />
          <flourish:Button
            x:Name="SubmitLoginButton"
            Variant="Filled"
            Click="SubmitLoginButton_Click"
          />
        </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SignedInPanel" Visibility="Collapsed">
        <flourish:FlourishCheckBox
          x:Name="RememberLoginCheckBox"
          HorizontalAlignment="Center"
          Checked="RememberLoginCheckBox_Changed"
          Unchecked="RememberLoginCheckBox_Changed"
        />
        <flourish:Button
          x:Name="LogoutButton"
          Variant="Outlined"
          Margin="0,14,0,0"
          HorizontalAlignment="Center"
          Click="LogoutButton_Click"
        />
        <flourish:FlourishTextBlock
          x:Name="SignedInErrorText"
          Margin="0,8,0,0"
          HorizontalAlignment="Center"
          FontSize="{DynamicResource FlourishFontSizeStandard}"
          Foreground="{DynamicResource FlourishDangerForegroundBrush}"
          TextAlignment="Center"
          TextWrapping="Wrap"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Page>
