<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>

  <Style TargetType="{x:Type controls:FlourishSearchBox}">
    <Setter Property="MinWidth" Value="{DynamicResource FlourishControlMinWidth}" />
    <Setter Property="MinHeight" Value="{DynamicResource FlourishControlHeight}" />
    <Setter Property="Padding" Value="{DynamicResource FlourishCompactControlPadding}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource FlourishControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishControlBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource FlourishSelectionBackgroundBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:FlourishSearchBox}">
          <Border
            x:Name="Chrome"
            Padding="{TemplateBinding Padding}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{DynamicResource FlourishControlCornerRadius}"
            SnapsToDevicePixels="True"
          >
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Width="16"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="{DynamicResource FlourishIconFontSizeTitlebarSearch}"
                LineHeight="{DynamicResource FlourishIconFontSizeTitlebarSearch}"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                IsHitTestVisible="False"
                Text="&#xE721;"
                TextAlignment="Center"
              />
              <ScrollViewer
                x:Name="PART_ContentHost"
                Grid.Column="1"
                Margin="8,0,0,0"
                HorizontalScrollBarVisibility="Hidden"
                Style="{DynamicResource FlourishTextContentHostScrollViewerStyle}"
                VerticalScrollBarVisibility="Hidden"
              />
              <TextBlock
                x:Name="PlaceholderText"
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
                IsHitTestVisible="False"
                Text="{TemplateBinding Placeholder}"
                TextTrimming="CharacterEllipsis"
                Visibility="Collapsed"
              />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="Text" Value="" />
                <Condition Property="IsKeyboardFocusWithin" Value="False" />
              </MultiTrigger.Conditions>
              <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
            </MultiTrigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource FlourishControlHoverBrush}" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeHoverBrush}" />
            </Trigger>
            <Trigger Property="IsReadOnly" Value="True">
              <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground2Brush}" />
              <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource FlourishNeutralBackground2Brush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeFocusBrush}" />
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishDangerStrokeBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
              <Setter Property="CaretBrush" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
              <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource FlourishControlDisabledBrush}" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
