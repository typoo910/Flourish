<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="Button.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <DataTemplate x:Key="IconButtonContentTemplate">
    <StackPanel Orientation="Horizontal">
      <ContentPresenter
        x:Name="IconHost"
        VerticalAlignment="Center"
        Content="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type controls:IconButton}}}"
        TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
        TextElement.FontSize="{DynamicResource FlourishFontSizeCaption}"
      />
      <ContentPresenter
        x:Name="LabelHost"
        Margin="6,0,0,0"
        VerticalAlignment="Center"
        Content="{Binding Content, RelativeSource={RelativeSource AncestorType={x:Type controls:IconButton}}}"
      />
    </StackPanel>
    <DataTemplate.Triggers>
      <DataTrigger
        Binding="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type controls:IconButton}}}"
        Value="{x:Null}"
      >
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="LabelHost" Property="Margin" Value="0" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding Content, RelativeSource={RelativeSource AncestorType={x:Type controls:IconButton}}}"
        Value="{x:Null}"
      >
        <Setter TargetName="LabelHost" Property="Visibility" Value="Collapsed" />
      </DataTrigger>
    </DataTemplate.Triggers>
  </DataTemplate>

  <ControlTemplate
    x:Key="IconOnlyButtonTemplate"
    TargetType="{x:Type controls:IconButton}"
  >
    <Grid SnapsToDevicePixels="True">
      <Border
        x:Name="ShadowChrome"
        Background="{TemplateBinding Background}"
        CornerRadius="{DynamicResource FlourishControlCornerRadius}"
        Effect="{DynamicResource FlourishElevation1Effect}"
        IsHitTestVisible="False"
        Visibility="Collapsed"
      />
      <Grid
        x:Name="InteractionRoot"
        ClipToBounds="True"
        SnapsToDevicePixels="True"
      >
      <Border
        x:Name="Chrome"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="{DynamicResource FlourishControlCornerRadius}"
      />
      <Border
        x:Name="HoverChrome"
        Background="{TemplateBinding controls:HoverReveal.OverrideColor}"
        BorderThickness="0"
        CornerRadius="{DynamicResource FlourishControlCornerRadius}"
        IsHitTestVisible="False"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
      >
        <Border.RenderTransform>
          <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
        </Border.RenderTransform>
      </Border>
      <Border
        x:Name="PressedChrome"
        Background="{DynamicResource FlourishPressedRevealBrush}"
        BorderThickness="0"
        CornerRadius="{DynamicResource FlourishControlCornerRadius}"
        IsHitTestVisible="False"
        Opacity="0"
      />
        <ContentPresenter
          x:Name="IconHost"
          Margin="{TemplateBinding Padding}"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Content="{TemplateBinding Icon}"
          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
          TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
          TextElement.FontSize="{DynamicResource FlourishFontSizeCaption}"
        />
      </Grid>
    </Grid>
    <ControlTemplate.Triggers>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True" />
          <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
        </MultiTrigger.Conditions>
        <Setter TargetName="HoverChrome" Property="Opacity" Value="1" />
        <Setter TargetName="HoverChrome" Property="RenderTransform">
          <Setter.Value>
            <ScaleTransform ScaleX="1" ScaleY="1" />
          </Setter.Value>
        </Setter>
      </MultiTrigger>
      <Trigger Property="Variant" Value="Elevated">
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Visible" />
        <Setter
          TargetName="PressedChrome"
          Property="Background"
          Value="{DynamicResource FlourishControlPressedBrush}"
        />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter
          TargetName="PressedChrome"
          Property="Background"
          Value="{DynamicResource FlourishPrimaryBackgroundPressedBrush}"
        />
      </Trigger>
      <Trigger Property="Variant" Value="Tonal">
        <Setter
          TargetName="PressedChrome"
          Property="Background"
          Value="{DynamicResource FlourishTonalButtonPressedBrush}"
        />
      </Trigger>
      <Trigger Property="Variant" Value="Danger">
        <Setter
          TargetName="PressedChrome"
          Property="Background"
          Value="{DynamicResource FlourishDangerStrokeBrush}"
        />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="HoverChrome" Property="Opacity" Value="0" />
        <Setter TargetName="PressedChrome" Property="Opacity" Value="1" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Variant" Value="Tonal" />
          <Condition Property="IsPressed" Value="True" />
        </MultiTrigger.Conditions>
        <Setter Property="Foreground" Value="{DynamicResource FlourishTonalButtonPressedForegroundBrush}" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
        <Setter Property="Background" Value="{DynamicResource FlourishControlDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeDisabledBrush}" />
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="HoverChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PressedChrome" Property="Visibility" Value="Collapsed" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style
    TargetType="{x:Type controls:IconButton}"
    BasedOn="{StaticResource {x:Type controls:Button}}"
  >
    <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
    <Style.Triggers>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter Property="Width" Value="{DynamicResource FlourishIconButtonSize}" />
        <Setter Property="Height" Value="{DynamicResource FlourishIconButtonSize}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ContentTemplate" Value="{x:Null}" />
        <Setter Property="Template" Value="{StaticResource IconOnlyButtonTemplate}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
