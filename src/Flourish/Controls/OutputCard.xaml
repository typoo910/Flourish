<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <!-- Terminal Card-family dictionary: this dependency chain loads each family resource once. -->
    <ResourceDictionary Source="IconCard.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <ControlTemplate x:Key="OutputCardTemplate" TargetType="{x:Type controls:OutputCard}">
    <Border
      x:Name="SurfaceChrome"
      Padding="{TemplateBinding Padding}"
      Background="{TemplateBinding Background}"
      BorderBrush="{TemplateBinding BorderBrush}"
      BorderThickness="{TemplateBinding BorderThickness}"
      CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
    >
      <Border
        x:Name="OutputViewport"
        Background="{DynamicResource FlourishOutputViewportBackgroundBrush}"
        ClipToBounds="True"
        CornerRadius="{DynamicResource FlourishControlCornerRadius}"
      >
        <controls:ScrollViewer
          x:Name="PART_OutputScrollViewer"
          Padding="{DynamicResource FlourishOutputViewportPadding}"
          Focusable="False"
          HorizontalScrollBarVisibility="Auto"
          IsCompact="True"
          VerticalScrollBarVisibility="Auto"
        >
          <controls:FlourishTextBlock
            x:Name="OutputHost"
            Foreground="{TemplateBinding Foreground}"
            Role="Caption"
            Text="{TemplateBinding Output}"
            TextWrapping="NoWrap"
          />
        </controls:ScrollViewer>
      </Border>
    </Border>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:OutputCard}">
    <Setter Property="MinHeight" Value="{DynamicResource FlourishOutputCardMinHeight}" />
    <Setter Property="Padding" Value="{DynamicResource FlourishCardPadding}" />
    <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource OutputCardTemplate}" />
    <Style.Triggers>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
