<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <Style TargetType="{x:Type controls:Paragraph}">
    <Setter Property="Role" Value="Paragraph" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeLarge}" />
    <Setter Property="FontStyle" Value="Normal" />
    <Setter Property="FontWeight" Value="Regular" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="LineHeight" Value="{DynamicResource FlourishLineHeightLarge}" />
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
</ResourceDictionary>
