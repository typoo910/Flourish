<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ControlTemplate x:Key="PresenterTemplate" TargetType="{x:Type controls:Presenter}">
    <Border
      Padding="{TemplateBinding Padding}"
      Background="{TemplateBinding Background}"
      BorderBrush="{TemplateBinding BorderBrush}"
      BorderThickness="{TemplateBinding BorderThickness}"
      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ContentPresenter
          x:Name="PresentationHost"
          Grid.Column="1"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Content="{TemplateBinding Presentation}"
          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
        />
        <Border
          x:Name="OverlayScrim"
          Grid.ColumnSpan="2"
          Panel.ZIndex="1"
          Background="{DynamicResource FlourishCardOverlayScrimBrush}"
          IsHitTestVisible="False"
          Visibility="Collapsed"
        />
        <Border
          x:Name="CopySurface"
          Grid.Column="0"
          Panel.ZIndex="2"
          Padding="{DynamicResource FlourishPresenterCopyPadding}"
        >
          <StackPanel
            x:Name="CopyAndBodyHost"
            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
          >
            <StackPanel x:Name="CopyHost">
              <controls:FlourishTextBlock
                x:Name="TitleHost"
                Foreground="{TemplateBinding Foreground}"
                Role="CardTitle"
                Text="{TemplateBinding Title}"
              />
              <controls:FlourishTextBlock
                x:Name="DescriptionHost"
                Margin="{DynamicResource FlourishPresenterDescriptionSpacing}"
                Foreground="{TemplateBinding Foreground}"
                Role="Description"
                Text="{TemplateBinding Description}"
              />
            </StackPanel>
            <ContentPresenter
              x:Name="BodyHost"
              Margin="{DynamicResource FlourishPresenterBodySpacing}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Content="{TemplateBinding Body}"
              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
              TextElement.Foreground="{TemplateBinding Foreground}"
            />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="PresenterPosition" Value="Left">
        <Setter TargetName="PresentationHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="1" />
      </Trigger>
      <Trigger Property="PresenterMode" Value="Overlay">
        <Setter TargetName="PresentationHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="PresentationHost" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Visible" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
        <Setter TargetName="DescriptionHost" Property="Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
      </Trigger>
      <Trigger Property="Presentation" Value="{x:Null}">
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="DescriptionHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Presentation" Value="">
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="DescriptionHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="DescriptionHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="DescriptionHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Description" Value="">
        <Setter TargetName="DescriptionHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Description" Value="{x:Null}">
        <Setter TargetName="DescriptionHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Body" Value="{x:Null}">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Body" Value="">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Description" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Description" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Description" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Description" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:Presenter}">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{x:Null}" />
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource PresenterTemplate}" />
  </Style>
</ResourceDictionary>
