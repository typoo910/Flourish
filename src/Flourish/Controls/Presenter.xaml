<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ControlTemplate x:Key="PresenterTemplate" TargetType="{x:Type controls:Presenter}">
    <Border
      x:Name="PresenterSurface"
      Padding="{TemplateBinding Padding}"
      BorderBrush="{TemplateBinding BorderBrush}"
      BorderThickness="{TemplateBinding BorderThickness}"
      ClipToBounds="True"
      CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border
          x:Name="PresentationSurface"
          Grid.Column="1"
          Grid.RowSpan="2"
          Background="{TemplateBinding Background}"
          ClipToBounds="True"
          CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        >
          <ContentPresenter
            x:Name="PresentationHost"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Content="{TemplateBinding Presentation}"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
          />
        </Border>
        <Border
          x:Name="OverlayScrim"
          Grid.ColumnSpan="2"
          Grid.RowSpan="2"
          Panel.ZIndex="1"
          Background="{DynamicResource FlourishCardOverlayScrimBrush}"
          IsHitTestVisible="False"
          Visibility="Collapsed"
        />
        <Border
          x:Name="CopySurface"
          Grid.Column="0"
          Grid.RowSpan="2"
          Panel.ZIndex="2"
          Padding="{DynamicResource FlourishPresenterCopyPadding}"
        >
          <StackPanel
            x:Name="CopyAndBodyHost"
            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
          >
            <StackPanel x:Name="CopyHost" HorizontalAlignment="Stretch">
              <controls:FlourishTextBlock
                x:Name="TitleHost"
                Foreground="{TemplateBinding Foreground}"
                Role="CardTitle"
                Text="{TemplateBinding Title}"
                TextAlignment="Left"
              />
              <controls:FlourishTextBlock
                x:Name="ContentHost"
                Margin="{DynamicResource FlourishPresenterContentSpacing}"
                Foreground="{TemplateBinding Foreground}"
                Role="Description"
                Text="{TemplateBinding Content}"
                TextAlignment="Left"
              />
            </StackPanel>
            <ContentPresenter
              x:Name="BodyHost"
              Margin="{DynamicResource FlourishPresenterBodySpacing}"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Content="{TemplateBinding Body}"
              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
              TextElement.Foreground="{TemplateBinding Foreground}"
            />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="PresenterPosition" Value="Left">
        <Setter TargetName="PresentationSurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="1" />
      </Trigger>
      <Trigger Property="PresenterMode" Value="Overlay">
        <Setter TargetName="PresentationSurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="PresentationSurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="PresentationSurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="PresentationSurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="PresentationHost" Property="HorizontalAlignment" Value="Stretch" />
        <Setter TargetName="PresentationHost" Property="VerticalAlignment" Value="Stretch" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Visible" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{DynamicResource FlourishCardOverlayForegroundBrush}" />
      </Trigger>
      <Trigger Property="PresenterMode" Value="TopDown">
        <Setter TargetName="PresentationSurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="PresentationSurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="PresentationSurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="PresentationSurface" Property="Grid.RowSpan" Value="1" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="1" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="1" />
      </Trigger>
      <Trigger Property="Presentation" Value="{x:Null}">
        <Setter TargetName="PresentationSurface" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Presentation" Value="">
        <Setter TargetName="PresentationSurface" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Body" Value="{x:Null}">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Body" Value="">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:Presenter}">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource FlourishNeutralBackground2Brush}" />
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource PresenterTemplate}" />
  </Style>
</ResourceDictionary>
