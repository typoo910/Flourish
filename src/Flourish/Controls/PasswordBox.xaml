<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <Style x:Key="FlourishPasswordBoxEditorStyle" TargetType="{x:Type PasswordBox}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type PasswordBox}">
          <ScrollViewer
            x:Name="PART_ContentHost"
            HorizontalScrollBarVisibility="Hidden"
            Style="{DynamicResource FlourishTextContentHostScrollViewerStyle}"
            VerticalScrollBarVisibility="Hidden"
          />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type controls:FlourishPasswordBox}">
    <Setter Property="MinWidth" Value="{DynamicResource FlourishControlMinWidth}" />
    <Setter Property="MinHeight" Value="{DynamicResource FlourishControlHeight}" />
    <Setter Property="Padding" Value="{DynamicResource FlourishControlPadding}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource FlourishControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishControlBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:FlourishPasswordBox}">
          <Border
            x:Name="Chrome"
            Padding="{TemplateBinding Padding}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{DynamicResource FlourishControlCornerRadius}"
            SnapsToDevicePixels="True"
          >
            <PasswordBox
              x:Name="PART_PasswordBox"
              Padding="0"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Background="Transparent"
              Foreground="{TemplateBinding Foreground}"
              FontFamily="{TemplateBinding FontFamily}"
              FontSize="{TemplateBinding FontSize}"
              IsEnabled="{TemplateBinding IsEnabled}"
              IsTabStop="False"
              MaxLength="{TemplateBinding MaxLength}"
              PasswordChar="{TemplateBinding PasswordChar}"
              Style="{StaticResource FlourishPasswordBoxEditorStyle}"
            />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource FlourishControlHoverBrush}" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeHoverBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeFocusBrush}" />
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishDangerStrokeBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
              <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource FlourishControlDisabledBrush}" />
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
