<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ControlTemplate x:Key="HeaderChunkTemplate" TargetType="{x:Type controls:HeaderChunk}">
    <Border
      x:Name="PART_HeaderSurface"
      MinHeight="{DynamicResource FlourishHeaderChunkMinHeight}"
      Background="{TemplateBinding Background}"
      BorderBrush="{TemplateBinding BorderBrush}"
      BorderThickness="{TemplateBinding BorderThickness}"
      ClipToBounds="True"
      CornerRadius="{DynamicResource FlourishOverlayCornerRadius}"
      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
    >
      <Grid x:Name="PART_ClipHost">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ContentPresenter
          x:Name="PresentationHost"
          Grid.Column="1"
          Grid.RowSpan="2"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Content="{TemplateBinding Presentation}"
          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
        />
        <Border
          x:Name="OverlayScrim"
          Grid.ColumnSpan="2"
          Grid.RowSpan="2"
          Panel.ZIndex="1"
          Background="{DynamicResource FlourishHeaderChunkOverlayScrimBrush}"
          IsHitTestVisible="False"
          Visibility="Collapsed"
        />
        <Border
          x:Name="CopySurface"
          Grid.Column="0"
          Grid.RowSpan="2"
          Panel.ZIndex="2"
          Padding="{TemplateBinding Padding}"
        >
          <StackPanel
            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
          >
            <StackPanel x:Name="CopyHost">
              <controls:FlourishTextBlock
                x:Name="TitleHost"
                FontSize="{DynamicResource FlourishFontSizeHeaderSize}"
                FontWeight="Bold"
                Foreground="{TemplateBinding Foreground}"
                Role="PageTitle"
                Text="{TemplateBinding Title}"
                TextWrapping="Wrap"
              />
              <controls:FlourishTextBlock
                x:Name="ContentHost"
                Margin="{DynamicResource FlourishHeaderChunkContentMargin}"
                Foreground="{TemplateBinding Foreground}"
                Role="Subtitle"
                Text="{TemplateBinding Content}"
              />
            </StackPanel>
            <ContentPresenter
              x:Name="BodyHost"
              Margin="{DynamicResource FlourishHeaderChunkBodyMargin}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              Content="{TemplateBinding Body}"
              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
              TextElement.FontFamily="{TemplateBinding FontFamily}"
              TextElement.FontSize="{TemplateBinding FontSize}"
              TextElement.Foreground="{TemplateBinding Foreground}"
            />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="PresenterPosition" Value="Left">
        <Setter TargetName="PresentationHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="1" />
      </Trigger>
      <Trigger Property="PresenterMode" Value="Overlay">
        <Setter TargetName="PresentationHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="PresentationHost" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="PresentationHost" Property="Grid.Row" Value="0" />
        <Setter TargetName="PresentationHost" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Visible" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{DynamicResource FlourishHeaderChunkOverlayForegroundBrush}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{DynamicResource FlourishHeaderChunkOverlayForegroundBrush}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{DynamicResource FlourishHeaderChunkOverlayForegroundBrush}" />
      </Trigger>
      <Trigger Property="PresenterMode" Value="TopDown">
        <Setter TargetName="PresentationHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="PresentationHost" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="PresentationHost" Property="Grid.Row" Value="0" />
        <Setter TargetName="PresentationHost" Property="Grid.RowSpan" Value="1" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="1" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="1" />
        <Setter TargetName="BodyHost" Property="HorizontalAlignment" Value="Left" />
      </Trigger>
      <Trigger Property="Presentation" Value="{x:Null}">
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Presentation" Value="">
        <Setter TargetName="PresentationHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="OverlayScrim" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="CopySurface" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.ColumnSpan" Value="2" />
        <Setter TargetName="CopySurface" Property="Grid.Row" Value="0" />
        <Setter TargetName="CopySurface" Property="Grid.RowSpan" Value="2" />
        <Setter TargetName="TitleHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="ContentHost" Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
        <Setter TargetName="BodyHost" Property="TextElement.Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Body" Value="{x:Null}">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Body" Value="">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </MultiTrigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:HeaderChunk}">
    <Setter Property="Margin" Value="{DynamicResource FlourishHeaderChunkMargin}" />
    <Setter Property="Padding" Value="{DynamicResource FlourishHeaderChunkPadding}" />
    <Setter Property="Background" Value="{DynamicResource FlourishHeroBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource HeaderChunkTemplate}" />
  </Style>
</ResourceDictionary>
