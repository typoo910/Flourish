<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <!-- Terminal Button-family dictionary: this dependency chain loads each family resource once. -->
    <ResourceDictionary Source="WindowCaptionButton.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <DataTemplate x:Key="CardButtonContentTemplate">
    <DockPanel LastChildFill="True">
      <ContentPresenter
        x:Name="IconHost"
        Margin="0,0,0,12"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        DockPanel.Dock="Top"
        Content="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
        TextElement.FontSize="{DynamicResource FlourishFontSizeSectionTitle}"
        TextElement.Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
      />
      <StackPanel x:Name="TextHost">
        <controls:FlourishTextBlock
          x:Name="TitleHost"
          Role="CardTitle"
          Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        />
        <ContentPresenter
          x:Name="DescriptionHost"
          Margin="0,4,0,0"
          Content="{Binding Content, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
          TextElement.FontFamily="{DynamicResource FlourishFontFamily}"
          TextElement.FontSize="{DynamicResource FlourishFontSizeDescription}"
          TextElement.Foreground="{DynamicResource FlourishNeutralForeground2Brush}"
        />
      </StackPanel>
    </DockPanel>
    <DataTemplate.Triggers>
      <DataTrigger
        Binding="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value="{x:Null}"
      >
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value=""
      >
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="DescriptionHost" Property="Margin" Value="0" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding Content, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value="{x:Null}"
      >
        <Setter TargetName="DescriptionHost" Property="Visibility" Value="Collapsed" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding IconPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value="Left"
      >
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Left" />
        <Setter TargetName="IconHost" Property="Margin" Value="0,0,12,0" />
        <Setter TargetName="IconHost" Property="VerticalAlignment" Value="Center" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding IconPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value="Right"
      >
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Right" />
        <Setter TargetName="IconHost" Property="Margin" Value="12,0,0,0" />
        <Setter TargetName="IconHost" Property="HorizontalAlignment" Value="Right" />
        <Setter TargetName="IconHost" Property="VerticalAlignment" Value="Center" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding IconPosition, RelativeSource={RelativeSource AncestorType={x:Type controls:CardButton}}}"
        Value="Bottom"
      >
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Bottom" />
        <Setter TargetName="IconHost" Property="Margin" Value="0,12,0,0" />
      </DataTrigger>
    </DataTemplate.Triggers>
  </DataTemplate>

  <ControlTemplate
    x:Key="CardButtonTemplate"
    TargetType="{x:Type controls:CardButton}"
  >
    <Grid
      x:Name="InteractionRoot"
      ClipToBounds="True"
      RenderTransformOrigin="0.5,0.5"
      SnapsToDevicePixels="True"
    >
      <Border
        x:Name="Chrome"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
      />
      <Border
        x:Name="HoverChrome"
        Background="{TemplateBinding controls:HoverReveal.OverrideColor}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        IsHitTestVisible="False"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
      >
        <Border.RenderTransform>
          <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
        </Border.RenderTransform>
      </Border>
      <Border
        x:Name="PressedChrome"
        Background="{DynamicResource FlourishPressedRevealBrush}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        IsHitTestVisible="False"
        Opacity="0"
      />
      <ContentPresenter
        Margin="{TemplateBinding Padding}"
        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
        Content="{TemplateBinding Content}"
        ContentTemplate="{TemplateBinding ContentTemplate}"
        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
      />
    </Grid>
    <ControlTemplate.Triggers>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True" />
          <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
        </MultiTrigger.Conditions>
        <Setter TargetName="HoverChrome" Property="Opacity" Value="1" />
        <Setter TargetName="HoverChrome" Property="RenderTransform">
          <Setter.Value>
            <ScaleTransform ScaleX="1" ScaleY="1" />
          </Setter.Value>
        </Setter>
      </MultiTrigger>
      <Trigger Property="Variant" Value="Elevated">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishControlPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishPrimaryBackgroundPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Tonal">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishTonalButtonPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Danger">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishDangerStrokeBrush}" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="HoverChrome" Property="Opacity" Value="0" />
        <Setter TargetName="PressedChrome" Property="Opacity" Value="1" />
        <Setter TargetName="InteractionRoot" Property="RenderTransform">
          <Setter.Value>
            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
          </Setter.Value>
        </Setter>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
        <Setter Property="Background" Value="{DynamicResource FlourishControlDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeDisabledBrush}" />
        <Setter TargetName="HoverChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PressedChrome" Property="Visibility" Value="Collapsed" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style
    TargetType="{x:Type controls:CardButton}"
    BasedOn="{StaticResource {x:Type controls:Button}}"
  >
    <Setter Property="Padding" Value="{DynamicResource FlourishInteractiveCardPadding}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
    <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="ContentTemplate" Value="{StaticResource CardButtonContentTemplate}" />
    <Setter Property="Template" Value="{StaticResource CardButtonTemplate}" />
  </Style>
</ResourceDictionary>
