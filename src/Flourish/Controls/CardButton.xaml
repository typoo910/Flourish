<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <!-- Terminal Button-family dictionary: this dependency chain loads each family resource once. -->
    <ResourceDictionary Source="WindowCaptionButton.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <ControlTemplate
    x:Key="CardButtonTemplate"
    TargetType="{x:Type controls:CardButton}"
  >
    <Grid SnapsToDevicePixels="True">
      <Border
        x:Name="ShadowChrome"
        Background="{TemplateBinding Background}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        Effect="{DynamicResource FlourishElevation1Effect}"
        IsHitTestVisible="False"
        Visibility="Collapsed"
      />
      <Grid
        x:Name="InteractionRoot"
        ClipToBounds="True"
        SnapsToDevicePixels="True"
      >
        <Border
          x:Name="Chrome"
          Background="{TemplateBinding Background}"
          BorderBrush="{TemplateBinding BorderBrush}"
          BorderThickness="{TemplateBinding BorderThickness}"
          CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        />
        <Border
          x:Name="HoverChrome"
          Background="{TemplateBinding controls:HoverReveal.OverrideColor}"
          BorderThickness="0"
          CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
          IsHitTestVisible="False"
          Opacity="0"
          RenderTransformOrigin="0.5,0.5"
        >
          <Border.RenderTransform>
            <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
          </Border.RenderTransform>
        </Border>
        <Border
          x:Name="PressedChrome"
          Background="{DynamicResource FlourishPressedRevealBrush}"
          BorderThickness="0"
          CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
          IsHitTestVisible="False"
          Opacity="0"
        />
        <DockPanel
          x:Name="ContentLayout"
          Margin="{TemplateBinding Padding}"
          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
          LastChildFill="True"
        >
          <ContentPresenter
            x:Name="IconHost"
            Margin="0,0,0,12"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            DockPanel.Dock="Top"
            Content="{TemplateBinding Icon}"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
            TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
            TextElement.FontSize="{DynamicResource FlourishFontSizeIcon}"
            TextElement.Foreground="{TemplateBinding Foreground}"
          />
          <StackPanel x:Name="CopyHost">
            <controls:FlourishTextBlock
              x:Name="TitleHost"
              Foreground="{TemplateBinding Foreground}"
              Role="CardTitle"
              Text="{TemplateBinding Title}"
            />
            <ContentPresenter
              x:Name="ContentHost"
              Margin="{DynamicResource FlourishCardTextSpacing}"
              Content="{TemplateBinding Content}"
              ContentStringFormat="{TemplateBinding ContentStringFormat}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
              TextElement.FontFamily="{DynamicResource FlourishFontFamily}"
              TextElement.FontSize="{DynamicResource FlourishFontSizeStandard}"
              TextElement.Foreground="{TemplateBinding Foreground}"
            />
          </StackPanel>
        </DockPanel>
      </Grid>
    </Grid>
    <ControlTemplate.Triggers>
      <Trigger Property="IconPosition" Value="Left">
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Left" />
        <Setter TargetName="IconHost" Property="Margin" Value="0,0,12,0" />
        <Setter TargetName="IconHost" Property="VerticalAlignment" Value="Center" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Right">
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Right" />
        <Setter TargetName="IconHost" Property="Margin" Value="12,0,0,0" />
        <Setter TargetName="IconHost" Property="HorizontalAlignment" Value="Right" />
        <Setter TargetName="IconHost" Property="VerticalAlignment" Value="Center" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Bottom">
        <Setter TargetName="IconHost" Property="DockPanel.Dock" Value="Bottom" />
        <Setter TargetName="IconHost" Property="Margin" Value="0,12,0,0" />
      </Trigger>
      <Trigger Property="Icon" Value="{x:Null}">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Icon" Value="">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True" />
          <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
        </MultiTrigger.Conditions>
        <Setter TargetName="HoverChrome" Property="Opacity" Value="1" />
        <Setter TargetName="HoverChrome" Property="RenderTransform">
          <Setter.Value>
            <ScaleTransform ScaleX="1" ScaleY="1" />
          </Setter.Value>
        </Setter>
      </MultiTrigger>
      <Trigger Property="Variant" Value="Elevated">
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Visible" />
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishControlPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishPrimaryBackgroundPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Tonal">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishTonalButtonPressedBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Danger">
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishDangerStrokeBrush}" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="HoverChrome" Property="Opacity" Value="0" />
        <Setter TargetName="PressedChrome" Property="Opacity" Value="1" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Variant" Value="Tonal" />
          <Condition Property="IsPressed" Value="True" />
        </MultiTrigger.Conditions>
        <Setter Property="Foreground" Value="{DynamicResource FlourishTonalButtonPressedForegroundBrush}" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
        <Setter Property="Background" Value="{DynamicResource FlourishControlDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlStrokeDisabledBrush}" />
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="HoverChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PressedChrome" Property="Visibility" Value="Collapsed" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style
    TargetType="{x:Type controls:CardButton}"
    BasedOn="{StaticResource {x:Type controls:Button}}"
  >
    <Setter Property="Padding" Value="{DynamicResource FlourishInteractiveCardPadding}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
    <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="Template" Value="{StaticResource CardButtonTemplate}" />
    <Style.Triggers>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinWidth" Value="{DynamicResource FlourishButtonMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource FlourishButtonHeight}" />
        <Setter Property="Padding" Value="{DynamicResource FlourishInteractiveCardPadding}" />
        <Setter Property="Template" Value="{StaticResource CardButtonTemplate}" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinWidth" Value="{DynamicResource FlourishButtonMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource FlourishButtonHeight}" />
        <Setter Property="Padding" Value="{DynamicResource FlourishInteractiveCardPadding}" />
        <Setter Property="Template" Value="{StaticResource CardButtonTemplate}" />
      </Trigger>
      <Trigger Property="Variant" Value="Standard">
        <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Elevated">
        <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Tonal">
        <Setter Property="Background" Value="{DynamicResource FlourishCardTonalBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter Property="Background" Value="{DynamicResource FlourishPrimaryBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishForegroundOnPrimaryBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
