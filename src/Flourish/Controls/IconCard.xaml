<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="ListCard.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <ControlTemplate x:Key="IconCardTemplate" TargetType="{x:Type controls:IconCard}">
    <Grid SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
      <Border
        x:Name="ShadowChrome"
        Background="{TemplateBinding Background}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        Effect="{DynamicResource FlourishElevation1Effect}"
        IsHitTestVisible="False"
        Visibility="Collapsed"
      />
      <Border
        Padding="{TemplateBinding Padding}"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
      >
        <DockPanel
          x:Name="ContentHost"
          HorizontalAlignment="{TemplateBinding ContentHorizontalAlignment}"
          VerticalAlignment="{TemplateBinding ContentVerticalAlignment}"
          LastChildFill="True"
        >
          <ContentPresenter
            x:Name="IconHost"
            Margin="{DynamicResource FlourishIconCardIconSpacingLeft}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            DockPanel.Dock="{TemplateBinding IconPosition}"
            Content="{TemplateBinding Icon}"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
            TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
            TextElement.FontSize="{DynamicResource FlourishFontSizeIcon}"
            TextElement.Foreground="{TemplateBinding Foreground}"
          />
          <StackPanel x:Name="CopyHost">
            <controls:FlourishTextBlock
              x:Name="TitleHost"
              Foreground="{TemplateBinding Foreground}"
              Role="CardTitle"
              Text="{TemplateBinding Title}"
            />
            <controls:FlourishTextBlock
              x:Name="MainTextHost"
              Margin="{DynamicResource FlourishCardTextSpacing}"
              Foreground="{TemplateBinding Foreground}"
              Role="Description"
              Text="{TemplateBinding MainText}"
            />
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>
    <ControlTemplate.Triggers>
      <Trigger Property="Variant" Value="Elevated">
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Visible" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Top">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishIconCardIconSpacingTop}" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Right">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishIconCardIconSpacingRight}" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Bottom">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishIconCardIconSpacingBottom}" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Left">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Left" />
        <Setter TargetName="MainTextHost" Property="TextAlignment" Value="Left" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Center">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Center" />
        <Setter TargetName="MainTextHost" Property="TextAlignment" Value="Center" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Right">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Right" />
        <Setter TargetName="MainTextHost" Property="TextAlignment" Value="Right" />
      </Trigger>
      <Trigger Property="Icon" Value="{x:Null}">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Icon" Value="">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="MainTextHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="MainTextHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="MainText" Value="">
        <Setter TargetName="MainTextHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="MainText" Value="{x:Null}">
        <Setter TargetName="MainTextHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="MainText" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="MainText" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="MainText" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="MainText" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style
    TargetType="{x:Type controls:IconCard}"
    BasedOn="{StaticResource {x:Type controls:Card}}"
  >
    <Setter Property="Template" Value="{StaticResource IconCardTemplate}" />
  </Style>
</ResourceDictionary>
