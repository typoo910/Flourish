<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="Button.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <ControlTemplate
    x:Key="WindowCaptionButtonTemplate"
    TargetType="{x:Type controls:WindowCaptionButton}"
  >
    <Grid x:Name="InteractionRoot" ClipToBounds="True" SnapsToDevicePixels="True">
      <Border
        x:Name="Chrome"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
      />
      <Border
        x:Name="HoverChrome"
        Background="{TemplateBinding controls:HoverReveal.OverrideColor}"
        IsHitTestVisible="False"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
      >
        <Border.RenderTransform>
          <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
        </Border.RenderTransform>
      </Border>
      <Border
        x:Name="PressedChrome"
        Background="{DynamicResource FlourishPressedRevealBrush}"
        IsHitTestVisible="False"
        Opacity="0"
      />
      <ContentPresenter
        Margin="{TemplateBinding Padding}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Content="{TemplateBinding Icon}"
        TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
        TextElement.FontSize="{DynamicResource FlourishIconFontSizeWindowCaption}"
        TextBlock.LineHeight="{DynamicResource FlourishIconFontSizeWindowCaption}"
        TextBlock.LineStackingStrategy="BlockLineHeight"
      />
    </Grid>
    <ControlTemplate.Triggers>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True" />
          <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
        </MultiTrigger.Conditions>
        <Setter TargetName="HoverChrome" Property="Opacity" Value="1" />
        <Setter TargetName="HoverChrome" Property="RenderTransform">
          <Setter.Value>
            <ScaleTransform ScaleX="1" ScaleY="1" />
          </Setter.Value>
        </Setter>
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Variant" Value="Danger" />
          <Condition Property="IsMouseOver" Value="True" />
        </MultiTrigger.Conditions>
        <Setter Property="Foreground" Value="{DynamicResource FlourishWindowCaptionCloseForegroundBrush}" />
      </MultiTrigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="HoverChrome" Property="Opacity" Value="0" />
        <Setter TargetName="PressedChrome" Property="Opacity" Value="1" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Variant" Value="Danger" />
          <Condition Property="IsPressed" Value="True" />
        </MultiTrigger.Conditions>
        <Setter TargetName="PressedChrome" Property="Background" Value="{DynamicResource FlourishWindowCaptionCloseHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishWindowCaptionCloseForegroundBrush}" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
        <Setter TargetName="HoverChrome" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="PressedChrome" Property="Visibility" Value="Collapsed" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style
    TargetType="{x:Type controls:WindowCaptionButton}"
    BasedOn="{StaticResource {x:Type controls:Button}}"
  >
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="40" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template" Value="{StaticResource WindowCaptionButtonTemplate}" />
    <Style.Triggers>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template" Value="{StaticResource WindowCaptionButtonTemplate}" />
      </Trigger>
      <Trigger Property="Variant" Value="Text">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Danger">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
        <Setter Property="controls:HoverReveal.OverrideColor" Value="{DynamicResource FlourishWindowCaptionCloseHoverBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
