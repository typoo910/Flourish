<UserControl
  x:Class="AckSS.Flourish.Controls.FlourishTitlebar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:ClassModifier="internal"
  mc:Ignorable="d"
>
  <Grid Background="Transparent">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <StackPanel
      x:Name="BreadcrumbNavigationHost"
      Grid.Column="0"
      Margin="4,0,0,0"
      Orientation="Horizontal"
    >
      <Button
        x:Name="BackButton"
        Width="38"
        Height="32"
        Margin="0,4,2,4"
        Click="BackButton_Click"
        IsEnabled="False"
        Style="{StaticResource FlourishIconButtonStyle}"
        ToolTip="Back"
      >
        <TextBlock
          FontFamily="{DynamicResource FlourishIconFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeTitlebarIcon}"
          Text="&#xE72B;"
        />
      </Button>

      <Button
        x:Name="ForwardButton"
        Width="38"
        Height="32"
        Margin="2,4"
        Click="ForwardButton_Click"
        IsEnabled="False"
        Style="{StaticResource FlourishIconButtonStyle}"
        ToolTip="Forward"
      >
        <TextBlock
          FontFamily="{DynamicResource FlourishIconFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeTitlebarIcon}"
          Text="&#xE72A;"
        />
      </Button>
    </StackPanel>

    <Button
      x:Name="NavigationToggleButton"
      Grid.Column="1"
      Width="38"
      Height="32"
      Margin="4,4"
      Click="NavigationToggleButton_Click"
      Style="{StaticResource FlourishIconButtonStyle}"
      ToolTip="Toggle navigation"
    >
      <TextBlock
        FontFamily="{DynamicResource FlourishIconFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeNavigationIcon}"
        Text="&#xE700;"
      />
    </Button>

    <StackPanel
      x:Name="BrandHost"
      Grid.Column="2"
      Margin="8,0,14,0"
      VerticalAlignment="Center"
      MouseLeftButtonDown="Titlebar_MouseLeftButtonDown"
      Orientation="Horizontal"
    >
      <Border
        x:Name="LogoHost"
        Width="26"
        Height="26"
        Background="{DynamicResource AccentSoftBrush}"
        ClipToBounds="True"
        CornerRadius="6"
      >
        <Grid>
          <Image x:Name="LogoImage" Stretch="UniformToFill" />
          <TextBlock
            x:Name="LogoFallback"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FlourishFontSizeTitle}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AccentBrush}"
          />
        </Grid>
      </Border>
      <StackPanel
        x:Name="TitleTextHost"
        Margin="8,0,0,0"
        VerticalAlignment="Center"
        Orientation="Horizontal"
      >
        <TextBlock
          x:Name="TitleText"
          VerticalAlignment="Center"
          FontSize="{DynamicResource FlourishFontSizeTitle}"
          FontWeight="SemiBold"
          Foreground="{DynamicResource PrimaryTextBrush}"
        />
        <TextBlock
          x:Name="SubtitleText"
          Margin="8,1,0,0"
          VerticalAlignment="Center"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          Foreground="{DynamicResource MutedTextBrush}"
        />
      </StackPanel>
    </StackPanel>

    <Border
      Grid.Column="3"
      Background="Transparent"
      MouseLeftButtonDown="Titlebar_MouseLeftButtonDown"
    />

    <Border
      x:Name="SearchBoxHost"
      Grid.Column="4"
      Width="320"
      Height="28"
      Margin="8,0,10,0"
      Padding="10,0"
      VerticalAlignment="Center"
      Background="{DynamicResource FlourishSearchBackgroundBrush}"
      BorderBrush="{DynamicResource CardBorderBrush}"
      BorderThickness="1"
      CornerRadius="8"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
          VerticalAlignment="Center"
          FontFamily="{DynamicResource FlourishIconFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeTitlebarIcon}"
          Foreground="{DynamicResource MutedTextBrush}"
          Text="&#xE721;"
        />
        <TextBox
          x:Name="SearchBox"
          Grid.Column="1"
          Margin="8,0,0,0"
          MinHeight="0"
          Padding="0"
          VerticalAlignment="Center"
          VerticalContentAlignment="Center"
          Background="Transparent"
          BorderThickness="0"
          CaretBrush="{DynamicResource PrimaryTextBrush}"
          FontFamily="{DynamicResource FlourishFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeCaption}"
          Foreground="{DynamicResource PrimaryTextBrush}"
          GotKeyboardFocus="SearchBox_GotKeyboardFocus"
          LostKeyboardFocus="SearchBox_LostKeyboardFocus"
          SelectionBrush="{DynamicResource AccentSoftBrush}"
          TextChanged="SearchBox_TextChanged"
        />
        <TextBlock
          x:Name="SearchPlaceholderText"
          Grid.Column="1"
          Margin="8,0,0,0"
          VerticalAlignment="Center"
          FontFamily="{DynamicResource FlourishFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeCaption}"
          Foreground="{DynamicResource MutedTextBrush}"
          IsHitTestVisible="False"
        />
      </Grid>
    </Border>

    <Button
      x:Name="ThemeToggleButton"
      Grid.Column="5"
      Width="38"
      Height="32"
      Margin="0,4,6,4"
      Click="ThemeToggleButton_Click"
      Style="{StaticResource FlourishIconButtonStyle}"
      ToolTip="Theme"
    >
      <TextBlock
        x:Name="ThemeToggleButtonIcon"
        FontFamily="{DynamicResource FlourishIconFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeTitlebarIcon}"
        Text="&#xE706;"
      />
    </Button>

    <Border
      x:Name="ProfileHost"
      Grid.Column="6"
      Width="26"
      Height="26"
      Margin="0,0,10,0"
      VerticalAlignment="Center"
      Background="{DynamicResource FlourishProfileBackgroundBrush}"
      CornerRadius="13"
    >
      <TextBlock
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        FontSize="{DynamicResource FlourishFontSizeCaption}"
        FontWeight="SemiBold"
        Foreground="{DynamicResource FlourishProfileForegroundBrush}"
        Text="JD"
      />
    </Border>

    <Button
      Grid.Column="7"
      Click="MinimizeButton_Click"
      Style="{StaticResource FlourishWindowCaptionButtonStyle}"
      ToolTip="Minimize"
    >
      <TextBlock
        FontFamily="{DynamicResource FlourishIconFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeWindowButtonIcon}"
        Text="&#xE921;"
      />
    </Button>

    <Button
      x:Name="MaximizeButton"
      Grid.Column="8"
      Click="MaximizeButton_Click"
      Style="{StaticResource FlourishWindowCaptionButtonStyle}"
      ToolTip="Maximize"
    >
      <TextBlock
        x:Name="MaximizeButtonIcon"
        FontFamily="{DynamicResource FlourishIconFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeWindowButtonIcon}"
        Text="&#xE922;"
      />
    </Button>

    <Button
      Grid.Column="9"
      Click="CloseButton_Click"
      Style="{StaticResource FlourishWindowCaptionCloseButtonStyle}"
      ToolTip="Close"
    >
      <TextBlock
        FontFamily="{DynamicResource FlourishIconFontFamily}"
        FontSize="{DynamicResource FlourishFontSizeWindowButtonIcon}"
        Text="&#xE8BB;"
      />
    </Button>
  </Grid>
</UserControl>
