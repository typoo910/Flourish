<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <Style
    x:Key="FlourishNavigationPaneGridSplitterPreviewStyle"
    TargetType="{x:Type Control}"
  >
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Control}">
          <Border
            x:Name="PreviewIndicator"
            Margin="1"
            Background="{DynamicResource FlourishPrimaryForegroundBrush}"
            CornerRadius="1"
            IsHitTestVisible="False"
            Opacity="0.86"
            SnapsToDevicePixels="True"
          />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="{x:Type controls:FlourishGridSplitter}">
    <Setter Property="Width" Value="4" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:FlourishGridSplitter}">
          <Grid Background="{TemplateBinding Background}">
            <Border
              x:Name="SplitterIndicator"
              Margin="1"
              Background="{DynamicResource FlourishPrimaryForegroundBrush}"
              CornerRadius="1"
              IsHitTestVisible="False"
              Opacity="0"
            />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="SplitterIndicator" Property="Opacity" Value="0.72" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="SplitterIndicator" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="SplitterIndicator" Property="Background" Value="{DynamicResource FlourishNeutralForegroundDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="Variant" Value="NavigationPane">
        <Setter Property="Width" Value="7" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="ResizeDirection" Value="Columns" />
        <Setter Property="ShowsPreview" Value="True" />
        <Setter
          Property="PreviewStyle"
          Value="{StaticResource FlourishNavigationPaneGridSplitterPreviewStyle}"
        />
        <Setter Property="Panel.ZIndex" Value="10" />
      </Trigger>
      <Trigger Property="ResizeDirection" Value="Rows">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="SizeNS" />
      </Trigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
