<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="Card.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <ControlTemplate x:Key="ActionCardTemplate" TargetType="{x:Type controls:ActionCard}">
    <Border
      x:Name="SurfaceChrome"
      Padding="{TemplateBinding Padding}"
      Background="{TemplateBinding Background}"
      BorderBrush="{TemplateBinding BorderBrush}"
      BorderThickness="{TemplateBinding BorderThickness}"
      CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
    >
      <Grid x:Name="LayoutRoot">
        <Grid.ColumnDefinitions>
          <ColumnDefinition x:Name="IconColumn" Width="Auto" />
          <ColumnDefinition x:Name="CopyColumn" Width="*" />
          <ColumnDefinition x:Name="BodyColumn" Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition x:Name="IconRow" Height="*" />
          <RowDefinition x:Name="CopyRow" Height="0" />
          <RowDefinition x:Name="BodyRow" Height="0" />
        </Grid.RowDefinitions>

        <ContentPresenter
          x:Name="IconHost"
          Grid.Row="0"
          Grid.Column="0"
          Margin="{DynamicResource FlourishActionCardHorizontalIconSpacing}"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Content="{TemplateBinding Icon}"
          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
          TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
          TextElement.FontSize="{DynamicResource FlourishFontSizeIcon}"
          TextElement.Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
        />
        <StackPanel
          x:Name="CopyHost"
          Grid.Row="0"
          Grid.Column="1"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Center"
        >
          <controls:FlourishTextBlock
            x:Name="TitleHost"
            Foreground="{TemplateBinding Foreground}"
            Role="CardTitle"
            Text="{TemplateBinding Title}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap"
          />
          <controls:FlourishTextBlock
            x:Name="ContentHost"
            Margin="{DynamicResource FlourishCardTextSpacing}"
            Foreground="{TemplateBinding Foreground}"
            Role="Description"
            Text="{TemplateBinding Content}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap"
          />
        </StackPanel>
        <ContentPresenter
          x:Name="BodyHost"
          Grid.Row="0"
          Grid.Column="2"
          Margin="{DynamicResource FlourishActionCardHorizontalBodySpacing}"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Content="{TemplateBinding Body}"
          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
          TextElement.Foreground="{TemplateBinding Foreground}"
        />
      </Grid>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="Variant" Value="Vertical">
        <Setter TargetName="IconColumn" Property="Width" Value="*" />
        <Setter TargetName="CopyColumn" Property="Width" Value="0" />
        <Setter TargetName="BodyColumn" Property="Width" Value="0" />
        <Setter TargetName="IconRow" Property="Height" Value="Auto" />
        <Setter TargetName="CopyRow" Property="Height" Value="Auto" />
        <Setter TargetName="BodyRow" Property="Height" Value="Auto" />
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishActionCardVerticalIconSpacing}" />
        <Setter TargetName="IconHost" Property="VerticalAlignment" Value="Top" />
        <Setter TargetName="CopyHost" Property="Grid.Row" Value="1" />
        <Setter TargetName="CopyHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="CopyHost" Property="HorizontalAlignment" Value="Left" />
        <Setter TargetName="CopyHost" Property="VerticalAlignment" Value="Top" />
        <Setter TargetName="TitleHost" Property="TextTrimming" Value="None" />
        <Setter TargetName="TitleHost" Property="TextWrapping" Value="Wrap" />
        <Setter TargetName="ContentHost" Property="TextTrimming" Value="None" />
        <Setter TargetName="ContentHost" Property="TextWrapping" Value="Wrap" />
        <Setter TargetName="BodyHost" Property="Grid.Row" Value="2" />
        <Setter TargetName="BodyHost" Property="Grid.Column" Value="0" />
        <Setter TargetName="BodyHost" Property="Margin" Value="{DynamicResource FlourishActionCardVerticalBodySpacing}" />
        <Setter TargetName="BodyHost" Property="HorizontalAlignment" Value="Left" />
        <Setter TargetName="BodyHost" Property="VerticalAlignment" Value="Top" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Icon" Value="{x:Null}">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Icon" Value="">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Body" Value="{x:Null}">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Body" Value="">
        <Setter TargetName="BodyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="BodyHost" Property="Margin" Value="0" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:ActionCard}">
    <Setter Property="MinHeight" Value="{DynamicResource FlourishActionCardMinHeight}" />
    <Setter Property="Padding" Value="{DynamicResource FlourishActionCardPadding}" />
    <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource ActionCardTemplate}" />
  </Style>
</ResourceDictionary>
