<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <ControlTemplate x:Key="CardTemplate" TargetType="{x:Type controls:Card}">
    <Grid SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
      <Border
        x:Name="ShadowChrome"
        Background="{TemplateBinding Background}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        Effect="{DynamicResource FlourishElevation1Effect}"
        IsHitTestVisible="False"
        Visibility="Collapsed"
      />
      <Border
        x:Name="SurfaceChrome"
        Padding="{TemplateBinding Padding}"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="{DynamicResource FlourishSurfaceCornerRadius}"
        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
      >
        <DockPanel
          x:Name="ContentLayout"
          HorizontalAlignment="{TemplateBinding ContentHorizontalAlignment}"
          VerticalAlignment="{TemplateBinding ContentVerticalAlignment}"
          LastChildFill="True"
        >
          <ContentPresenter
            x:Name="IconHost"
            Margin="{DynamicResource FlourishCardIconSpacingLeft}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            DockPanel.Dock="{TemplateBinding IconPosition}"
            Content="{TemplateBinding Icon}"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
            TextElement.FontFamily="{DynamicResource FlourishIconFontFamily}"
            TextElement.FontSize="{DynamicResource FlourishFontSizeIcon}"
            TextElement.Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
          />
          <StackPanel x:Name="CopyHost">
            <controls:FlourishTextBlock
              x:Name="TitleHost"
              Foreground="{TemplateBinding Foreground}"
              Role="CardTitle"
              Text="{TemplateBinding Title}"
            />
            <controls:FlourishTextBlock
              x:Name="ContentHost"
              Margin="{DynamicResource FlourishCardTextSpacing}"
              Foreground="{TemplateBinding Foreground}"
              Role="Description"
              Text="{TemplateBinding Content}"
            />
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>
    <ControlTemplate.Triggers>
      <Trigger Property="Variant" Value="Elevated">
        <Setter TargetName="ShadowChrome" Property="Visibility" Value="Visible" />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter TargetName="IconHost" Property="TextElement.Foreground" Value="{DynamicResource FlourishForegroundOnPrimaryBrush}" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Top">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishCardIconSpacingTop}" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Right">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishCardIconSpacingRight}" />
      </Trigger>
      <Trigger Property="IconPosition" Value="Bottom">
        <Setter TargetName="IconHost" Property="Margin" Value="{DynamicResource FlourishCardIconSpacingBottom}" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Left">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Left" />
        <Setter TargetName="ContentHost" Property="TextAlignment" Value="Left" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Center">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Center" />
        <Setter TargetName="ContentHost" Property="TextAlignment" Value="Center" />
      </Trigger>
      <Trigger Property="ContentHorizontalAlignment" Value="Right">
        <Setter TargetName="TitleHost" Property="TextAlignment" Value="Right" />
        <Setter TargetName="ContentHost" Property="TextAlignment" Value="Right" />
      </Trigger>
      <Trigger Property="Icon" Value="{x:Null}">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Icon" Value="">
        <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Title" Value="{x:Null}">
        <Setter TargetName="TitleHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="ContentHost" Property="Margin" Value="0" />
      </Trigger>
      <Trigger Property="Content" Value="">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <Trigger Property="Content" Value="{x:Null}">
        <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="" />
          <Condition Property="Content" Value="{x:Null}" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="Title" Value="{x:Null}" />
          <Condition Property="Content" Value="" />
        </MultiTrigger.Conditions>
        <Setter TargetName="CopyHost" Property="Visibility" Value="Collapsed" />
        <Setter TargetName="IconHost" Property="Margin" Value="0" />
      </MultiTrigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.62" />
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style TargetType="{x:Type controls:Card}">
    <Setter Property="Padding" Value="{DynamicResource FlourishCardPadding}" />
    <Setter Property="Background" Value="{DynamicResource FlourishCardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishSurfaceStrokeBrush}" />
    <Setter Property="BorderThickness" Value="{DynamicResource FlourishSurfaceBorderThickness}" />
    <Setter Property="Foreground" Value="{DynamicResource FlourishNeutralForeground1Brush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeStandard}" />
    <Setter Property="ContentHorizontalAlignment" Value="Stretch" />
    <Setter Property="ContentVerticalAlignment" Value="Stretch" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template" Value="{StaticResource CardTemplate}" />
    <Style.Triggers>
      <Trigger Property="Variant" Value="Tonal">
        <Setter Property="Background" Value="{DynamicResource FlourishCardTonalBackgroundBrush}" />
      </Trigger>
      <Trigger Property="Variant" Value="Filled">
        <Setter Property="Background" Value="{DynamicResource FlourishPrimaryBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlourishForegroundOnPrimaryBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
