<Window
  x:Class="ArkheideSystem.Flourish.Windows.FlourishShellWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:control="clr-namespace:ArkheideSystem.Flourish.Controls"
  Width="1100"
  Height="720"
  MinWidth="820"
  MinHeight="560"
  x:ClassModifier="internal"
  Background="{DynamicResource AppBackgroundBrush}"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d"
>
  <Window.Resources>
    <Style x:Key="FlourishNavigationPaneSplitterStyle" TargetType="{x:Type GridSplitter}">
      <Setter Property="Width" Value="7" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Cursor" Value="SizeWE" />
      <Setter Property="ResizeDirection" Value="Columns" />
      <Setter Property="ShowsPreview" Value="True" />
      <Setter Property="Panel.ZIndex" Value="10" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type GridSplitter}">
            <Grid Background="{TemplateBinding Background}">
              <Border
                x:Name="SplitterIndicator"
                Width="2"
                HorizontalAlignment="Center"
                Background="{DynamicResource AccentBrush}"
                CornerRadius="1"
                IsHitTestVisible="False"
                Opacity="0"
              />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SplitterIndicator" Property="Opacity" Value="0.72" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style
      x:Key="FlourishStatusIconButtonStyle"
      BasedOn="{StaticResource FlourishIconButtonStyle}"
      TargetType="{x:Type Button}"
    >
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Margin" Value="2,0,0,0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <DataTemplate x:Key="FlourishNavigationItemTemplate">
      <Grid x:Name="NavigationTemplateRoot">
        <TextBlock
          x:Name="NavigationGroupHeader"
          FontSize="{DynamicResource FlourishFontSizeSmall}"
          FontWeight="Normal"
          Foreground="{DynamicResource MutedTextBrush}"
          Opacity="0.72"
          Text="{Binding Label}"
          Visibility="Collapsed"
        />

        <Grid
          x:Name="NavigationItemLayout"
          Margin="{Binding IndentMargin}"
        >
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
          </Grid.ColumnDefinitions>
          <TextBlock
            x:Name="NavigationItemIcon"
            Width="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="{DynamicResource FlourishFontSizeNavigationIcon}"
            Text="{Binding IconGlyph}"
            TextAlignment="Center"
          />
          <TextBlock
            x:Name="NavigationItemLabel"
            Grid.Column="1"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            Text="{Binding Label}"
          />
          <TextBlock
            x:Name="NavigationItemExpander"
            Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="{DynamicResource FlourishFontSizeCaption}"
            Text="{Binding ExpandGlyph}"
          />
        </Grid>
      </Grid>
      <DataTemplate.Triggers>
        <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
          <Setter TargetName="NavigationGroupHeader" Property="Visibility" Value="Visible" />
          <Setter TargetName="NavigationItemLayout" Property="Visibility" Value="Collapsed" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsActiveChildParent}" Value="True">
          <Setter
            TargetName="NavigationItemLabel"
            Property="Foreground"
            Value="{DynamicResource AccentBrush}"
          />
        </DataTrigger>
        <DataTrigger
          Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}"
          Value="False"
        >
          <Setter TargetName="NavigationGroupHeader" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="NavigationItemLabel" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="NavigationItemExpander" Property="Visibility" Value="Collapsed" />
          <Setter TargetName="NavigationItemLayout" Property="Width" Value="20" />
        </DataTrigger>
      </DataTemplate.Triggers>
    </DataTemplate>
  </Window.Resources>

  <Border
    x:Name="ShellBorder"
    BorderBrush="{DynamicResource CardBorderBrush}"
    BorderThickness="1"
  >
    <Grid x:Name="ShellRootGrid" SizeChanged="ShellRootGrid_SizeChanged">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <control:FlourishTitlebar
        x:Name="Titlebar"
        Grid.Row="0"
        Height="40"
      />

      <Border
        Grid.Row="1"
        Margin="0"
        Background="Transparent"
        BorderThickness="0"
        ClipToBounds="True"
      >
        <Grid x:Name="WorkAreaGrid">
          <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PaneColumn" Width="220" />
            <ColumnDefinition x:Name="ContentColumn" Width="*" />
          </Grid.ColumnDefinitions>

          <Border
            x:Name="NavigationPaneBorder"
            Grid.Column="0"
            Background="Transparent"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="0,0,1,0"
          >
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <StackPanel
                x:Name="NavigationHeaderRegionHost"
                Grid.Row="0"
                Orientation="Vertical"
                Visibility="Collapsed"
              />
              <ListBox
                x:Name="NavigationItemsHost"
                Grid.Row="1"
                ItemTemplate="{StaticResource FlourishNavigationItemTemplate}"
                ItemContainerStyle="{StaticResource FlourishNavigationListBoxItemStyle}"
                ItemsSource="{Binding}"
                ScrollViewer.CanContentScroll="True"
                PreviewKeyDown="NavigationItemsHost_PreviewKeyDown"
                PreviewMouseLeftButtonDown="NavigationItemsHost_PreviewMouseLeftButtonDown"
                SelectionChanged="NavigationItemsHost_SelectionChanged"
                Style="{StaticResource FlourishNavigationListBoxStyle}"
                Tag="True"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling"
              >
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>

              <Border
                x:Name="FixedNavigationItemsBorder"
                Grid.Row="2"
                Padding="0,6,0,6"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed"
              >
                <ListBox
                  x:Name="FixedNavigationItemsHost"
                  ItemTemplate="{StaticResource FlourishNavigationItemTemplate}"
                  ItemContainerStyle="{StaticResource FlourishNavigationListBoxItemStyle}"
                  ItemsSource="{Binding}"
                  PreviewKeyDown="NavigationItemsHost_PreviewKeyDown"
                  PreviewMouseLeftButtonDown="NavigationItemsHost_PreviewMouseLeftButtonDown"
                  SelectionChanged="NavigationItemsHost_SelectionChanged"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  Style="{StaticResource FlourishNavigationListBoxStyle}"
                  Tag="True"
                />
              </Border>
              <StackPanel
                x:Name="NavigationFooterRegionHost"
                Grid.Row="3"
                Orientation="Vertical"
                Visibility="Collapsed"
              />
            </Grid>
          </Border>

          <Grid x:Name="ContentAreaGrid" Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
              x:Name="ContentHeaderRegionHost"
              Grid.Row="0"
              Orientation="Vertical"
              Visibility="Collapsed"
            />

            <Border
              x:Name="ToolbarHostBorder"
              Grid.Row="1"
              Margin="8,0,8,4"
              Padding="2"
              Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1"
              CornerRadius="6"
            >
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                  x:Name="ToolbarStartRegionHost"
                  Grid.Column="0"
                  Orientation="Horizontal"
                  Visibility="Collapsed"
                />
                <StackPanel
                  x:Name="ToolbarItemsHost"
                  Grid.Column="1"
                  Orientation="Horizontal"
                />
                <StackPanel
                  x:Name="ToolbarEndRegionHost"
                  Grid.Column="2"
                  Orientation="Horizontal"
                  Visibility="Collapsed"
                />
              </Grid>
            </Border>

            <Border
              x:Name="BreadcrumbHost"
              Grid.Row="2"
              Margin="12,0,12,8"
              Padding="12,0"
              Background="Transparent"
            >
              <TextBlock
                x:Name="BreadcrumbText"
                VerticalAlignment="Center"
                FontSize="{DynamicResource FlourishFontSizeCaption}"
                Foreground="{DynamicResource MutedTextBrush}"
              />
            </Border>

            <Grid x:Name="ContentFrameHost" Grid.Row="3">
              <Frame
                x:Name="RootFrame"
                Focusable="False"
                JournalOwnership="OwnsJournal"
                NavigationUIVisibility="Hidden"
              />
              <Grid
                x:Name="ContentOverlayRegionHost"
                Panel.ZIndex="10"
                Visibility="Collapsed"
              />
            </Grid>

            <StackPanel
              x:Name="ContentFooterRegionHost"
              Grid.Row="4"
              Orientation="Vertical"
              Visibility="Collapsed"
            />
          </Grid>

          <GridSplitter
            x:Name="NavigationPaneSplitter"
            Grid.Column="0"
            DragCompleted="NavigationPaneSplitter_DragCompleted"
            DragStarted="NavigationPaneSplitter_DragStarted"
            Style="{StaticResource FlourishNavigationPaneSplitterStyle}"
            Visibility="Collapsed"
          />
        </Grid>
      </Border>

      <Border
        x:Name="StatusBarBorder"
        Grid.Row="2"
        Panel.ZIndex="120"
        Padding="8,3"
        Background="{DynamicResource CardSecondaryBackgroundBrush}"
        BorderBrush="{DynamicResource CardBorderBrush}"
        BorderThickness="0,1,0,0"
        PreviewMouseLeftButtonDown="StatusBarBorder_PreviewMouseLeftButtonDown"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel
            x:Name="BackgroundTaskItemsHost"
            Grid.Column="0"
            AutomationProperties.LiveSetting="Polite"
            VerticalAlignment="Center"
            Orientation="Horizontal"
          />

          <Button
            x:Name="BackgroundTaskQueueButton"
            Grid.Column="1"
            Click="BackgroundTaskQueueButton_Click"
            MouseEnter="BackgroundTaskQueueButton_MouseEnter"
            Style="{StaticResource FlourishStatusIconButtonStyle}"
            Visibility="Collapsed"
          >
            <Grid>
              <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="{DynamicResource FlourishFontSizeCaption}"
                Text="&#xE8FD;"
              />
              <Border
                MinWidth="12"
                Height="12"
                Margin="10,-7,-7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{DynamicResource AccentBrush}"
                CornerRadius="6"
              >
                <TextBlock
                  x:Name="BackgroundTaskQueueCountText"
                  Margin="2,0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontSize="8"
                  Foreground="White"
                  TextAlignment="Center"
                />
              </Border>
            </Grid>
          </Button>

          <StackPanel
            x:Name="FooterStartRegionHost"
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Visibility="Collapsed"
          />

          <StackPanel
            x:Name="StatusItemsHost"
            Grid.Column="4"
            VerticalAlignment="Center"
            Orientation="Horizontal"
          />

          <Button
            x:Name="SystemStatusButton"
            Grid.Column="5"
            Click="SystemStatusButton_Click"
            MouseEnter="SystemStatusButton_MouseEnter"
            Style="{StaticResource FlourishStatusIconButtonStyle}"
            Visibility="Collapsed"
          >
            <TextBlock
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              FontFamily="{DynamicResource FlourishIconFontFamily}"
              FontSize="{DynamicResource FlourishFontSizeCaption}"
              Text="&#xE950;"
            />
          </Button>

          <StackPanel
            x:Name="FooterEndRegionHost"
            Grid.Column="6"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Visibility="Collapsed"
          />
        </Grid>
      </Border>

      <Canvas
        x:Name="ProfileOverlay"
        Grid.RowSpan="3"
        Panel.ZIndex="130"
        Background="Transparent"
        ClipToBounds="True"
        PreviewMouseLeftButtonDown="ProfileOverlay_PreviewMouseLeftButtonDown"
        Visibility="Collapsed"
      >
        <Grid
          x:Name="ProfileCard"
          Width="304"
          SizeChanged="ProfileCard_SizeChanged"
        >
          <Border
            Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="8"
          >
            <Border.Effect>
              <DropShadowEffect
                BlurRadius="16"
                Direction="270"
                Opacity="0.2"
                ShadowDepth="3"
                Color="#000000"
              />
            </Border.Effect>
          </Border>
          <Border
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
          >
            <Frame
              x:Name="ProfileFrame"
              Background="Transparent"
              BorderBrush="{x:Null}"
              BorderThickness="0"
              ClipToBounds="True"
              Focusable="False"
              FocusVisualStyle="{x:Null}"
              JournalOwnership="OwnsJournal"
              NavigationUIVisibility="Hidden"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              ScrollViewer.VerticalScrollBarVisibility="Disabled"
              SizeChanged="ProfileFrame_SizeChanged"
            />
          </Border>
        </Grid>
      </Canvas>

      <Canvas
        x:Name="StatusFlyoutOverlay"
        Grid.RowSpan="3"
        Panel.ZIndex="110"
        Background="Transparent"
        ClipToBounds="True"
        PreviewMouseLeftButtonDown="StatusFlyoutOverlay_PreviewMouseLeftButtonDown"
        Visibility="Collapsed"
      >
        <Grid
          x:Name="StatusFlyoutCard"
          Width="360"
          AutomationProperties.LiveSetting="Polite"
          Focusable="True"
          KeyboardNavigation.TabNavigation="Cycle"
          SizeChanged="StatusFlyoutCard_SizeChanged"
        >
          <Border
            Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="8"
          >
            <Border.Effect>
              <DropShadowEffect
                BlurRadius="16"
                Direction="90"
                Opacity="0.2"
                ShadowDepth="3"
                Color="#000000"
              />
            </Border.Effect>
          </Border>
          <Border
            Padding="14,12"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
          >
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock
                x:Name="StatusFlyoutTitle"
                Margin="0,0,0,10"
                Focusable="True"
                FontSize="{DynamicResource FlourishFontSizeBase}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource PrimaryTextBrush}"
              />
              <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
              >
                <StackPanel x:Name="StatusFlyoutContentHost" />
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Canvas>
    </Grid>
  </Border>
</Window>
