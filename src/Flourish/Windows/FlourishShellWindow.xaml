<Window
  x:Class="AcksheedSys.Flourish.Windows.FlourishShellWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Width="1100"
  Height="720"
  MinWidth="820"
  MinHeight="560"
  x:ClassModifier="internal"
  Background="{StaticResource AppBackgroundBrush}"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  mc:Ignorable="d"
>
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="0"
      CornerRadius="0"
      GlassFrameThickness="0"
      ResizeBorderThickness="6"
      UseAeroCaptionButtons="False"
    />
  </shell:WindowChrome.WindowChrome>

  <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid x:Name="AppTitleBar" Grid.Row="0" Height="54" Margin="6,4,6,0" Background="Transparent">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button
          x:Name="BackButton"
          Grid.Column="0"
          Margin="2,8"
          Click="TitleBar_BackRequested"
          IsEnabled="False"
          Style="{StaticResource FlourishIconButtonStyle}"
          ToolTip="Back"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE72B;" />
        </Button>

        <Button
          x:Name="PaneToggleButton"
          Grid.Column="1"
          Margin="2,8"
          Click="TitleBar_PaneToggleRequested"
          Style="{StaticResource FlourishIconButtonStyle}"
          ToolTip="Toggle navigation"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE700;" />
        </Button>

        <StackPanel
          Grid.Column="2"
          Margin="10,0,16,0"
          VerticalAlignment="Center"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
          Orientation="Horizontal"
        >
          <Border
            Width="32"
            Height="32"
            Background="{StaticResource AccentSoftBrush}"
            CornerRadius="8"
          >
            <Grid>
              <Image x:Name="AppLogoImage" Margin="5" Stretch="Uniform" Visibility="Collapsed" />
              <TextBlock
                x:Name="AppLogoFallback"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{StaticResource AccentBrush}"
              />
            </Grid>
          </Border>
          <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock
              x:Name="AppTitleText"
              FontSize="15"
              FontWeight="SemiBold"
              Foreground="{StaticResource PrimaryTextBrush}"
            />
            <TextBlock
              x:Name="AppSubtitleText"
              Margin="0,1,0,0"
              FontSize="11"
              Foreground="{StaticResource MutedTextBrush}"
            />
          </StackPanel>
        </StackPanel>

        <Border
          Grid.Column="3"
          Background="Transparent"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
        />

        <Border
          x:Name="SearchBoxHost"
          Grid.Column="4"
          Width="320"
          Height="34"
          Margin="8,0,12,0"
          Padding="10,0"
          VerticalAlignment="Center"
          Background="White"
          BorderBrush="{StaticResource CardBorderBrush}"
          BorderThickness="1"
          CornerRadius="8"
        >
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
              VerticalAlignment="Center"
              FontFamily="Segoe MDL2 Assets"
              Foreground="{StaticResource MutedTextBrush}"
              Text="&#xE721;"
            />
            <TextBox
              x:Name="SearchBox"
              Grid.Column="1"
              Margin="8,0,0,0"
              VerticalContentAlignment="Center"
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource PrimaryTextBrush}"
            />
          </Grid>
        </Border>

        <Border
          Grid.Column="5"
          Width="30"
          Height="30"
          Margin="0,0,12,0"
          VerticalAlignment="Center"
          Background="#E0F2FE"
          CornerRadius="15"
        >
          <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="12"
            FontWeight="SemiBold"
            Foreground="#0369A1"
            Text="JD"
          />
        </Border>

        <Button
          Grid.Column="6"
          Click="MinimizeButton_Click"
          Style="{StaticResource FlourishIconButtonStyle}"
          ToolTip="Minimize"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE921;" />
        </Button>

        <Button
          Grid.Column="7"
          Click="MaximizeButton_Click"
          Style="{StaticResource FlourishIconButtonStyle}"
          ToolTip="Maximize"
        >
          <TextBlock
            x:Name="MaximizeButtonIcon"
            FontFamily="Segoe MDL2 Assets"
            FontSize="11"
            Text="&#xE922;"
          />
        </Button>

        <Button
          Grid.Column="8"
          Click="CloseButton_Click"
          Style="{StaticResource FlourishCloseButtonStyle}"
          ToolTip="Close"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE8BB;" />
        </Button>
      </Grid>

      <Border
        x:Name="ToolbarHostBorder"
        Grid.Row="1"
        Margin="12,0,12,8"
        Padding="6"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        CornerRadius="8"
      >
        <StackPanel x:Name="ToolbarItemsHost" Orientation="Horizontal" />
      </Border>

      <Border
        x:Name="BreadcrumbHost"
        Grid.Row="2"
        Margin="12,0,12,8"
        Padding="12,0"
        Background="Transparent"
      >
        <TextBlock
          x:Name="BreadcrumbText"
          VerticalAlignment="Center"
          FontSize="12"
          Foreground="{StaticResource MutedTextBrush}"
        />
      </Border>

      <Border
        Grid.Row="3"
        Margin="12,0,12,8"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        ClipToBounds="True"
        CornerRadius="8"
      >
        <Grid x:Name="WorkAreaGrid">
          <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PaneColumn" Width="220" />
            <ColumnDefinition x:Name="ContentColumn" Width="*" />
          </Grid.ColumnDefinitions>

          <Border
            x:Name="NavigationPaneBorder"
            Grid.Column="0"
            Background="#FBFCFE"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="0,0,1,0"
          >
            <DockPanel LastChildFill="True">
              <TextBlock
                x:Name="PaneTitle"
                Margin="20,16,16,8"
                DockPanel.Dock="Top"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource MutedTextBrush}"
              />

              <ListBox
                x:Name="NavigationItemsHost"
                DockPanel.Dock="Top"
                ItemContainerStyle="{StaticResource FlourishNavigationListBoxItemStyle}"
                ItemsSource="{Binding}"
                ScrollViewer.CanContentScroll="True"
                SelectionChanged="NavigationItemsHost_SelectionChanged"
                Style="{StaticResource FlourishNavigationListBoxStyle}"
                Tag="True"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling"
              >
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        Text="{Binding IconGlyph}"
                      />
                      <TextBlock
                        x:Name="NavigationItemLabel"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Label}"
                      />
                    </Grid>
                    <DataTemplate.Triggers>
                      <DataTrigger
                        Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        Value="False"
                      >
                        <Setter
                          TargetName="NavigationItemLabel"
                          Property="Visibility"
                          Value="Collapsed"
                        />
                      </DataTrigger>
                    </DataTemplate.Triggers>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>

          <Frame
            x:Name="RootFrame"
            Grid.Column="1"
            Focusable="False"
            JournalOwnership="OwnsJournal"
            NavigationUIVisibility="Hidden"
          />
        </Grid>
      </Border>

      <Border
        Grid.Row="4"
        Padding="12,10"
        Background="{StaticResource CardSecondaryBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="0,1,0,0"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock
            x:Name="StatusTextBlock"
            VerticalAlignment="Center"
            Foreground="{StaticResource MutedTextBrush}"
          />

          <StackPanel x:Name="StatusItemsHost" Grid.Column="1" Orientation="Horizontal" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
