<Window
  x:Class="ArkheideSystem.Flourish.Windows.FlourishMessageBoxWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  Width="480"
  MinWidth="420"
  MaxWidth="620"
  SizeToContent="Height"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowStartupLocation="CenterOwner"
  WindowStyle="None"
  x:ClassModifier="internal"
  AllowsTransparency="True"
  Background="Transparent"
  SnapsToDevicePixels="True"
  TextOptions.TextFormattingMode="Display"
  UseLayoutRounding="True"
  mc:Ignorable="d"
>
  <Window.Resources>
    <sys:Boolean x:Key="FlourishHoverRevealEnabled">True</sys:Boolean>
    <sys:Int32 x:Key="FlourishToolTipInitialShowDelay">200</sys:Int32>
    <Style x:Key="FlourishMessageBoxButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter
        Property="Background"
        Value="{DynamicResource FlourishMessageBoxSecondarySurfaceBrush}"
      />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
      <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6"
            >
              <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RecognizesAccessKey="True"
              />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter
                  TargetName="Chrome"
                  Property="Background"
                  Value="{DynamicResource FlourishControlHoverBrush}"
                />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter
                  TargetName="Chrome"
                  Property="Background"
                  Value="{DynamicResource FlourishControlHoverBrush}"
                />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style
      x:Key="FlourishMessageBoxPrimaryButtonStyle"
      TargetType="{x:Type Button}"
    >
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
      <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border
              x:Name="Chrome"
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6"
            >
              <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RecognizesAccessKey="True"
              />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter
                  TargetName="Chrome"
                  Property="Background"
                  Value="{DynamicResource FlourishPrimaryButtonHoverBrush}"
                />
                <Setter
                  TargetName="Chrome"
                  Property="BorderBrush"
                  Value="{DynamicResource FlourishPrimaryButtonHoverBrush}"
                />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter
                  TargetName="Chrome"
                  Property="Background"
                  Value="{DynamicResource FlourishPrimaryButtonPressedBrush}"
                />
                <Setter
                  TargetName="Chrome"
                  Property="BorderBrush"
                  Value="{DynamicResource FlourishPrimaryButtonPressedBrush}"
                />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="30,28,30,46">
    <Border
      Background="{DynamicResource FlourishMessageBoxSurfaceBrush}"
      CornerRadius="10"
      IsHitTestVisible="False"
      SnapsToDevicePixels="True"
    >
      <Border.Effect>
        <DropShadowEffect
          BlurRadius="32"
          Direction="270"
          Opacity="0.26"
          ShadowDepth="6"
          Color="#000000"
        />
      </Border.Effect>
    </Border>

    <Border
      Background="{DynamicResource FlourishMessageBoxSurfaceBrush}"
      CornerRadius="10"
      SnapsToDevicePixels="True"
    >
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid
        x:Name="Header"
        Grid.Row="0"
        Height="40"
        Background="Transparent"
        MouseLeftButtonDown="Header_MouseLeftButtonDown"
      >
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
          x:Name="CaptionText"
          Margin="16,0,8,0"
          VerticalAlignment="Center"
          FontFamily="{DynamicResource FlourishFontFamily}"
          FontSize="{DynamicResource FlourishFontSizeCaption}"
          FontWeight="SemiBold"
          Foreground="{DynamicResource PrimaryTextBrush}"
          TextTrimming="CharacterEllipsis"
        />
        <Button
          x:Name="CloseButton"
          Grid.Column="1"
          Click="CloseButton_Click"
          Style="{StaticResource FlourishWindowCaptionCloseButtonStyle}"
        >
          <TextBlock
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="{DynamicResource FlourishFontSizeWindowButtonIcon}"
            Text="&#xE8BB;"
          />
        </Button>
      </Grid>

      <Grid
        Grid.Row="1"
        Margin="20,6,20,18"
      >
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
          x:Name="IconHost"
          Width="36"
          Height="36"
          Margin="0,1,14,0"
          VerticalAlignment="Top"
          Background="{DynamicResource AccentSoftBrush}"
          CornerRadius="18"
        >
          <TextBlock
            x:Name="IconText"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="16"
            Foreground="{DynamicResource AccentBrush}"
            TextAlignment="Center"
          />
        </Border>

        <ScrollViewer
          Grid.Column="1"
          MaxHeight="260"
          HorizontalScrollBarVisibility="Disabled"
          VerticalScrollBarVisibility="Auto"
        >
          <TextBlock
            x:Name="MessageText"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishFontFamily}"
            FontSize="{DynamicResource FlourishFontSizeBase}"
            Foreground="{DynamicResource PrimaryTextBrush}"
            LineHeight="20"
            TextWrapping="Wrap"
          />
        </ScrollViewer>
      </Grid>

      <Border
        Grid.Row="2"
        Padding="20,12"
        Background="{DynamicResource FlourishMessageBoxSecondarySurfaceBrush}"
        BorderBrush="{DynamicResource CardBorderBrush}"
        BorderThickness="0,1,0,0"
        CornerRadius="0,0,10,10"
      >
        <StackPanel
          x:Name="ButtonsHost"
          HorizontalAlignment="Right"
          Orientation="Horizontal"
        />
      </Border>
    </Grid>
    </Border>
  </Grid>
</Window>
