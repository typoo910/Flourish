<UserControl
  x:Class="AcksheedSys.Flourish.Control.FlourishTitlebar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:ClassModifier="internal"
  mc:Ignorable="d"
>
  <Grid Background="Transparent">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <StackPanel
      x:Name="BreadcrumbNavigationHost"
      Grid.Column="0"
      Margin="4,0,0,0"
      Orientation="Horizontal"
    >
      <Button
        x:Name="BackButton"
        Width="38"
        Height="32"
        Margin="0,4,2,4"
        Click="BackButton_Click"
        IsEnabled="False"
        Style="{StaticResource FlourishIconButtonStyle}"
        ToolTip="Back"
      >
        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE72B;" />
      </Button>

      <Button
        x:Name="ForwardButton"
        Width="38"
        Height="32"
        Margin="2,4"
        Click="ForwardButton_Click"
        IsEnabled="False"
        Style="{StaticResource FlourishIconButtonStyle}"
        ToolTip="Forward"
      >
        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE72A;" />
      </Button>
    </StackPanel>

    <Button
      x:Name="NavigationToggleButton"
      Grid.Column="1"
      Width="38"
      Height="32"
      Margin="2,4"
      Click="NavigationToggleButton_Click"
      Style="{StaticResource FlourishIconButtonStyle}"
      ToolTip="Toggle navigation"
    >
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE700;" />
    </Button>

    <StackPanel
      x:Name="BrandHost"
      Grid.Column="2"
      Margin="8,0,14,0"
      VerticalAlignment="Center"
      MouseLeftButtonDown="Titlebar_MouseLeftButtonDown"
      Orientation="Horizontal"
    >
      <Border
        x:Name="LogoHost"
        Width="26"
        Height="26"
        Background="{StaticResource AccentSoftBrush}"
        CornerRadius="6"
      >
        <Grid>
          <Image x:Name="LogoImage" Margin="4" Stretch="Uniform" />
          <TextBlock
            x:Name="LogoFallback"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{StaticResource AccentBrush}"
          />
        </Grid>
      </Border>
      <StackPanel
        x:Name="TitleTextHost"
        Margin="8,0,0,0"
        VerticalAlignment="Center"
        Orientation="Horizontal"
      >
        <TextBlock
          x:Name="TitleText"
          VerticalAlignment="Center"
          FontSize="13"
          FontWeight="SemiBold"
          Foreground="{StaticResource PrimaryTextBrush}"
        />
        <TextBlock
          x:Name="SubtitleText"
          Margin="8,1,0,0"
          VerticalAlignment="Center"
          FontSize="10"
          Foreground="{StaticResource MutedTextBrush}"
        />
      </StackPanel>
    </StackPanel>

    <Border
      Grid.Column="3"
      Background="Transparent"
      MouseLeftButtonDown="Titlebar_MouseLeftButtonDown"
    />

    <Border
      x:Name="SearchBoxHost"
      Grid.Column="4"
      Width="320"
      Height="28"
      Margin="8,0,10,0"
      Padding="10,0"
      VerticalAlignment="Center"
      Background="White"
      BorderBrush="{StaticResource CardBorderBrush}"
      BorderThickness="1"
      CornerRadius="8"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
          VerticalAlignment="Center"
          FontFamily="Segoe MDL2 Assets"
          Foreground="{StaticResource MutedTextBrush}"
          Text="&#xE721;"
        />
        <TextBox
          x:Name="SearchBox"
          Grid.Column="1"
          Margin="8,0,0,0"
          VerticalContentAlignment="Center"
          Background="Transparent"
          BorderThickness="0"
          Foreground="{StaticResource PrimaryTextBrush}"
          GotKeyboardFocus="SearchBox_GotKeyboardFocus"
          LostKeyboardFocus="SearchBox_LostKeyboardFocus"
          TextChanged="SearchBox_TextChanged"
        />
        <TextBlock
          x:Name="SearchPlaceholderText"
          Grid.Column="1"
          Margin="10,0,0,0"
          VerticalAlignment="Center"
          Foreground="{StaticResource MutedTextBrush}"
          IsHitTestVisible="False"
        />
      </Grid>
    </Border>

    <Border
      x:Name="ProfileHost"
      Grid.Column="5"
      Width="26"
      Height="26"
      Margin="0,0,10,0"
      VerticalAlignment="Center"
      Background="#E0F2FE"
      CornerRadius="13"
    >
      <TextBlock
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        FontSize="12"
        FontWeight="SemiBold"
        Foreground="#0369A1"
        Text="JD"
      />
    </Border>

    <Button
      Grid.Column="6"
      Click="MinimizeButton_Click"
      Style="{StaticResource FlourishWindowCaptionButtonStyle}"
      ToolTip="Minimize"
    >
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE921;" />
    </Button>

    <Button
      x:Name="MaximizeButton"
      Grid.Column="7"
      Click="MaximizeButton_Click"
      Style="{StaticResource FlourishWindowCaptionButtonStyle}"
      ToolTip="Maximize"
    >
      <TextBlock
        x:Name="MaximizeButtonIcon"
        FontFamily="Segoe MDL2 Assets"
        FontSize="11"
        Text="&#xE922;"
      />
    </Button>

    <Button
      Grid.Column="8"
      Click="CloseButton_Click"
      Style="{StaticResource FlourishWindowCaptionCloseButtonStyle}"
      ToolTip="Close"
    >
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE8BB;" />
    </Button>
  </Grid>
</UserControl>
