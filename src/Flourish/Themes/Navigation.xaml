<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:ArkheideSystem.Flourish.Controls"
>
  <Style x:Key="FlourishNavigationListBoxStyle" TargetType="{x:Type ListBox}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
  </Style>

  <Style x:Key="FlourishNavigationListBoxItemBaseStyle" TargetType="{x:Type ListBoxItem}">
    <Setter Property="Height" Value="32" />
    <Setter Property="Margin" Value="5,1" />
    <Setter Property="Padding" Value="9,0" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="ToolTip" Value="{Binding Label}" />
    <Setter
      Property="ToolTipService.InitialShowDelay"
      Value="{DynamicResource FlourishToolTipInitialShowDelay}"
    />
    <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
    <Setter Property="ToolTipService.ShowDuration" Value="10000" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter
      Property="controls:HoverReveal.IsEnabled"
      Value="{DynamicResource FlourishHoverRevealEnabled}"
    />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ListBoxItem}">
          <Grid ClipToBounds="True">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="5"
            />
            <Border
              x:Name="HoverChrome"
              Background="{DynamicResource FlourishControlHoverBrush}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="5"
              IsHitTestVisible="False"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5"
            >
              <Border.RenderTransform>
                <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
              </Border.RenderTransform>
            </Border>
            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="Center"
            />
          </Grid>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
              </MultiTrigger.Conditions>
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </MultiTrigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishNavigationSelectedBrush}"
              />
              <Setter
                TargetName="HoverChrome"
                Property="Background"
                Value="{DynamicResource FlourishNavigationSelectedBrush}"
              />
            </Trigger>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding IsCommandItem}" Value="True" />
                <Condition
                  Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                  Value="True"
                />
              </MultiDataTrigger.Conditions>
              <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
              <Setter TargetName="Chrome" Property="Background" Value="Transparent" />
              <Setter
                TargetName="HoverChrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </MultiDataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="FlourishNavigationListBoxItemStyle"
    BasedOn="{StaticResource FlourishNavigationListBoxItemBaseStyle}"
    TargetType="{x:Type ListBoxItem}"
  >
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsVisible}" Value="False">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Height" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Margin" Value="16,20,12,7" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ToolTip" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="IsHitTestVisible" Value="False" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsCommandItem}" Value="True">
        <Setter Property="Focusable" Value="False" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
        Value="False"
      >
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="4,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
      </DataTrigger>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding IsGroupHeader}" Value="True" />
          <Condition
            Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
            Value="False"
          />
        </MultiDataTrigger.Conditions>
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Height" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
