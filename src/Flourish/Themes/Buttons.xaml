<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:AckSS.Flourish.Controls"
>
  <Style x:Key="FlourishInteractiveButtonBaseStyle" TargetType="{x:Type Button}">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FlourishFontFamily}" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeBase}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter
      Property="ToolTipService.InitialShowDelay"
      Value="{DynamicResource FlourishToolTipInitialShowDelay}"
    />
    <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
    <Setter Property="ToolTipService.ShowDuration" Value="10000" />
    <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
    <Setter
      Property="controls:HoverReveal.IsEnabled"
      Value="{DynamicResource FlourishHoverRevealEnabled}"
    />
  </Style>

  <Style
    x:Key="FlourishIconButtonVisualStyle"
    BasedOn="{StaticResource FlourishInteractiveButtonBaseStyle}"
    TargetType="{x:Type Button}"
  >
    <Setter Property="Width" Value="42" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid ClipToBounds="True">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="6" />
            <Border
              x:Name="HoverChrome"
              Background="{DynamicResource FlourishControlHoverBrush}"
              CornerRadius="6"
              IsHitTestVisible="False"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5"
            >
              <Border.RenderTransform>
                <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
              </Border.RenderTransform>
            </Border>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="True" />
              </MultiTrigger.Conditions>
              <MultiTrigger.EnterActions>
                <BeginStoryboard x:Name="IconButtonHoverRevealStoryboard">
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverChrome"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0"
                    />
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleX"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleY"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </MultiTrigger.EnterActions>
              <MultiTrigger.ExitActions>
                <StopStoryboard BeginStoryboardName="IconButtonHoverRevealStoryboard" />
              </MultiTrigger.ExitActions>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
              </MultiTrigger.Conditions>
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
              <Setter
                TargetName="HoverChrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="FlourishIconButtonStyle"
    BasedOn="{StaticResource FlourishIconButtonVisualStyle}"
    TargetType="{x:Type Button}"
  >
    <Style.Triggers>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.35" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FlourishCloseButtonStyle"
    BasedOn="{StaticResource FlourishIconButtonVisualStyle}"
    TargetType="{x:Type Button}"
  >
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="White" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Foreground" Value="White" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FlourishWindowCaptionButtonVisualStyle"
    BasedOn="{StaticResource FlourishInteractiveButtonBaseStyle}"
    TargetType="{x:Type Button}"
  >
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="40" />
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishControlHoverBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid ClipToBounds="True">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" />
            <Border
              x:Name="HoverChrome"
              Background="{TemplateBinding BorderBrush}"
              IsHitTestVisible="False"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5"
            >
              <Border.RenderTransform>
                <ScaleTransform x:Name="HoverRevealScale" ScaleX="1" ScaleY="1" />
              </Border.RenderTransform>
            </Border>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="True" />
              </MultiTrigger.Conditions>
              <MultiTrigger.EnterActions>
                <BeginStoryboard x:Name="CaptionButtonHoverRevealStoryboard">
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverChrome"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0"
                    />
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleX"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleY"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </MultiTrigger.EnterActions>
              <MultiTrigger.ExitActions>
                <StopStoryboard BeginStoryboardName="CaptionButtonHoverRevealStoryboard" />
              </MultiTrigger.ExitActions>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
              </MultiTrigger.Conditions>
              <Setter
                TargetName="HoverChrome"
                Property="Opacity"
                Value="1"
              />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter
                TargetName="HoverChrome"
                Property="Opacity"
                Value="1"
              />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="FlourishWindowCaptionButtonStyle"
    BasedOn="{StaticResource FlourishWindowCaptionButtonVisualStyle}"
    TargetType="{x:Type Button}"
  >
    <Style.Triggers>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.35" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FlourishWindowCaptionCloseButtonStyle"
    BasedOn="{StaticResource FlourishWindowCaptionButtonVisualStyle}"
    TargetType="{x:Type Button}"
  >
    <Setter Property="BorderBrush" Value="{DynamicResource FlourishWindowCaptionCloseHoverBrush}" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="White" />
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Foreground" Value="White" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style
    x:Key="FlourishToolbarButtonStyle"
    BasedOn="{StaticResource FlourishInteractiveButtonBaseStyle}"
    TargetType="{x:Type Button}"
  >
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="Padding" Value="7,0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontSize" Value="{DynamicResource FlourishFontSizeCaption}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid ClipToBounds="True">
            <Border
              x:Name="Chrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="5"
            />
            <Border
              x:Name="HoverChrome"
              Background="{DynamicResource FlourishControlHoverBrush}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="5"
              IsHitTestVisible="False"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5"
            >
              <Border.RenderTransform>
                <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
              </Border.RenderTransform>
            </Border>
            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
            />
          </Grid>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="True" />
              </MultiTrigger.Conditions>
              <MultiTrigger.EnterActions>
                <BeginStoryboard x:Name="ToolbarButtonHoverRevealStoryboard">
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverChrome"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0"
                    />
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleX"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleY"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </MultiTrigger.EnterActions>
              <MultiTrigger.ExitActions>
                <StopStoryboard BeginStoryboardName="ToolbarButtonHoverRevealStoryboard" />
              </MultiTrigger.ExitActions>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
              </MultiTrigger.Conditions>
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </MultiTrigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter
                TargetName="Chrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
              <Setter
                TargetName="HoverChrome"
                Property="Background"
                Value="{DynamicResource FlourishControlHoverBrush}"
              />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
