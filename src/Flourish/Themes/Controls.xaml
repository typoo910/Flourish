<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
>
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/Flourish;component/Controls/ScrollBar.xaml" />
    <!-- PageBody is the terminal dictionary in the ScrollViewer dependency chain. -->
    <ResourceDictionary Source="/Flourish;component/Controls/PageBody.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/TextBlock.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Label.xaml" />
    <!-- CardButton is the terminal dictionary in the Button-family dependency chain. -->
    <ResourceDictionary Source="/Flourish;component/Controls/CardButton.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Paragraph.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Document.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/CodeSpace.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Presenter.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Chunk.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/HeaderChunk.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/TextBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/PasswordBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/SearchBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/CheckBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/RadioButton.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/ComboBoxItem.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/ComboBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/ListBoxItem.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/ListBox.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/DataGrid.xaml" />
    <!-- OutputCard is the terminal dictionary in the Card-family dependency chain. -->
    <ResourceDictionary Source="/Flourish;component/Controls/OutputCard.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/Overlay.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/ToolTip.xaml" />
    <ResourceDictionary Source="/Flourish;component/Controls/GridSplitter.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- Runtime services may override these public interaction defaults. -->
  <sys:Boolean x:Key="FlourishHoverRevealEnabled">True</sys:Boolean>
  <sys:TimeSpan x:Key="FlourishHoverRevealDuration">0:0:0.140</sys:TimeSpan>
  <sys:Boolean x:Key="FlourishToolTipsEnabled">False</sys:Boolean>
  <sys:Int32 x:Key="FlourishToolTipInitialShowDelay">200</sys:Int32>
  <sys:Double x:Key="FlourishToolTipSpawnableMargin">5</sys:Double>

  <!-- Compact Flourish geometry with light borders and a layered surface hierarchy. -->
  <sys:Double x:Key="FlourishControlHeight">30</sys:Double>
  <sys:Double x:Key="FlourishControlMinWidth">64</sys:Double>
  <sys:Double x:Key="FlourishButtonHeight">32</sys:Double>
  <sys:Double x:Key="FlourishButtonMinWidth">72</sys:Double>
  <sys:Double x:Key="FlourishButtonIconOnlySize">32</sys:Double>
  <CornerRadius x:Key="FlourishControlCornerRadius">6</CornerRadius>
  <CornerRadius x:Key="FlourishSurfaceCornerRadius">8</CornerRadius>
  <CornerRadius x:Key="FlourishOverlayCornerRadius">10</CornerRadius>
  <CornerRadius x:Key="FlourishDialogCornerRadius">12</CornerRadius>
  <CornerRadius x:Key="FlourishDialogFooterCornerRadius">0,0,12,12</CornerRadius>
  <Thickness x:Key="FlourishControlPadding">10,4</Thickness>
  <Thickness x:Key="FlourishOverlayPadding">16,14</Thickness>
  <Thickness x:Key="FlourishCompactControlPadding">8,2</Thickness>
  <Thickness x:Key="FlourishControlBorderThickness">1</Thickness>
  <Thickness x:Key="FlourishSurfaceBorderThickness">0</Thickness>
  <Thickness x:Key="FlourishFocusBorderThickness">1.5</Thickness>
  <Thickness x:Key="FlourishVerticalDividerThickness">0,0,1,0</Thickness>
  <Thickness x:Key="FlourishHorizontalDividerThickness">0,1,0,0</Thickness>
</ResourceDictionary>
