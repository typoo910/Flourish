              CornerRadius="5"
              IsHitTestVisible="False"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5"
            >
              <Border.RenderTransform>
                <ScaleTransform x:Name="HoverRevealScale" ScaleX="0" ScaleY="0" />
              </Border.RenderTransform>
            </Border>
            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="Center"
            />
          </Grid>
          <ControlTemplate.Triggers>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="True" />
              </MultiTrigger.Conditions>
              <MultiTrigger.EnterActions>
                <BeginStoryboard x:Name="NavigationItemHoverRevealStoryboard">
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverChrome"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0"
                    />
                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleX"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>                    <DoubleAnimation
                      Storyboard.TargetName="HoverRevealScale"
                      Storyboard.TargetProperty="ScaleY"
                      From="0"
                      To="1"
                      Duration="0:0:0.14"
                    >
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </MultiTrigger.EnterActions>
              <MultiTrigger.ExitActions>
                <StopStoryboard BeginStoryboardName="NavigationItemHoverRevealStoryboard" />
              </MultiTrigger.ExitActions>
            </MultiTrigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="controls:HoverReveal.IsEnabled" Value="False" />
              </MultiTrigger.Conditions>
              <Setter TargetName="Chrome" Property="Background" Value="#D6E8FF" />
            </MultiTrigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
              <Setter TargetName="Chrome" Property="Background" Value="#CFE0FF" />
              <Setter TargetName="HoverChrome" Property="Background" Value="#CFE0FF" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsVisible}" Value="False">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Height" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
        <Setter Property="Height" Value="Auto" />
        <Setter Property="Margin" Value="16,12,12,4" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="IsHitTestVisible" Value="False" />
      </DataTrigger>
      <DataTrigger
        Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
        Value="False"
      >
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="4,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
      </DataTrigger>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding IsGroupHeader}" Value="True" />
          <Condition
            Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
            Value="False"
          />
        </MultiDataTrigger.Conditions>
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Height" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>
