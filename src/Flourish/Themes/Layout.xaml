<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
>
  <!-- Shared shell geometry keeps window-edge content and collapsed navigation aligned. -->
  <sys:Double x:Key="FlourishShellOuterInset">8</sys:Double>
  <sys:Double x:Key="FlourishShellCommandButtonWidth">38</sys:Double>
  <sys:Double x:Key="FlourishShellCommandButtonHeight">32</sys:Double>
  <sys:Double x:Key="FlourishScrollBarWidth">10</sys:Double>
  <sys:Double x:Key="FlourishCompactScrollBarWidth">5</sys:Double>
  <GridLength x:Key="FlourishTitlebarLeadingSpacerWidth">8</GridLength>
  <Thickness x:Key="FlourishTitlebarNavigationToggleMargin">4</Thickness>
  <Thickness x:Key="FlourishCollapsedNavigationItemMargin">4,1,0,1</Thickness>
  <Thickness x:Key="FlourishNavigationPaneLeftPadding">8,0,0,0</Thickness>
  <Thickness x:Key="FlourishNavigationPaneRightPadding">0,0,8,0</Thickness>
  <Thickness x:Key="FlourishNavigationCustomRegionMargin">4,0</Thickness>
  <Thickness x:Key="FlourishStatusBarPadding">12,3</Thickness>

  <!-- A 4-DIP spacing grid keeps peer content compact and separates hierarchy levels. -->
  <sys:Double x:Key="FlourishSpaceXXSmall">4</sys:Double>
  <sys:Double x:Key="FlourishSpaceXSmall">8</sys:Double>
  <sys:Double x:Key="FlourishSpaceSmall">12</sys:Double>
  <sys:Double x:Key="FlourishSpaceMedium">16</sys:Double>
  <sys:Double x:Key="FlourishSpaceLarge">24</sys:Double>
  <sys:Double x:Key="FlourishSpaceXLarge">32</sys:Double>
  <sys:Double x:Key="FlourishSpaceXXLarge">40</sys:Double>

  <Thickness x:Key="FlourishContentBodyMargin">32,0,32,0</Thickness>
  <Thickness x:Key="FlourishPageContentMargin">0,32,0,48</Thickness>
  <Thickness x:Key="FlourishPageSubtitleMargin">0,8,0,0</Thickness>
  <Thickness x:Key="FlourishSectionMargin">0,32,0,0</Thickness>
  <Thickness x:Key="FlourishSectionDescriptionMargin">0,6,0,0</Thickness>
  <Thickness x:Key="FlourishSectionCardMargin">0,12,0,0</Thickness>
  <Thickness x:Key="FlourishPeerCardMargin">0,16,0,0</Thickness>
  <Thickness x:Key="FlourishCardPadding">20</Thickness>
  <Thickness x:Key="FlourishHeroCardPadding">32</Thickness>
  <Thickness x:Key="FlourishInteractiveCardPadding">18</Thickness>
</ResourceDictionary>
