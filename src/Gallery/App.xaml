<Application
  x:Class="ArkheideSystem.Gallery.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Flourish;component/Themes/Generic.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <Style x:Key="GalleryPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      </Style>

      <Style x:Key="GalleryPageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Style>

      <Style x:Key="GallerySectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      </Style>

      <Style x:Key="GalleryFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      </Style>

      <Style x:Key="GalleryCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{DynamicResource CardSecondaryBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
      </Style>

      <Style
        x:Key="GalleryActionButtonStyle"
        BasedOn="{StaticResource FlourishToolbarButtonStyle}"
        TargetType="Button"
      >
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="94" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
      </Style>

      <Style
        x:Key="GalleryTextBoxStyle"
        BasedOn="{StaticResource FlourishFormTextBoxStyle}"
        TargetType="TextBox"
      >
        <Setter Property="MinWidth" Value="180" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
