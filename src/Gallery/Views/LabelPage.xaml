<Page
  x:Class="ArkheideSystem.Gallery.Views.LabelPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Name an input and transfer keyboard focus through the native WPF access-key contract."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishLabel"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="MemberGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="Member" Width="220" />
          <DataGridTextColumn Binding="{Binding Description}" Header="Purpose" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Place the label next to its target and mark one character with an underscore for keyboard access."
      Title="Association"
    >
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="Target sends focus to the related control when the access key is invoked."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Text input"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="152">
              <StackPanel
                Width="240"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
              >
                <flourish:FlourishLabel
                  Content="_Display name"
                  Target="{Binding ElementName=DisplayNameBox}"
                />
                <flourish:FlourishTextBox
                  x:Name="DisplayNameBox"
                  Margin="0,4,0,0"
                  Text="Flourish user"
                />
              </StackPanel>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="The same association works for selectors and other focusable controls."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Selection input"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="152">
              <StackPanel
                Width="240"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
              >
                <flourish:FlourishLabel
                  Content="_Theme"
                  Target="{Binding ElementName=ThemeBox}"
                />
                <flourish:FlourishComboBox
                  x:Name="ThemeBox"
                  Margin="0,4,0,0"
                  SelectedIndex="0"
                >
                  <flourish:FlourishComboBoxItem Content="System" />
                  <flourish:FlourishComboBoxItem Content="Light" />
                  <flourish:FlourishComboBoxItem Content="Dark" />
                </flourish:FlourishComboBox>
              </StackPanel>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Browse the Flourish source repository."
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Read the FlourishLabel API reference."
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="FlourishLabel documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
