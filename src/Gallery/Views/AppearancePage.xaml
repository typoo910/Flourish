<Page
  x:Class="ArkheideSystem.Gallery.Views.AppearancePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,40">
      <TextBlock Style="{StaticResource GalleryPageTitleStyle}" Text="Appearance &amp; motion" />
      <TextBlock
        Style="{StaticResource GalleryPageSubtitleStyle}"
        Text="Change visual resources and shell effects at runtime. Every control below calls a public service and reports the effective state returned by Flourish."
      />

      <Border Margin="0,24,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Theme" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Select a requested mode or cycle through System, Light, and Dark." />
          <WrapPanel>
            <ComboBox x:Name="ThemeBox" Width="220" Height="32" VerticalContentAlignment="Center" />
            <Button Margin="10,0,0,0" Click="ApplyTheme_Click" Content="Apply theme" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleTheme_Click" Content="Cycle theme" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="ThemeStatusText" Margin="0,12,0,0" Foreground="{DynamicResource AccentBrush}" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Typography" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Update text family, base size, and icon family resources without rebuilding the visual tree." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Text font family" />
              <TextBox x:Name="FontFamilyBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Base size" />
              <TextBox x:Name="FontSizeBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0,0,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Icon font family" />
              <TextBox x:Name="IconFontFamilyBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
          </Grid>
          <Button Margin="0,14,0,0" HorizontalAlignment="Left" Click="ApplyFont_Click" Content="Apply typography" Style="{StaticResource GalleryActionButtonStyle}" />
          <TextBlock x:Name="FontStatusText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Tooltips" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Enable or disable Flourish tooltips and change their initial delay and spawn margin." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Initial delay (ms)" />
              <TextBox x:Name="ToolTipDelayBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Spawn margin" />
              <TextBox x:Name="ToolTipMarginBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
            <Button Grid.Column="2" Margin="8,20,0,0" Click="ConfigureToolTip_Click" Content="Apply settings" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button x:Name="ToggleToolTipButton" Grid.Column="3" Margin="8,20,0,0" Click="ToggleToolTip_Click" Style="{StaticResource GalleryActionButtonStyle}" />
          </Grid>
          <TextBlock x:Name="ToolTipStatusText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Motion" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Change transitions and timing, including whether system reduced-motion preferences suppress animation." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Page transition" />
              <ComboBox x:Name="PageTransitionBox" Height="32" VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Duration (ms)" />
              <TextBox x:Name="PageDurationBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Navigation transition" />
              <ComboBox x:Name="NavigationTransitionBox" Height="32" VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="8,0,0,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Duration (ms)" />
              <TextBox x:Name="NavigationDurationBox" Style="{StaticResource GalleryTextBoxStyle}" />
            </StackPanel>
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <CheckBox x:Name="MotionEnabledBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Motion enabled" />
            <CheckBox x:Name="HoverRevealBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Hover reveal" />
            <CheckBox x:Name="ReducedMotionBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Respect system reduced motion" />
            <Button Click="ApplyMotion_Click" Content="Apply motion" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="MotionStatusText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Window material" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Request the native backdrop and immersive dark mode. Flourish reports platform support and whether the effect was actually applied." TextWrapping="Wrap" />
          <WrapPanel>
            <ComboBox x:Name="MaterialBox" Width="220" Height="32" VerticalContentAlignment="Center" />
            <CheckBox x:Name="MaterialDarkModeBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Immersive dark mode" />
            <Button Margin="18,0,0,0" Click="ApplyMaterial_Click" Content="Apply material" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="MaterialStatusText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
