<Page
  x:Class="ArkheideSystem.Gallery.Views.AppearancePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Change visual resources and shell effects at runtime."
        ChunkHeroTitle="Appearance &amp; motion"
      />

      <flourish:Chunk
        ChunkDescription="Switch the active color theme."
        ChunkTitle="Theme"
      >
        <UniformGrid Columns="2">
          <flourish:Card
            Margin="0,0,8,0"
            Title="Theme controls"
            Text="Select a requested mode or cycle through System, Light, and Dark."
          >
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:FlourishComboBox x:Name="ThemeBox" Width="220" />
                <flourish:Button Margin="10,0,0,0" Click="ApplyTheme_Click" Content="Apply theme" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleTheme_Click" Content="Cycle theme" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Title="Output"
            Text="Shows the effective theme after each request."
          >
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="ThemeStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Update application-wide typography resources."
        ChunkTitle="Typography"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Global typography"
          Text="Change the text family, base size, and icon family without rebuilding the visual tree."
        >
          <flourish:Card.Body>
            <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Text font family" />
                <flourish:FlourishTextBox x:Name="FontFamilyBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Base size" />
                <flourish:FlourishTextBox x:Name="FontSizeBox" />
              </StackPanel>
              <StackPanel Grid.Column="2" Margin="8,0,0,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Icon font family" />
                <flourish:FlourishTextBox x:Name="IconFontFamilyBox" />
              </StackPanel>
            </Grid>
            <flourish:Button Margin="0,14,0,0" HorizontalAlignment="Left" Click="ApplyFont_Click" Content="Apply typography" />
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the effective typography resources.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="FontStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Override typography for this page only."
        ChunkTitle="Page typography"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Local font override"
          Text="Leave size empty to follow the global base size, or clear the override to restore the global font."
        >
          <flourish:Card.Body>
            <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Override font family" />
                <flourish:FlourishTextBox x:Name="PageOverrideFontFamilyBox" Text="Georgia" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Override size (optional)" />
                <flourish:FlourishTextBox x:Name="PageOverrideFontSizeBox" />
              </StackPanel>
              <flourish:Button Grid.Column="2" Margin="8,20,0,0" Click="ApplyPageFontOverride_Click" Content="Apply page override" />
              <flourish:Button Grid.Column="3" Margin="8,20,0,0" Click="ClearPageFontOverride_Click" Content="Clear override" />
            </Grid>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the active page-level font override.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="PageFontOverrideStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Configure tooltip availability and timing."
        ChunkTitle="Tooltips"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Tooltip behavior"
          Text="Enable or disable Flourish tooltips and adjust their initial delay and spawn margin."
        >
          <flourish:Card.Body>
            <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Initial delay (ms)" />
                <flourish:FlourishTextBox x:Name="ToolTipDelayBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Spawn margin" />
                <flourish:FlourishTextBox x:Name="ToolTipMarginBox" />
              </StackPanel>
              <flourish:Button Grid.Column="2" Margin="8,20,0,0" Click="ConfigureToolTip_Click" Content="Apply settings" />
              <flourish:Button x:Name="ToggleToolTipButton" Grid.Column="3" Margin="8,20,0,0" Click="ToggleToolTip_Click" />
            </Grid>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the effective tooltip configuration.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="ToolTipStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Configure transition types and timing."
        ChunkTitle="Motion"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Motion settings"
          Text="Choose page and navigation transitions and decide whether system reduced-motion preferences suppress animation."
        >
          <flourish:Card.Body>
            <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Page transition" />
                <flourish:FlourishComboBox x:Name="PageTransitionBox" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Duration (ms)" />
                <flourish:FlourishTextBox x:Name="PageDurationBox" />
              </StackPanel>
              <StackPanel Grid.Column="2" Margin="8,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Navigation transition" />
                <flourish:FlourishComboBox x:Name="NavigationTransitionBox" />
              </StackPanel>
              <StackPanel Grid.Column="3" Margin="8,0,0,0">
                <flourish:FlourishTextBlock Role="FieldLabel" Text="Duration (ms)" />
                <flourish:FlourishTextBox x:Name="NavigationDurationBox" />
              </StackPanel>
            </Grid>
            <WrapPanel Margin="0,14,0,0">
              <flourish:FlourishCheckBox x:Name="MotionEnabledBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Motion enabled" />
              <flourish:FlourishCheckBox x:Name="HoverRevealBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Hover reveal" />
              <flourish:FlourishCheckBox x:Name="ReducedMotionBox" Margin="0,0,22,0" VerticalAlignment="Center" Content="Respect system reduced motion" />
              <flourish:Button Click="ApplyMotion_Click" Content="Apply motion" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the active motion configuration.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="MotionStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Configure the shell window backdrop."
        ChunkTitle="Window material"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Native material"
          Text="Request a native backdrop and immersive dark mode, then inspect platform support and the effective result."
        >
          <flourish:Card.Body>
            <StackPanel>
            <WrapPanel>
              <flourish:FlourishComboBox x:Name="MaterialBox" Width="220" />
              <flourish:FlourishCheckBox x:Name="MaterialDarkModeBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Immersive dark mode" />
              <flourish:Button Margin="18,0,0,0" Click="ApplyMaterial_Click" Content="Apply material" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows platform support and the applied material.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="MaterialStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
