<Page
  x:Class="ArkheideSystem.Gallery.Views.BackgroundTasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Queue, observe, cancel, and inspect background work."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Background tasks"
    />

    <flourish:Chunk
      Content="Submit several forms of runtime work."
      Title="Queue runtime work"
    >
      <UniformGrid VerticalAlignment="Stretch" Columns="2">
        <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE768;"
            Content="Queue work that reports progress while it runs."
            Title="Progress task"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="AddProgressTask_Click" Content="Add task" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8F1;"
            Content="Queue work that returns a captured value."
            Title="Result task"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="AddResultTask_Click" Content="Add task" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8FD;"
            Content="Queue four tasks to demonstrate bounded concurrency."
            Title="Task burst"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="AddBurst_Click" Content="Queue 4 tasks" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE711;"
            Content="Cancel the most recently submitted task."
            Title="Last task"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="CancelLast_Click" Content="Cancel last" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Content="Cancel the task selected in the live task list."
            Title="Selected task"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="CancelSelected_Click" Content="Cancel selected" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard
          x:Name="ServiceOutput"
          Margin="8,0,0,0"
          VerticalAlignment="Stretch"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Compare active tasks with their captured outcomes."
      Title="Task state"
    >
      <StackPanel>
        <flourish:Presenter
          Content="Queued, running, and cancelling items update through TasksChanged."
          PresenterMode="Split"
          PresenterPosition="Left"
          Title="Live tasks"
        >
          <flourish:Presenter.Presentation>
            <flourish:FlourishListBox x:Name="ActiveTaskList" MinHeight="220" />
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="{DynamicResource FlourishPresenterPeerMargin}"
          Content="Completion never faults; failures and cancellation are represented in the result object."
          PresenterMode="Split"
          PresenterPosition="Left"
          Title="Recent outcomes"
        >
          <flourish:Presenter.Presentation>
            <flourish:FlourishListBox x:Name="OutcomeList" MinHeight="220" />
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </StackPanel>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="var handle = backgroundTasks.AddTask(&#xA;    &quot;Refresh reports&quot;,&#xA;    async context =&gt; await RefreshReportsAsync(context.CancellationToken));&#xA;&#xA;var result = await handle.Completion;" />
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the canonical Flourish documentation." Icon="&#xE946;" IsEnabled="False" Title="Flourish documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
