<Page
  x:Class="ArkheideSystem.Gallery.Views.BackgroundTasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:Chunk
        ChunkDescription="Submit work after startup, observe immutable progress snapshots, request cooperative cancellation, and await captured outcomes without crashing the host."
        ChunkTitle="Background tasks"
      />

      <flourish:Chunk
        ChunkDescription="Progress tasks report twenty updates. Result tasks return a value. A burst demonstrates the service's bounded concurrency."
        ChunkTitle="Queue runtime work"
      >
        <flourish:Card>
          <StackPanel>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,8" Click="AddProgressTask_Click" Content="Add progress task" />
            <flourish:Button Margin="0,0,8,8" Click="AddResultTask_Click" Content="Add result task" />
            <flourish:Button Margin="0,0,8,8" Click="AddBurst_Click" Content="Queue 4 tasks" />
            <flourish:Button Margin="0,0,8,8" Click="CancelLast_Click" Content="Cancel last" />
            <flourish:Button Margin="0,0,8,8" Click="CancelSelected_Click" Content="Cancel selected" />
          </WrapPanel>
          <flourish:FlourishTextBlock x:Name="ServiceStatusText" Margin="0,6,0,0" Role="Status" />
          </StackPanel>
        </flourish:Card>
      </flourish:Chunk>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <flourish:Chunk
          ChunkDescription="Queued, running, and cancelling items update through TasksChanged."
          ChunkTitle="Active queue"
        >
          <flourish:Card>
            <flourish:FlourishListBox x:Name="ActiveTaskList" MinHeight="220" />
          </flourish:Card>
        </flourish:Chunk>

        <flourish:Chunk
          Grid.Column="2"
          ChunkDescription="Completion never faults; failures and cancellation are represented in the result object."
          ChunkTitle="Captured outcomes"
        >
          <flourish:Card>
            <flourish:FlourishListBox x:Name="OutcomeList" MinHeight="220" />
          </flourish:Card>
        </flourish:Chunk>
      </Grid>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
