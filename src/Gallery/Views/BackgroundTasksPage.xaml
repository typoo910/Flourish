<Page
  x:Class="ArkheideSystem.Gallery.Views.BackgroundTasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Queue, observe, cancel, and inspect background work."
        ChunkHeroTitle="Background tasks"
      />

      <flourish:Chunk
        ChunkDescription="Submit several forms of runtime work."
        ChunkTitle="Queue runtime work"
      >
        <UniformGrid Columns="2">
          <flourish:Card
            Margin="0,0,8,0"
            Title="Task controls"
            Text="Progress tasks report updates, result tasks return a value, and a burst demonstrates bounded concurrency."
          >
            <flourish:Card.Body>
              <WrapPanel>
                <flourish:Button Margin="0,0,8,8" Click="AddProgressTask_Click" Content="Add progress task" />
                <flourish:Button Margin="0,0,8,8" Click="AddResultTask_Click" Content="Add result task" />
                <flourish:Button Margin="0,0,8,8" Click="AddBurst_Click" Content="Queue 4 tasks" />
                <flourish:Button Margin="0,0,8,8" Click="CancelLast_Click" Content="Cancel last" />
                <flourish:Button Margin="0,0,8,8" Click="CancelSelected_Click" Content="Cancel selected" />
              </WrapPanel>
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Title="Output"
            Text="Shows the latest queue or cancellation response."
          >
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="ServiceStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Compare active tasks with their captured outcomes."
        ChunkTitle="Task state"
      >
        <UniformGrid Columns="2">
          <flourish:Card
            Margin="0,0,8,0"
            Title="Live tasks"
            Text="Queued, running, and cancelling items update through TasksChanged."
          >
            <flourish:Card.Body>
              <flourish:FlourishListBox x:Name="ActiveTaskList" MinHeight="220" />
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            Title="Recent outcomes"
            Text="Completion never faults; failures and cancellation are represented in the result object."
          >
            <flourish:Card.Body>
              <flourish:FlourishListBox x:Name="OutcomeList" MinHeight="220" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
