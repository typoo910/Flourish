<Page
  x:Class="ArkheideSystem.Gallery.Views.BackgroundTasksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Queue, observe, cancel, and inspect background work."
        ChunkHeroTitle="Background tasks"
      />

      <flourish:Chunk
        ChunkDescription="Submit several forms of runtime work."
        ChunkTitle="Queue runtime work"
      >
        <UniformGrid VerticalAlignment="Stretch" Columns="2">
          <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE768;"
              Text="Queue work that reports progress while it runs."
              Title="Progress task"
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="AddProgressTask_Click" Content="Add task" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8F1;"
              Text="Queue work that returns a captured value."
              Title="Result task"
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="AddResultTask_Click" Content="Add task" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8FD;"
              Text="Queue four tasks to demonstrate bounded concurrency."
              Title="Task burst"
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="AddBurst_Click" Content="Queue 4 tasks" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE711;"
              Text="Cancel the most recently submitted task."
              Title="Last task"
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="CancelLast_Click" Content="Cancel last" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Text="Cancel the task selected in the live task list."
              Title="Selected task"
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="CancelSelected_Click" Content="Cancel selected" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:OutputCard
            x:Name="ServiceOutput"
            Margin="8,0,0,0"
            VerticalAlignment="Stretch"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Compare active tasks with their captured outcomes."
        ChunkTitle="Task state"
      >
        <UniformGrid VerticalAlignment="Stretch" Columns="2">
          <flourish:Card
            Margin="0,0,8,0"
            VerticalAlignment="Stretch"
            Title="Live tasks"
            Text="Queued, running, and cancelling items update through TasksChanged."
          >
            <flourish:Card.Body>
              <flourish:FlourishListBox x:Name="ActiveTaskList" MinHeight="220" />
            </flourish:Card.Body>
          </flourish:Card>
          <flourish:Card
            Margin="8,0,0,0"
            VerticalAlignment="Stretch"
            Title="Recent outcomes"
            Text="Completion never faults; failures and cancellation are represented in the result object."
          >
            <flourish:Card.Body>
              <flourish:FlourishListBox x:Name="OutcomeList" MinHeight="220" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
