<Page
  x:Class="ArkheideSystem.Gallery.Views.ConfigurationPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,40">
      <TextBlock Style="{StaticResource GalleryPageTitleStyle}" Text="Configuration &amp; localization" />
      <TextBlock
        Style="{StaticResource GalleryPageSubtitleStyle}"
        Text="Read the effective host configuration, update appsettings.json atomically, trigger reloads, and change the active Flourish locale while the app stays open."
      />

      <Border Margin="0,24,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Effective configuration" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="The configuration service exposes the merged value from every registered provider." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ReadKeyBox" Style="{StaticResource GalleryTextBoxStyle}" Text="Flourish:Preferences:Theme" />
            <Button Grid.Column="1" Margin="10,0,0,0" Click="ReadValue_Click" Content="Read value" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Grid.Column="2" Margin="8,0,0,0" Click="Reload_Click" Content="Reload providers" Style="{StaticResource GalleryActionButtonStyle}" />
          </Grid>
          <TextBlock x:Name="ReadValueText" Margin="0,12,0,0" Foreground="{DynamicResource AccentBrush}" Text="No value read yet." TextWrapping="Wrap" />
          <TextBlock x:Name="SnapshotText" Margin="0,6,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Transactional appsettings update" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Set, append, and remove use an atomic file replacement. A successful write immediately reloads the effective configuration." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Configuration path" />
              <TextBox x:Name="WriteKeyBox" Style="{StaticResource GalleryTextBoxStyle}" Text="Gallery:Runtime:Message" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="String value" />
              <TextBox x:Name="WriteValueBox" Style="{StaticResource GalleryTextBoxStyle}" Text="Hello from runtime" />
            </StackPanel>
          </Grid>
          <WrapPanel Margin="0,14,0,0">
            <Button Margin="0,0,8,0" Click="SetValue_Click" Content="Set &amp; save" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="0,0,8,0" Click="MergeValue_Click" Content="Merge into parent" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="0,0,8,0" Click="AppendValue_Click" Content="Append to array" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Click="RemoveValue_Click" Content="Remove" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="WriteResultText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="No runtime update yet." TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Runtime locale" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Choose a built-in locale or enter the identifier of a locale registered by the host." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="LocaleBox" Height="32" IsEditable="True" VerticalContentAlignment="Center" />
            <Button Grid.Column="1" Margin="10,0,0,0" Click="ApplyLocale_Click" Content="Apply locale" Style="{StaticResource GalleryActionButtonStyle}" />
          </Grid>
          <TextBlock x:Name="LocaleStatusText" Margin="0,12,0,0" Foreground="{DynamicResource AccentBrush}" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Runtime locale files" />
          <TextBlock Margin="0,5,0,16" Foreground="{DynamicResource MutedTextBrush}" Text="Register a lang_&lt;locale&gt;.json file, reload it after external edits, and remove that source through its registration handle." TextWrapping="Wrap" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="LocaleFilePathBox" Style="{StaticResource GalleryTextBoxStyle}" Text="lang_ES.json" />
            <Button Grid.Column="1" Margin="10,0,0,0" Click="RegisterLocaleFile_Click" Content="Register file" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Grid.Column="2" Margin="8,0,0,0" Click="ReloadLocaleFile_Click" Content="Reload file" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Grid.Column="3" Margin="8,0,0,0" Click="UnregisterLocaleFile_Click" Content="Unregister" Style="{StaticResource GalleryActionButtonStyle}" />
          </Grid>
          <TextBlock x:Name="LocaleFileStatusText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="No locale file registered by this page." TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
