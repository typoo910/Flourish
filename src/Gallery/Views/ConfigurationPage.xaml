<Page
  x:Class="ArkheideSystem.Gallery.Views.ConfigurationPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Edit configuration and localization while the app runs."
        ChunkHeroTitle="Configuration &amp; localization"
      />

      <flourish:Chunk
        ChunkDescription="Read values from the active provider chain."
        ChunkTitle="Effective configuration"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE721;"
              Title="Configuration key"
              Text="Choose a value from the active provider chain."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="ReadKeyBox" Width="220" Text="Flourish:Preferences:Theme" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE721;"
              Title="Read merged value"
              Text="Resolve the selected configuration key."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="ReadValue_Click" Content="Read value" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE72C;"
              Title="Configuration providers"
              Text="Reload every registered provider."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="Reload_Click" Content="Reload providers" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Result">
            <flourish:Card.Body>
              <StackPanel>
                <flourish:FlourishTextBlock x:Name="ReadValueText" Role="Status" Text="No value read yet." />
                <flourish:FlourishTextBlock x:Name="SnapshotText" Margin="0,8,0,0" Role="Status" />
              </StackPanel>
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Edit appsettings.json atomically."
        ChunkTitle="Transactional appsettings update"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE71B;"
              Title="Configuration path"
              Text="Choose the appsettings key to edit."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="WriteKeyBox" Width="220" Text="Gallery:Runtime:Message" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE70F;"
              Title="String value"
              Text="Provide the value used by write operations."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="WriteValueBox" Width="220" Text="Hello from runtime" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74E;"
              Title="Set value"
              Text="Replace the selected value and save atomically."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="SetValue_Click" Content="Set &amp; save" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE72D;"
              Title="Merge value"
              Text="Merge the value into its parent object."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="MergeValue_Click" Content="Merge into parent" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE710;"
              Title="Append value"
              Text="Append the value to the selected array."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="AppendValue_Click" Content="Append to array" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Remove value"
              Text="Remove the selected key from appsettings.json."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="RemoveValue_Click" Content="Remove" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Result">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="WriteResultText" Role="Status" Text="No runtime update yet." />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Switch the active localization source."
        ChunkTitle="Runtime locale"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <flourish:ListCard
            Grid.Column="0"
            Margin="0,0,8,0"
            VerticalAlignment="Stretch"
            Presenter="&#xE774;"
            Title="Application locale"
            Text="Choose a built-in or host-registered locale."
          >
            <flourish:ListCard.Body>
              <flourish:FlourishComboBox
                x:Name="LocaleBox"
                Width="220"
                SelectionChanged="LocaleBox_SelectionChanged"
              />
            </flourish:ListCard.Body>
          </flourish:ListCard>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="LocaleStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage an external locale file."
        ChunkTitle="Runtime locale files"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE8A5;"
              Title="Locale file path"
              Text="Choose an external lang_&lt;locale&gt;.json source."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="LocaleFilePathBox" Width="220" Text="lang_ES.json" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE710;"
              Title="Register locale file"
              Text="Register the selected source with localization."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="RegisterLocaleFile_Click" Content="Register file" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE72C;"
              Title="Reload locale file"
              Text="Reload edits from the registered source."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="ReloadLocaleFile_Click" Content="Reload file" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Remove locale file"
              Text="Unregister the current external source."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="UnregisterLocaleFile_Click" Content="Unregister" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Result">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="LocaleFileStatusText" Role="Status" Text="No locale file registered by this page." />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
