<Page
  x:Class="ArkheideSystem.Gallery.Views.ListBoxItemPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Represent one generated or explicit item inside FlourishListBox."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishListBoxItem"
    />

    <flourish:Chunk
      Content="Navigation-specific states are properties of the item container, not separate controls."
      Title="Variant"
    >
      <UniformGrid Columns="3">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="An ordinary selectable list item."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Item"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="170">
              <flourish:FlourishListBox Width="210" HorizontalAlignment="Center" VerticalAlignment="Center">
                <flourish:FlourishListBoxItem Content="Selected item" IsSelected="True" />
              </flourish:FlourishListBox>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0"
          Content="A non-selectable semantic label in a navigation list."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Group header"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="170">
              <flourish:FlourishListBox Width="210" HorizontalAlignment="Center" VerticalAlignment="Center" Appearance="Navigation">
                <flourish:FlourishListBoxItem Content="Workspace" IsGroupHeader="True" />
              </flourish:FlourishListBox>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="An item whose activation dispatches a configured command."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Command item"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="170">
              <flourish:FlourishListBox Width="210" HorizontalAlignment="Center" VerticalAlignment="Center" Appearance="Navigation">
                <flourish:FlourishListBoxItem Content="Refresh" IsCommandItem="True" />
              </flourish:FlourishListBox>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid ItemsSource="{Binding Properties, ElementName=RootPage}" AutoGenerateColumns="False" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Member" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Normally FlourishListBox creates these containers. Declare one directly only when item-level navigation state is part of the view."
      Title="Container"
    >
      <flourish:Card Title="Generated items" Content="Data-bound lists should put content in ItemsSource and let the parent list prepare visibility, group, command, enabled, and tooltip bindings." />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the FlourishListBoxItem API reference." Icon="&#xE8A5;" IsEnabled="False" Title="FlourishListBoxItem documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
