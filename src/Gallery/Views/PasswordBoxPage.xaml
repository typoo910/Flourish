<Page
  x:Class="ArkheideSystem.Gallery.Views.PasswordBoxPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Collect a masked secret while retaining the native PasswordBox security boundary."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishPasswordBox"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="MemberGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="Member" Width="220" />
          <DataGridTextColumn Binding="{Binding Description}" Header="Purpose" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Use PasswordChanged to move a secret into application-owned secure processing."
      Title="Entry"
    >
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="The default mask protects the visible value while the editor has focus."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Masked value"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="136">
              <flourish:FlourishPasswordBox
                Width="240"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Password="Flourish"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="PasswordChar and MaxLength refine the input policy without exposing plaintext."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Configured mask"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="136">
              <flourish:FlourishPasswordBox
                Width="240"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxLength="12"
                Password="Secret"
                PasswordChar="●"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Browse the Flourish source repository."
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Read the FlourishPasswordBox API reference."
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="FlourishPasswordBox documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
