<Page
  x:Class="ArkheideSystem.Gallery.Views.RuntimeRoutePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Inspect a route registered after startup."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Runtime route"
    />

    <flourish:Chunk
      Content="Review the instance and navigation parameter created by the runtime route."
      Title="Route details"
    >
      <flourish:Presenter
        Content="This page was not present in ConfigureNavigation; its route and menu entry were registered while Gallery was already running."
        PresenterMode="Split"
        PresenterPosition="Left"
        Title="Route instance"
      >
        <flourish:Presenter.Presentation>
          <StackPanel>
            <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,22,0,0" Text="PAGE INSTANCE" />
            <flourish:FlourishTextBlock x:Name="InstanceText" Foreground="{DynamicResource FlourishPrimaryForegroundBrush}" TextWrapping="Wrap" />
            <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,18,0,0" Text="NAVIGATION PARAMETER" />
            <flourish:FlourishTextBlock x:Name="ParameterText" Foreground="{DynamicResource FlourishNeutralForeground1Brush}" TextWrapping="Wrap" />
          </StackPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the navigation documentation." Icon="&#xE946;" IsEnabled="False" Title="Navigation documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
