<Page
  x:Class="ArkheideSystem.Gallery.Views.RuntimeRoutePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        Description="Inspect a route registered after startup."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Runtime route"
      />

      <flourish:Chunk
        Description="Review the instance and navigation parameter created by the runtime route."
        Title="Route details"
      >
        <flourish:Presenter
          Description="This page was not present in ConfigureNavigation; its route and menu entry were registered while Gallery was already running."
          PresenterMode="Split"
          PresenterPosition="Right"
          Title="Route instance"
        >
          <flourish:Presenter.Presentation>
            <StackPanel>
              <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,22,0,0" Text="PAGE INSTANCE" />
              <flourish:FlourishTextBlock x:Name="InstanceText" Foreground="{DynamicResource FlourishPrimaryForegroundBrush}" TextWrapping="Wrap" />
              <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,18,0,0" Text="NAVIGATION PARAMETER" />
              <flourish:FlourishTextBlock x:Name="ParameterText" Foreground="{DynamicResource FlourishNeutralForeground1Brush}" TextWrapping="Wrap" />
            </StackPanel>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
