<Page
  x:Class="ArkheideSystem.Gallery.Views.RuntimeRoutePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
    <flourish:Chunk
      ChunkDescription="This page was registered while Gallery was already running."
      ChunkTitle="A route created at runtime"
    >
      <flourish:FlourishCard
        MaxWidth="680"
        HorizontalAlignment="Left"
        Appearance="Elevated"
      >
        <StackPanel>
          <flourish:FlourishTextBlock Role="Paragraph" Text="This page was not present in ConfigureNavigation. Its route and menu entry were registered while Gallery was already running." />
          <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,22,0,0" Text="PAGE INSTANCE" />
          <flourish:FlourishTextBlock x:Name="InstanceText" FontFamily="Consolas" FontSize="16" Foreground="{DynamicResource FlourishPrimaryForegroundBrush}" TextWrapping="Wrap" />
          <flourish:FlourishTextBlock Role="FieldLabel" Margin="0,18,0,0" Text="NAVIGATION PARAMETER" />
          <flourish:FlourishTextBlock x:Name="ParameterText" FontFamily="Consolas" Foreground="{DynamicResource FlourishNeutralForeground1Brush}" TextWrapping="Wrap" />
        </StackPanel>
      </flourish:FlourishCard>
    </flourish:Chunk>
  </StackPanel>
</Page>
