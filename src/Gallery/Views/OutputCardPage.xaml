<Page
  x:Class="ArkheideSystem.Gallery.Views.OutputCardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="A compact scrollable viewport for append-only logs, progress, results, and failures."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="OutputCard"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="OutputCardMemberGrid"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        CanUserReorderColumns="False"
        FontWeight="Regular"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="MEMBER" Width="224" />
          <DataGridTextColumn Binding="{Binding Description}" Header="PURPOSE" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Output">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <flourish:ActionCard
            Icon="&#xE8F2;"
            Content="Append one timestamped message."
            Title="Append message"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="AppendMessage_Click" Content="Write line" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8FD;"
            Content="Exercise automatic viewport scrolling."
            Title="Append burst"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="AppendBurst_Click" Content="Write 24 lines" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE946;"
            Content="Append a summary of the current Output value."
            Title="Inspect output"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="InspectOutput_Click" Content="Write summary" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Content="Reset the message history."
            Title="Clear history"
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="ClearHistory_Click" Content="Clear" Variant="Danger" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard
          x:Name="HistoryOutput"
          Grid.Column="2"
          AutomationProperties.Name="Output history"
          VerticalAlignment="Stretch"
        />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:OutputCard x:Name=&quot;BuildOutput&quot; /&gt;&#xA;&#xA;BuildOutput.WriteLine(&quot;Build started.&quot;);&#xA;BuildOutput.WriteLine(&quot;Build completed.&quot;);&#xA;BuildOutput.Clear();" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          AutomationProperties.Name="Flourish GitHub repository"
          Content="Repository link placeholder"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          AutomationProperties.Name="OutputCard documentation"
          Content="Canonical documentation link placeholder"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="OutputCard documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
