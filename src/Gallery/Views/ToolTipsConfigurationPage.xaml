<Page
  x:Class="ArkheideSystem.Gallery.Views.ToolTipsConfigurationPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Title="ToolTips"
      Content="Enable the Flourish tooltip presentation and define its initial display delay."
      PresenterMode="Split"
      PresenterPosition="Right"
    />

    <flourish:Chunk Title="Tip policy">
      <flourish:Card
        Icon="&#xE823;"
        Title="Shared presentation"
        Content="UseTips applies the Flourish tooltip host to eligible controls. Empty or whitespace-only tooltip content never opens a surface."
      />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="builder.ConfigureShell(shell =&gt;&#10;    shell.UseTips(delay: 200));&#10;&#10;// XAML&#10;&lt;flourish:Button&#10;  AutomationProperties.Name=&quot;Refresh&quot;&#10;  Content=&quot;Refresh&quot;&#10;  ToolTip=&quot;Reload the current data.&quot; /&gt;" />
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the canonical Flourish documentation." Icon="&#xE946;" IsEnabled="False" Title="Flourish documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
