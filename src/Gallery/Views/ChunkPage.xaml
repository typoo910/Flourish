<Page
  x:Class="ArkheideSystem.Gallery.Views.ChunkPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Group one page topic into a full-width section."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Chunk"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid ItemsSource="{Binding Properties, ElementName=RootPage}" AutoGenerateColumns="False" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Property" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Example">
      <UniformGrid Columns="2">
        <flourish:Card
          Margin="0,0,8,0"
          Icon="&#xE8A5;"
          Content="This page's full-width sections directly demonstrate the Chunk boundary around one topic."
          Title="Content surface"
        />
        <flourish:Card
          Margin="8,0,0,0"
          Content="Use a deliberate layout only when peer content belongs to the same Chunk topic."
          Title="Custom body"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Content">
      <flourish:Card Content="Title names the topic, Content adds optional context, and Body contains the required section content. Empty optional copy collapses with its spacing." />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:PageBody&gt;&#xA;  &lt;flourish:HeaderChunk Title=&quot;Reports&quot; Content=&quot;Review generated reports.&quot; PresenterMode=&quot;Split&quot; PresenterPosition=&quot;Right&quot; /&gt;&#xA;  &lt;flourish:Chunk Title=&quot;Recent reports&quot;&gt;&#xA;    &lt;flourish:Card Title=&quot;Quarterly report&quot; Content=&quot;Ready to review.&quot; /&gt;&#xA;  &lt;/flourish:Chunk&gt;&#xA;&lt;/flourish:PageBody&gt;" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE8A5;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the Chunk guide." Icon="&#xE946;" IsEnabled="False" Title="Chunk documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
