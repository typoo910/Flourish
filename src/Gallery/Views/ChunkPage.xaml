<Page
  x:Class="ArkheideSystem.Gallery.Views.ChunkPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        x:Name="HeroPreview"
        Description="Compose Gallery pages from focused sections."
        Title="Chunk"
        PresenterMode="Split"
        PresenterPosition="Right"
      >
        <flourish:ChunkHero.Body>
          <WrapPanel>
            <flourish:Button Variant="Filled" Click="PresenterRight_Click" Content="Presentation right" />
            <flourish:Button Margin="8,0,0,0" Variant="Tonal" Click="PresenterLeft_Click" Content="Presentation left" />
            <flourish:Button Margin="8,0,0,0" Variant="Tonal" Click="Overlay_Click" Content="Overlay" />
          </WrapPanel>
        </flourish:ChunkHero.Body>
        <flourish:ChunkHero.Presentation>
          <Border MinHeight="220" Background="{DynamicResource FlourishPrimarySurfaceBrush}" CornerRadius="12">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <flourish:FlourishTextBlock FontFamily="{DynamicResource FlourishIconFontFamily}" FontSize="{DynamicResource FlourishFontSizeIcon}" Foreground="{DynamicResource FlourishPrimaryForegroundBrush}" Role="Icon" Text="&#xE7C8;" />
              <flourish:FlourishTextBlock Margin="0,12,0,0" Role="CardTitle" Text="Presenter" />
            </StackPanel>
          </Border>
        </flourish:ChunkHero.Presentation>
      </flourish:ChunkHero>

      <flourish:Chunk Title="Variant">
        <UniformGrid Columns="2">
          <flourish:Card Margin="0,0,8,0" MainText="Places the presenter beside the hero content." Title="Split" />
          <flourish:Card Margin="8,0,0,0" MainText="Layers the hero content over the presenter." Title="Overlay" />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk Title="Table">
        <flourish:DataGrid ItemsSource="{Binding Properties, ElementName=RootPage}" AutoGenerateColumns="False" IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Property" />
            <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
          </DataGrid.Columns>
        </flourish:DataGrid>
      </flourish:Chunk>

      <flourish:Chunk Title="Example">
        <UniformGrid Columns="2">
          <flourish:IconCard
            Margin="0,0,8,0"
            Icon="&#xE8A5;"
            MainText="Use IconCard when a concise card needs one icon."
            Title="Single icon"
          />
          <flourish:Card
            Margin="8,0,0,0"
            MainText="Body accepts controls, cards, lists, presenters, paragraphs, and custom layouts."
            Title="Chunk body"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk Title="Chunk content">
        <flourish:Card MainText="Title names one topic, Description adds optional context, and Body hosts the section content." />
      </flourish:Chunk>

      <flourish:Chunk Title="Hero content">
        <flourish:Card MainText="ChunkHero adds Presentation and reserves the page-leading position for exactly one introduction." />
      </flourish:Chunk>

      <flourish:Chunk Title="Usage">
        <flourish:Card MainText="Start with exactly one leading ChunkHero, then place each distinct topic in its own full-width Chunk. Omit Description when Title is sufficient." />
      </flourish:Chunk>

      <flourish:Chunk Title="Reference">
        <UniformGrid Columns="2">
          <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE8A5;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
          <flourish:CardButton Margin="8,0,0,0" Content="Read the Chunk and ChunkHero guide." Icon="&#xE946;" IsEnabled="False" Title="Chunk documentation" ToolTip="External navigation is not available in Gallery." />
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
