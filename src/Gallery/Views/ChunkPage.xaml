<Page
  x:Class="ArkheideSystem.Gallery.Views.ChunkPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        x:Name="HeroPreview"
        ChunkHeroDescription="ChunkHero introduces the page with one focused story. Its body carries actions, while its presenter can host an image, a visual, or a simple color surface."
        ChunkHeroMode="SplitLeft"
        ChunkHeroTitle="Build every page from meaningful chunks"
      >
        <flourish:ChunkHero.ChunkHeroBody>
          <WrapPanel>
            <flourish:Button Appearance="Primary" Click="SplitLeft_Click" Content="Split left" />
            <flourish:Button Margin="8,0,0,0" Click="SplitRight_Click" Content="Split right" />
            <flourish:Button Margin="8,0,0,0" Click="Overlay_Click" Content="Overlay" />
          </WrapPanel>
        </flourish:ChunkHero.ChunkHeroBody>
        <flourish:ChunkHero.ChunkHeroPresenter>
          <Border
            MinHeight="220"
            Background="{DynamicResource FlourishPrimarySurfaceBrush}"
            CornerRadius="12"
          >
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="48"
                Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
                Text="&#xE7C8;"
              />
              <flourish:FlourishTextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Role="CardTitle"
                Text="Presenter"
              />
            </StackPanel>
          </Border>
        </flourish:ChunkHero.ChunkHeroPresenter>
      </flourish:ChunkHero>

      <flourish:Chunk
        ChunkDescription="A Chunk owns its heading, optional supporting copy, and one body region. The default margin separates adjacent chunks; the default spacing keeps the heading and body on the same rhythm."
        ChunkTitle="Chunk anatomy"
      >
        <flourish:FlourishCard>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <flourish:FlourishTextBlock
              Width="44"
              Height="44"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              FontFamily="{DynamicResource FlourishIconFontFamily}"
              FontSize="28"
              Foreground="{DynamicResource FlourishAccentForegroundBrush}"
              Text="&#xE8A5;"
              TextAlignment="Center"
            />
            <StackPanel Grid.Column="1" Margin="16,0,0,0">
              <flourish:FlourishTextBlock Role="CardTitle" Text="ChunkBody accepts any UIElement" />
              <flourish:FlourishTextBlock
                Margin="0,4,0,0"
                Role="Description"
                Text="Cards, forms, lists, charts, and custom layouts all belong here without changing the surrounding section rhythm."
              />
            </StackPanel>
          </Grid>
        </flourish:FlourishCard>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Optional description">
        <UniformGrid Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            Content="ChunkDescription can be omitted when the title already provides enough context."
            Icon="&#xE946;"
            Title="Keep headings concise"
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            Content="ChunkMargin and ChunkSpacing can be overridden for an intentional local composition."
            Icon="&#xE8B0;"
            Title="Use the shared rhythm"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="SplitLeft keeps copy on the left, SplitRight places the presenter first, and Overlay layers the copy over a full presenter. Use the buttons in the hero to compare all three modes."
        ChunkTitle="ChunkHero modes"
      >
        <flourish:FlourishCard Appearance="Subtle">
          <flourish:FlourishTextBlock
            Role="Paragraph"
            Text="A page should have at most one hero, positioned before its regular chunks. A presenter is deliberately general-purpose: the preview above uses only a themed background block."
          />
        </flourish:FlourishCard>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
