<Page
  x:Class="ArkheideSystem.Gallery.Views.ChunkPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:ScrollViewer
    HorizontalScrollBarVisibility="Disabled"
    VerticalScrollBarVisibility="Auto"
  >
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        x:Name="HeroPreview"
        ChunkHeroDescription="ChunkHero introduces the page with one focused story. Its body carries actions, while its presenter can host an image, a visual, or a simple color surface."
        PresenterMode="Split"
        PresenterPosition="Right"
        ChunkHeroTitle="Build every page from meaningful chunks"
      >
        <flourish:ChunkHero.ChunkHeroBody>
          <WrapPanel>
            <flourish:Button Variant="Filled" Click="PresenterRight_Click" Content="Presenter right" />
            <flourish:Button
              Variant="Tonal"
              Margin="8,0,0,0"
              Click="PresenterLeft_Click"
              Content="Presenter left"
            />
            <flourish:Button
              Variant="Tonal"
              Margin="8,0,0,0"
              Click="Overlay_Click"
              Content="Overlay"
            />
          </WrapPanel>
        </flourish:ChunkHero.ChunkHeroBody>
        <flourish:ChunkHero.Presenter>
          <Border
            MinHeight="220"
            Background="{DynamicResource FlourishPrimarySurfaceBrush}"
            CornerRadius="12"
          >
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="48"
                Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
                Text="&#xE7C8;"
              />
              <flourish:FlourishTextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Role="CardTitle"
                Text="Presenter"
              />
            </StackPanel>
          </Border>
        </flourish:ChunkHero.Presenter>
      </flourish:ChunkHero>

      <flourish:Chunk
        ChunkDescription="Inspect the structure of a page section."
        ChunkTitle="Chunk anatomy"
      >
        <flourish:Card
          Title="ChunkBody content"
          Text="A Chunk owns a heading, optional supporting copy, and one body region while shared spacing preserves the page rhythm."
        >
          <flourish:Card.Body>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <flourish:FlourishTextBlock
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="28"
                Foreground="{DynamicResource FlourishAccentForegroundBrush}"
                Text="&#xE8A5;"
                TextAlignment="Center"
              />
              <flourish:FlourishTextBlock
                Grid.Column="1"
                Margin="16,0,0,0"
                Role="Paragraph"
                Text="Cards, forms, lists, charts, and custom layouts all belong in ChunkBody."
              />
            </Grid>
          </flourish:Card.Body>
        </flourish:Card>
      </flourish:Chunk>

      <flourish:Chunk ChunkTitle="Optional description">
        <UniformGrid Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            Content="ChunkDescription can be omitted when the title already provides enough context."
            Icon="&#xE946;"
            Title="Keep headings concise"
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            Content="ChunkMargin and ChunkSpacing can be overridden for an intentional local composition."
            Icon="&#xE8B0;"
            Title="Use the shared rhythm"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Compare the presenter layouts available to a page hero."
        ChunkTitle="Hero layouts"
      >
        <StackPanel>
          <UniformGrid Columns="2" Rows="1">
            <flourish:Card
              Margin="0,0,8,0"
              Title="Presenter right"
              Text="Split with PresenterPosition=Right keeps the presenter on the right."
            />
            <flourish:Card
              Margin="8,0,0,0"
              Title="Presenter left"
              Text="Split with PresenterPosition=Left places the presenter first."
            />
          </UniformGrid>
          <flourish:Card
            Margin="0,16,0,0"
            Title="Overlay"
            Text="Overlay layers the copy over a full presenter; a page should contain at most one hero."
          />
        </StackPanel>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
