<Page
  x:Class="ArkheideSystem.Gallery.Views.TextBlockPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Apply semantic Flourish typography roles without locally reproducing font resources."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishTextBlock"
    />

    <flourish:Chunk
      Content="Representative roles share an equal-height TopDown presentation row."
      Title="Variant"
    >
      <UniformGrid Columns="3">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="Default text for ordinary interface copy."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Body"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="160">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Role="Body"
                Text="Standard body copy"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0"
          Content="A semantic heading for a compact content surface."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="CardTitle"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="160">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Role="CardTitle"
                Text="Card title"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="An icon glyph rendered through the configured icon family."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Icon"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="160">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Role="Icon"
                Text="&#xE8A5;"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        ItemsSource="{Binding Properties, ElementName=RootPage}"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Member" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Roles">
      <flourish:Card
        Title="Semantic typography"
        Content="Body, Paragraph, Caption, Muted, FieldLabel, Subtitle, Description, CardTitle, SectionTitle, PageTitle, Status, and Icon are available. Prefer the owning higher-level control for structural titles."
      />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the FlourishTextBlock API reference." Icon="&#xE8A5;" IsEnabled="False" Title="FlourishTextBlock documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
