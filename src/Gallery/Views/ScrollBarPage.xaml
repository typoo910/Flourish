<Page
  x:Class="ArkheideSystem.Gallery.Views.ScrollBarPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Expose a standalone Flourish-styled WPF scroll bar for a custom scrolling surface."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishScrollBar"
    />

    <flourish:Chunk
      Content="Orientation is native WPF state; both examples reserve the same presentation height."
      Title="Variant"
    >
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="Moves along the vertical axis."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Vertical"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="210">
              <flourish:FlourishScrollBar
                Height="150"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Maximum="100"
                Orientation="Vertical"
                Value="36"
                ViewportSize="24"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="Moves along the horizontal axis."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Horizontal"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="210">
              <flourish:FlourishScrollBar
                Width="260"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Maximum="100"
                Orientation="Horizontal"
                Value="36"
                ViewportSize="24"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid ItemsSource="{Binding Properties, ElementName=RootPage}" AutoGenerateColumns="False" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Member" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Most content should use ScrollViewer, which creates and coordinates FlourishScrollBar automatically."
      Title="Hosting"
    >
      <flourish:Card Title="Custom surfaces" Content="Use the standalone control only when a custom viewport owns its offset, range, commands, and synchronization." />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the FlourishScrollBar API reference." Icon="&#xE8A5;" IsEnabled="False" Title="FlourishScrollBar documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
