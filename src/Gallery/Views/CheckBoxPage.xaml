<Page
  x:Class="ArkheideSystem.Gallery.Views.CheckBoxPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Represent an independent Boolean or optional three-state preference."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishCheckBox"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="MemberGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="Member" Width="220" />
          <DataGridTextColumn Binding="{Binding Description}" Header="Purpose" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Choose two-state behavior for ordinary preferences and three-state behavior only when null has a clear meaning."
      Title="Selection"
    >
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="Checked and Unchecked map directly to true and false."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Boolean"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="136">
              <flourish:FlourishCheckBox
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="Enable notifications"
                IsChecked="True"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="Indeterminate represents an inherited or mixed value."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Three state"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="136">
              <flourish:FlourishCheckBox
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="Use inherited setting"
                IsChecked="{x:Null}"
                IsThreeState="True"
              />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Browse the Flourish source repository."
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Read the FlourishCheckBox API reference."
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="FlourishCheckBox documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
