<Page
  x:Class="ArkheideSystem.Gallery.Views.TitleBarRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Change title-bar identity, features, and search at runtime."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Title bar &amp; search"
    />

    <flourish:Chunk
      Content="Update application metadata and logo information."
      Title="Application identity"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE8D2;"
            Title="Application title"
            Content="Set the application name used by the title and logo surfaces."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="TitleBox" Width="220" KeyDown="IdentityBox_KeyDown" LostFocus="IdentityBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8D2;"
            Title="Application subtitle"
            Content="Set supporting application text shown in the logo surface."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="SubtitleBox" Width="220" KeyDown="IdentityBox_KeyDown" LostFocus="IdentityBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8B9;"
            Title="Logo path"
            Content="Optionally provide an image for the title-bar logo."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="LogoPathBox" Width="220" KeyDown="LogoBox_KeyDown" LostFocus="LogoBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8D2;"
            Title="Logo fallback text"
            Content="Provide text to use when an image is unavailable."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="LogoFallbackBox" Width="220" KeyDown="LogoBox_KeyDown" LostFocus="LogoBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8D2;"
            Title="Unnamed project"
            Content="Set the title shown when no project is active."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="UnnamedProjectBox" Width="220" KeyDown="UnnamedProjectBox_KeyDown" LostFocus="UnnamedProjectBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="IdentityOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Toggle individual title-bar elements."
      Title="Element visibility"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
        <flourish:ActionCard
          Icon="&#xE713;"
          Title="Title-bar element"
          Content="Choose the element whose visibility will change."
        >
          <flourish:ActionCard.Body>
            <flourish:FlourishComboBox x:Name="TitleBarElementBox" Width="220" SelectionChanged="TitleBarElementBox_SelectionChanged" />
          </flourish:ActionCard.Body>
        </flourish:ActionCard>
        <flourish:ActionCard
          Margin="{DynamicResource FlourishActionCardPeerMargin}"
          Icon="&#xE7B3;"
          Title="Element visibility"
          Content="Show or hide the selected title-bar element."
        >
          <flourish:ActionCard.Body>
            <flourish:FlourishCheckBox
              x:Name="TitleBarElementVisibleBox"
              VerticalAlignment="Center"
              Checked="TitleBarElementVisibleBox_Changed"
              Content="Visible"
              Unchecked="TitleBarElementVisibleBox_Changed"
            />
          </flourish:ActionCard.Body>
        </flourish:ActionCard>
        <flourish:ActionCard
          Margin="{DynamicResource FlourishActionCardPeerMargin}"
          Icon="&#xE72A;"
          Title="Breadcrumb display"
          Content="Choose the breadcrumb visibility policy."
        >
          <flourish:ActionCard.Body>
            <flourish:FlourishComboBox x:Name="BreadcrumbModeBox" Width="220" SelectionChanged="BreadcrumbModeBox_SelectionChanged" />
          </flourish:ActionCard.Body>
        </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="ElementOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Bind and exercise asynchronous search."
      Title="Runtime search binding"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE721;"
            Title="Search query"
            Content="Set the text shared with the title-bar search box."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="SearchTextBox" Width="220" KeyDown="SearchTextBox_KeyDown" LostFocus="SearchTextBox_LostFocus" Text="runtime API" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8A7;"
            Title="Search focus"
            Content="Move keyboard focus to the title-bar search box."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="FocusSearch_Click" Content="Focus search" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Title="Clear query"
            Content="Remove the current title-bar search text."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="ClearSearch_Click" Content="Clear" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE8D2;"
            Title="Search placeholder"
            Content="Set the hint shown when the search box is empty."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="SearchPlaceholderBox" Width="220" KeyDown="SearchPlaceholderBox_KeyDown" LostFocus="SearchPlaceholderBox_LostFocus" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE7B3;"
            Title="Search visibility"
            Content="Show or hide the title-bar search feature."
          >
            <flourish:ActionCard.Body>
              <flourish:Button x:Name="ToggleSearchVisibilityButton" Click="ToggleSearchVisibility_Click" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="SearchOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Toggle complete shell capabilities."
      Title="High-level shell features"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE713;"
            Title="Shell feature"
            Content="Choose the complete shell surface to configure."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishComboBox x:Name="ShellFeatureBox" Width="220" SelectionChanged="ShellFeatureBox_SelectionChanged" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74E;"
            Title="Feature availability"
            Content="Enable or disable the selected shell surface."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishCheckBox
                x:Name="ShellFeatureEnabledBox"
                VerticalAlignment="Center"
                Checked="ShellFeatureEnabledBox_Changed"
                Content="Enabled"
                Unchecked="ShellFeatureEnabledBox_Changed"
              />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="ShellFeatureOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
