<Page
  x:Class="ArkheideSystem.Gallery.Views.TitleBarRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Change title-bar identity, features, and search at runtime."
        ChunkHeroTitle="Title bar &amp; search"
      />

      <flourish:Chunk
        ChunkDescription="Update shell identity values."
        ChunkTitle="Identity"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE8D2;"
              Title="Window title"
              Text="Set the primary identity text shown by the shell."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="TitleBox" Width="220" KeyDown="IdentityBox_KeyDown" LostFocus="IdentityBox_LostFocus" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8D2;"
              Title="Window subtitle"
              Text="Set the supporting identity text shown by the shell."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="SubtitleBox" Width="220" KeyDown="IdentityBox_KeyDown" LostFocus="IdentityBox_LostFocus" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8B9;"
              Title="Logo path"
              Text="Optionally provide an image for the title-bar logo."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="LogoPathBox" Width="220" KeyDown="LogoBox_KeyDown" LostFocus="LogoBox_LostFocus" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8D2;"
              Title="Logo fallback text"
              Text="Provide text to use when an image is unavailable."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="LogoFallbackBox" Width="220" KeyDown="LogoBox_KeyDown" LostFocus="LogoBox_LostFocus" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="IdentityStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Toggle individual title-bar elements."
        ChunkTitle="Element visibility"
      >
        <StackPanel>
          <flourish:ListCard
            Presenter="&#xE713;"
            Title="Title-bar element"
            Text="Choose the element whose visibility will change."
          >
            <flourish:ListCard.Body>
              <flourish:FlourishComboBox x:Name="TitleBarElementBox" Width="220" SelectionChanged="TitleBarElementBox_SelectionChanged" />
            </flourish:ListCard.Body>
          </flourish:ListCard>
          <flourish:ListCard
            Margin="{DynamicResource FlourishListCardPeerMargin}"
            Presenter="&#xE7B3;"
            Title="Element visibility"
            Text="Show or hide the selected title-bar element."
          >
            <flourish:ListCard.Body>
              <flourish:FlourishCheckBox
                x:Name="TitleBarElementVisibleBox"
                VerticalAlignment="Center"
                Checked="TitleBarElementVisibleBox_Changed"
                Content="Visible"
                Unchecked="TitleBarElementVisibleBox_Changed"
              />
            </flourish:ListCard.Body>
          </flourish:ListCard>
          <flourish:ListCard
            Margin="{DynamicResource FlourishListCardPeerMargin}"
            Presenter="&#xE72A;"
            Title="Breadcrumb display"
            Text="Choose the breadcrumb visibility policy."
          >
            <flourish:ListCard.Body>
              <flourish:FlourishComboBox x:Name="BreadcrumbModeBox" Width="220" SelectionChanged="BreadcrumbModeBox_SelectionChanged" />
            </flourish:ListCard.Body>
          </flourish:ListCard>
        </StackPanel>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Bind and exercise asynchronous search."
        ChunkTitle="Runtime search binding"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE721;"
              Title="Search query"
              Text="Set the text shared with the title-bar search box."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="SearchTextBox" Width="220" KeyDown="SearchTextBox_KeyDown" LostFocus="SearchTextBox_LostFocus" Text="runtime API" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8A7;"
              Title="Search focus"
              Text="Move keyboard focus to the title-bar search box."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="FocusSearch_Click" Content="Focus search" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Clear query"
              Text="Remove the current title-bar search text."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="ClearSearch_Click" Content="Clear" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE8D2;"
              Title="Search placeholder"
              Text="Set the hint shown when the search box is empty."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="SearchPlaceholderBox" Width="220" KeyDown="SearchPlaceholderBox_KeyDown" LostFocus="SearchPlaceholderBox_LostFocus" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE7B3;"
              Title="Search visibility"
              Text="Show or hide the title-bar search feature."
            >
              <flourish:ListCard.Body>
                <flourish:Button x:Name="ToggleSearchVisibilityButton" Click="ToggleSearchVisibility_Click" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="SearchStatusText" Role="Status" Text="Waiting for a query." />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Toggle complete shell capabilities."
        ChunkTitle="High-level shell features"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE713;"
              Title="Shell feature"
              Text="Choose the complete shell surface to configure."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishComboBox x:Name="ShellFeatureBox" Width="220" SelectionChanged="ShellFeatureBox_SelectionChanged" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74E;"
              Title="Feature availability"
              Text="Enable or disable the selected shell surface."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishCheckBox
                  x:Name="ShellFeatureEnabledBox"
                  VerticalAlignment="Center"
                  Checked="ShellFeatureEnabledBox_Changed"
                  Content="Enabled"
                  Unchecked="ShellFeatureEnabledBox_Changed"
                />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="ShellFeatureStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </Grid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
