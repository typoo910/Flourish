<Page
  x:Class="ArkheideSystem.Gallery.Views.NavigationRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Change navigation structure and behavior at runtime."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Navigation at runtime"
    />

    <flourish:Chunk
      Content="Configure the live navigation panel."
      Title="Navigation panel"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE700;"
            Title="Panel state"
            Content="Open or close the live navigation panel."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="TogglePanel_Click" Content="Open / close" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Panel availability"
            Content="Enable or disable navigation without recreating the shell."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="TogglePanelEnabled_Click" Content="Enable / disable" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE72A;"
            Title="Panel direction"
            Content="Choose the edge that hosts the navigation panel."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishComboBox x:Name="DirectionBox" Width="120" SelectionChanged="DirectionBox_SelectionChanged" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Open width"
            Content="Set the panel width while navigation is open."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="OpenWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="240" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Closed width"
            Content="Set the panel width while navigation is closed."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="ClosedWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="64" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Minimum width"
            Content="Set the minimum allowed panel width."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="MinWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="150" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Maximum width"
            Content="Set the maximum allowed panel width."
          >
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="MaxWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="480" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="PanelOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Add and remove a route with its menu item."
      Title="Route transaction"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE710;"
            Title="Install demo route"
            Content="Register the runtime route and its navigation item."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="InstallRoute_Click" Content="Install demo route" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE72A;"
            Title="Navigate to route"
            Content="Open the registered runtime destination."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="NavigateRoute_Click" Content="Navigate to route" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE713;"
            Title="Navigation item"
            Content="Enable or disable the installed menu item."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="ToggleMenuItem_Click" Content="Enable / disable item" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Title="Remove demo route"
            Content="Remove the route and its navigation item."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="RemoveRoute_Click" Content="Remove route" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="RouteOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Manage cached page instances."
      Title="Page cache"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard
            Icon="&#xE74E;"
            Title="Enable cache"
            Content="Retain page instances for subsequent navigation."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="EnableCache_Click" Content="Enable cache" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE711;"
            Title="Disable cache"
            Content="Stop retaining page instances for this route."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="DisableCache_Click" Content="Disable cache" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Title="Evict demo page"
            Content="Remove the demo instance while preserving its route."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="EvictCache_Click" Content="Evict demo page" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard
            Margin="{DynamicResource FlourishActionCardPeerMargin}"
            Icon="&#xE74D;"
            Title="Clear page cache"
            Content="Remove every active cached page instance."
          >
            <flourish:ActionCard.Body>
              <flourish:Button Click="ClearCache_Click" Content="Clear all" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="CacheOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </Grid>
    </flourish:Chunk>
    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="builder&#10;    .ConfigureServices((_, services) =&gt;&#10;        services.AddNavigable&lt;HomePage&gt;(&quot;Overview&quot;, &quot;\uE80F&quot;))&#10;    .ConfigureShell(shell =&gt; shell.UseNavigation())&#10;    .ConfigureNavigation(navigation =&gt; navigation.SetGroup(&#10;        &quot;General&quot;,&#10;        groupId: 0,&#10;        group =&gt; group.AddNavigableViewItem&lt;HomePage&gt;(isInitial: true)));" />
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the canonical Flourish documentation." Icon="&#xE946;" IsEnabled="False" Title="Flourish documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
