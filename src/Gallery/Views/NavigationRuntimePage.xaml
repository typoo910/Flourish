<Page
  x:Class="ArkheideSystem.Gallery.Views.NavigationRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Change navigation structure and behavior at runtime."
        ChunkHeroTitle="Navigation at runtime"
      />

      <flourish:Chunk
        ChunkDescription="Configure the live navigation panel."
        ChunkTitle="Navigation panel"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE700;"
              Title="Panel state"
              Text="Open or close the live navigation panel."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="TogglePanel_Click" Content="Open / close" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Panel availability"
              Text="Enable or disable navigation without recreating the shell."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="TogglePanelEnabled_Click" Content="Enable / disable" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE72A;"
              Title="Panel direction"
              Text="Choose the edge that hosts the navigation panel."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishComboBox x:Name="DirectionBox" Width="120" SelectionChanged="DirectionBox_SelectionChanged" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Open width"
              Text="Set the panel width while navigation is open."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="OpenWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="240" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Closed width"
              Text="Set the panel width while navigation is closed."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="ClosedWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="64" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Minimum width"
              Text="Set the minimum allowed panel width."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="MinWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="150" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Maximum width"
              Text="Set the maximum allowed panel width."
            >
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="MaxWidthBox" Width="110" KeyDown="WidthBox_KeyDown" LostFocus="WidthBox_LostFocus" Text="480" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:OutputCard x:Name="PanelOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Add and remove a route with its menu item."
        ChunkTitle="Route transaction"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE710;"
              Title="Install demo route"
              Text="Register the runtime route and its navigation item."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="InstallRoute_Click" Content="Install demo route" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE72A;"
              Title="Navigate to route"
              Text="Open the registered runtime destination."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="NavigateRoute_Click" Content="Navigate to route" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE713;"
              Title="Navigation item"
              Text="Enable or disable the installed menu item."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleMenuItem_Click" Content="Enable / disable item" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Remove demo route"
              Text="Remove the route and its navigation item."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="RemoveRoute_Click" Content="Remove route" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:OutputCard x:Name="RouteOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
        </Grid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage cached page instances."
        ChunkTitle="Page cache"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard
              Presenter="&#xE74E;"
              Title="Enable cache"
              Text="Retain page instances for subsequent navigation."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="EnableCache_Click" Content="Enable cache" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE711;"
              Title="Disable cache"
              Text="Stop retaining page instances for this route."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="DisableCache_Click" Content="Disable cache" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Evict demo page"
              Text="Remove the demo instance while preserving its route."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="EvictCache_Click" Content="Evict demo page" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard
              Margin="{DynamicResource FlourishListCardPeerMargin}"
              Presenter="&#xE74D;"
              Title="Clear page cache"
              Text="Remove every active cached page instance."
            >
              <flourish:ListCard.Body>
                <flourish:Button Click="ClearCache_Click" Content="Clear all" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:OutputCard x:Name="CacheOutput" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Stretch" />
        </Grid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:ScrollViewer>
</Page>
