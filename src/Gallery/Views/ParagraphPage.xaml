<Page
  x:Class="ArkheideSystem.Gallery.Views.ParagraphPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Represent one normalized Large-size paragraph inside a Document reading surface."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Paragraph"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        ItemsSource="{Binding Properties, ElementName=RootPage}"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Member" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Paragraph is the normalized text item; Document owns the border, first-line indentation, and spacing between items."
      Title="Document relationship"
    >
      <flourish:Document>
        <flourish:Paragraph Text="Each Paragraph represents exactly one portion of continuous prose. Set Text directly and let the enclosing Document apply the standard reading layout." />
        <flourish:Paragraph Text="Use several Paragraph children when the subject needs several distinct thoughts. Use a Card instead when one concise block is enough." />
      </flourish:Document>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Browse the Flourish source repository."
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Read the Paragraph API reference."
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="Paragraph documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
