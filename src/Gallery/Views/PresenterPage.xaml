<Page
  x:Class="ArkheideSystem.Gallery.Views.PresenterPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Combine copy and controls with images, illustrations, or groups of icons in one full-width presentation layout."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Presenter"
    />

    <flourish:Chunk
      Content="Each diagram summarizes a composition. The full-width live examples follow the member table."
      Title="Variant"
    >
      <UniformGrid Columns="3">
        <flourish:Presenter Margin="0,0,8,0" Content="Places Presentation beside the copy-and-body region." PresenterMode="TopDown" PresenterPosition="Left" Title="Split">
          <flourish:Presenter.Presentation>
            <Grid MinHeight="180">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Margin="8" Background="{DynamicResource FlourishNeutralBackground2Brush}" CornerRadius="8" />
              <Border Grid.Column="1" Margin="8" BorderBrush="{DynamicResource FlourishControlStrokeBrush}" BorderThickness="1" CornerRadius="8" />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="4,0" Content="Layers the copy-and-body region over Presentation." PresenterMode="TopDown" PresenterPosition="Left" Title="Overlay">
          <flourish:Presenter.Presentation>
            <Grid MinHeight="180">
              <Border Margin="8" Background="{DynamicResource FlourishNeutralBackground2Brush}" CornerRadius="8" />
              <Border Width="120" Height="64" BorderBrush="{DynamicResource FlourishControlStrokeBrush}" BorderThickness="1" CornerRadius="8" />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="8,0,0,0" Content="Places Presentation above the copy-and-body region and may share a row with peer TopDown Presenters." PresenterMode="TopDown" PresenterPosition="Left" Title="TopDown">
          <flourish:Presenter.Presentation>
            <Grid MinHeight="180">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Margin="8" Background="{DynamicResource FlourishNeutralBackground2Brush}" CornerRadius="8" />
              <Border Grid.Row="1" Margin="8" BorderBrush="{DynamicResource FlourishControlStrokeBrush}" BorderThickness="1" CornerRadius="8" />
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        ItemsSource="{Binding Properties, ElementName=RootPage}"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Property" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Split places Presentation beside the copy-and-body region."
      Title="Split"
    >
      <StackPanel>
        <flourish:Presenter
          Content="Presentation defaults to the left. Body shares the copy region and stays aligned with the copy on the right."
          PresenterMode="Split"
          PresenterPosition="Left"
          Title="Left presentation (default)"
        >
          <flourish:Presenter.Body>
            <flourish:Button Content="Explore layout" Variant="Filled" />
          </flourish:Presenter.Body>
          <flourish:Presenter.Presentation>
            <Border MinHeight="180">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <flourish:FlourishTextBlock Margin="8" Role="Icon" Text="&#xE8A5;" />
                <flourish:FlourishTextBlock Margin="8" Role="Icon" Text="&#xE7C8;" />
                <flourish:FlourishTextBlock Margin="8" Role="Icon" Text="&#xE790;" />
              </StackPanel>
            </Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>

        <flourish:Presenter
          Margin="{DynamicResource FlourishPresenterPeerMargin}"
          Content="Body remains grouped with the copy while Presentation stays on the default left side."
          PresenterMode="Split"
          PresenterPosition="Left"
          Title="Split with Body"
        >
          <flourish:Presenter.Body>
            <flourish:Button Content="Open details" Variant="Tonal" />
          </flourish:Presenter.Body>
          <flourish:Presenter.Presentation>
            <Border MinHeight="180">
              <flourish:FlourishTextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Role="Icon"
                Text="&#xE950;"
              />
            </Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </StackPanel>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Overlay layers copy and Body over Presentation."
      Title="Overlay"
    >
      <flourish:Presenter
        Content="The presentation fills the surface while the copy remains readable above its scrim."
        PresenterMode="Overlay"
        PresenterPosition="Right"
        Title="Layered presentation"
      >
        <flourish:Presenter.Body>
          <flourish:Button Content="Overlay action" Variant="Filled" />
        </flourish:Presenter.Body>
        <flourish:Presenter.Presentation>
          <Border MinHeight="240" CornerRadius="12">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#0F6CBD" />
                <GradientStop Offset="1" Color="#5C2E91" />
              </LinearGradientBrush>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
              <flourish:FlourishTextBlock Margin="12" Foreground="#80FFFFFF" Role="Icon" Text="&#xE8A5;" />
              <flourish:FlourishTextBlock Margin="12" Foreground="#80FFFFFF" Role="Icon" Text="&#xE8B9;" />
              <flourish:FlourishTextBlock Margin="12" Foreground="#80FFFFFF" Role="Icon" Text="&#xE790;" />
            </StackPanel>
          </Border>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk
      Content="TopDown places Presentation above a left-aligned copy-and-body region."
      Title="TopDown"
    >
      <flourish:Presenter
        Content="Use the vertical composition when the presented visual should establish context before the supporting copy and action."
        PresenterMode="TopDown"
        PresenterPosition="Right"
        Title="Top-down presentation"
      >
        <flourish:Presenter.Body>
          <flourish:Button Content="Continue" Variant="Filled" />
        </flourish:Presenter.Body>
        <flourish:Presenter.Presentation>
          <Border MinHeight="180">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
              <flourish:FlourishTextBlock Margin="12" Role="Icon" Text="&#xE7C8;" />
              <flourish:FlourishTextBlock Margin="12" Role="Icon" Text="&#xE8A5;" />
              <flourish:FlourishTextBlock Margin="12" Role="Icon" Text="&#xE950;" />
            </StackPanel>
          </Border>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Choosing a surface">
      <UniformGrid Columns="2">
        <flourish:Card
          Margin="0,0,8,0"
          Content="Use Card when concise copy needs exactly one icon and no arbitrary child controls."
          Title="One icon"
        />
        <flourish:Card
          Margin="8,0,0,0"
          Content="Use Presenter for images, multiple icons, illustrations, or controls arranged with copy."
          Title="Rich presentation"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:Presenter Title=&quot;Reports&quot; Content=&quot;Review recent activity.&quot; PresenterMode=&quot;Split&quot; PresenterPosition=&quot;Left&quot;&gt;&#xA;  &lt;flourish:Presenter.Presentation&gt;&#xA;    &lt;Image Source=&quot;Assets/reports.png&quot; Stretch=&quot;Uniform&quot; /&gt;&#xA;  &lt;/flourish:Presenter.Presentation&gt;&#xA;&lt;/flourish:Presenter&gt;" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Browse the Flourish source repository."
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Read the Presenter guide."
          Icon="&#xE946;"
          IsEnabled="False"
          Title="Presenter documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
