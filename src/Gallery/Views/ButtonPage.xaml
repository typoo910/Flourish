<Page
  x:Class="ArkheideSystem.Gallery.Views.ButtonPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Accessible application actions built on the WPF button contract."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Button"
    />

    <flourish:Chunk Title="Variant">
      <UniformGrid Columns="3">
        <flourish:Presenter Margin="0,0,8,8" Content="Adds elevation to separate an action from its surrounding surface." PresenterMode="TopDown" PresenterPosition="Left" Title="Elevated">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Elevated" Variant="Elevated" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="8,0,8,8" Content="Expresses the primary action in a group." PresenterMode="TopDown" PresenterPosition="Left" Title="Filled">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Filled" Variant="Filled" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="8,0,0,8" Content="Provides a softer filled emphasis for supporting actions." PresenterMode="TopDown" PresenterPosition="Left" Title="Tonal">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Tonal" Variant="Tonal" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="0,8,8,0" Content="Uses a boundary for a medium-emphasis secondary action." PresenterMode="TopDown" PresenterPosition="Left" Title="Outlined">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Outlined" Variant="Outlined" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="8,8,8,0" Content="Keeps tertiary and toolbar actions visually quiet." PresenterMode="TopDown" PresenterPosition="Left" Title="Text">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Text" Variant="Text" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter Margin="8,8,0,0" Content="Identifies destructive or difficult-to-reverse intent." PresenterMode="TopDown" PresenterPosition="Left" Title="Danger">
          <flourish:Presenter.Presentation>
            <Border MinHeight="160"><flourish:Button HorizontalAlignment="Center" VerticalAlignment="Center" Content="Danger" Variant="Danger" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="PropertiesGrid"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        CanUserReorderColumns="False"
        FontWeight="Regular"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn
            Binding="{Binding Name}"
            Header="PROPERTY"
            Width="220"
          />
          <DataGridTextColumn
            Binding="{Binding Description}"
            Header="PURPOSE"
            Width="*"
          />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Button">
      <flourish:Presenter
        Content="Bind Command for reusable actions, or handle Click for local behavior."
        PresenterMode="Split"
        PresenterPosition="Left"
        Title="Standard action"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,0" Content="Continue" Variant="Filled" />
            <flourish:Button Content="Cancel" Variant="Outlined" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Icon-only Button">
      <flourish:Presenter
        Content="Use a ToolTip or automation name when the action has no visible label."
        PresenterMode="Split"
        PresenterPosition="Left"
        Title="Icon actions"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button
              Margin="0,0,8,0"
              AutomationProperties.Name="Refresh"
              Icon="&#xE72C;"
              ToolTip="Refresh"
              Variant="Text"
            />
            <flourish:Button
              Margin="0,0,8,0"
              AutomationProperties.Name="Search"
              Icon="&#xE8D4;"
              ToolTip="Search"
              Variant="Text"
            />
            <flourish:Button Content="Add item" Icon="&#xE710;" Variant="Filled" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Hover feedback">
      <flourish:Presenter
        Content="HoverReveal supplies feedback and can be disabled for a local action."
        PresenterMode="Split"
        PresenterPosition="Left"
        Title="Pointer feedback"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,0" Content="Default reveal" />
            <flourish:Button flourish:HoverReveal.IsEnabled="False" Content="Static feedback" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Interaction contract">
      <flourish:Card
        Content="Every button type retains focus, keyboard activation, commands, disabled state, and automation behavior."
      />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:Button&#xA;  Command=&quot;{Binding SaveCommand}&quot;&#xA;  Content=&quot;Save&quot;&#xA;  Icon=&quot;&amp;#xE74E;&quot;&#xA;  Variant=&quot;Filled&quot; /&gt;" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          AutomationProperties.Name="Flourish GitHub repository"
          Content="Repository link placeholder"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          AutomationProperties.Name="Button documentation"
          Content="Canonical documentation link placeholder"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="Button documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
