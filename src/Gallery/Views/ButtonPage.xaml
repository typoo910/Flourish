<Page
  x:Class="ArkheideSystem.Gallery.Views.ButtonPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:Chunk
        ChunkDescription="Buttons use Appearance for action semantics. Dedicated derived controls add icon, card, and window-caption behavior without changing the common button contract."
        ChunkTitle="Button"
      />

      <flourish:Chunk
        ChunkDescription="Button is the standard content action. Its Appearance property changes semantic emphasis while Content, Command, IsEnabled, ToolTip, and sizing remain standard WPF button properties."
        ChunkTitle="Button and Appearance"
      >
        <flourish:FlourishCard>
          <StackPanel>
            <flourish:FlourishTextBlock Role="FieldLabel" Text="APPEARANCE" />
            <WrapPanel Margin="0,8,0,0">
              <flourish:Button Margin="0,0,8,8" Appearance="Standard" Content="Standard" />
              <flourish:Button Margin="0,0,8,8" Appearance="Primary" Content="Primary" />
              <flourish:Button Margin="0,0,8,8" Appearance="Subtle" Content="Subtle" />
              <flourish:Button Margin="0,0,8,8" Appearance="Danger" Content="Danger" />
            </WrapPanel>
            <Grid Margin="0,4,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,12,0">
                <flourish:FlourishTextBlock Role="CardTitle" Text="Standard and Primary" />
                <flourish:FlourishTextBlock
                  Margin="0,4,0,0"
                  Role="Description"
                  Text="Use Standard for normal actions and Primary for the main action in a related group."
                />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <flourish:FlourishTextBlock Role="CardTitle" Text="Subtle and Danger" />
                <flourish:FlourishTextBlock
                  Margin="0,4,0,0"
                  Role="Description"
                  Text="Use Subtle for low-emphasis commands and Danger for destructive actions."
                />
              </StackPanel>
            </Grid>
          </StackPanel>
        </flourish:FlourishCard>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="IconButton derives from Button and adds Icon. Icon-only actions use compact 30 by 30 geometry by default, while icon-plus-label commands keep the ordinary Button geometry. Plain ToolTip content automatically uses FlourishToolTip."
        ChunkTitle="IconButton"
      >
        <flourish:FlourishCard>
          <StackPanel>
            <WrapPanel>
              <flourish:IconButton Margin="0,0,8,8" Appearance="Subtle" Icon="&#xE72C;" ToolTip="Refresh" />
              <flourish:IconButton Margin="0,0,8,8" Appearance="Subtle" Icon="&#xE8D4;" ToolTip="Search" />
              <flourish:IconButton Margin="0,0,8,8" Appearance="Primary" Content="Add item" Icon="&#xE710;" />
              <flourish:IconButton Margin="0,0,0,8" Appearance="Danger" Content="Remove" Icon="&#xE74D;" />
            </WrapPanel>
            <flourish:FlourishTextBlock
              Margin="0,4,0,0"
              Role="Description"
              Text="Icon accepts either a glyph string or a visual element. Content is optional and is shown as the label when supplied."
            />
          </StackPanel>
        </flourish:FlourishCard>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="CardButton represents a complete interactive card. Title is the heading, inherited Content is the supporting description, and IconPosition chooses where the icon appears."
        ChunkTitle="CardButton"
      >
        <UniformGrid Margin="0,0,0,0" Columns="2">
          <flourish:CardButton
            Margin="0,0,8,0"
            Content="Review generated reports and recent exports."
            Icon="&#xE8A5;"
            Title="Open reports"
          />
          <flourish:CardButton
            Margin="8,0,0,0"
            Content="Place the icon beside the text when the card needs a compact horizontal layout."
            Icon="&#xE946;"
            IconPosition="Left"
            Title="View details"
          />
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="WindowCaptionButton derives from IconButton and is reserved for minimize, maximize, restore, and close commands in a window title bar. It intentionally uses dedicated caption geometry."
        ChunkTitle="WindowCaptionButton"
      >
        <flourish:FlourishCard>
          <StackPanel>
            <Border
              HorizontalAlignment="Left"
              Background="{DynamicResource FlourishControlBackgroundBrush}"
              BorderBrush="{DynamicResource FlourishControlStrokeBrush}"
              BorderThickness="1"
            >
              <StackPanel Orientation="Horizontal">
                <flourish:WindowCaptionButton Appearance="Subtle" Icon="&#xE921;" ToolTip="Minimize" />
                <flourish:WindowCaptionButton Appearance="Subtle" Icon="&#xE922;" ToolTip="Maximize" />
                <flourish:WindowCaptionButton Appearance="Danger" Icon="&#xE8BB;" ToolTip="Close" />
              </StackPanel>
            </Border>
            <flourish:FlourishTextBlock
              Margin="0,8,0,0"
              Role="Description"
              Text="Use Danger only for a close command. Other caption commands normally use Subtle."
            />
          </StackPanel>
        </flourish:FlourishCard>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="The Button family participates in HoverReveal. The default template provides animated hover feedback, while the attached properties can adjust it for a local interaction requirement."
        ChunkTitle="Hover feedback"
      >
        <flourish:FlourishCard>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,0" Content="Default hover reveal" />
            <flourish:Button flourish:HoverReveal.IsEnabled="False" Content="Static hover feedback" />
            <flourish:Button Margin="8,0,0,0" Appearance="Danger" Content="Danger hover reveal" />
          </WrapPanel>
        </flourish:FlourishCard>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
