<Page
  x:Class="ArkheideSystem.Gallery.Views.ButtonPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Accessible application actions built on the WPF button contract."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Button"
    />

    <flourish:Chunk Title="Variant">
      <flourish:Presenter
        Content="Filled is primary, Tonal is softer, and Danger identifies destructive intent."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Visual hierarchy"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,8" Content="Elevated" Variant="Elevated" />
            <flourish:Button Margin="0,0,8,8" Content="Filled" Variant="Filled" />
            <flourish:Button Margin="0,0,8,8" Content="Tonal" Variant="Tonal" />
            <flourish:Button Margin="0,0,8,8" Content="Outlined" Variant="Outlined" />
            <flourish:Button Margin="0,0,8,8" Content="Text" Variant="Text" />
            <flourish:Button Margin="0,0,0,8" Content="Danger" Variant="Danger" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="PropertiesGrid"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        CanUserReorderColumns="False"
        FontWeight="Regular"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn
            Binding="{Binding Name}"
            Header="PROPERTY"
            Width="220"
          />
          <DataGridTextColumn
            Binding="{Binding Description}"
            Header="PURPOSE"
            Width="*"
          />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Button">
      <flourish:Presenter
        Content="Bind Command for reusable actions, or handle Click for local behavior."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Standard action"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,0" Content="Continue" Variant="Filled" />
            <flourish:Button Content="Cancel" Variant="Outlined" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Icon-only Button">
      <flourish:Presenter
        Content="Use a ToolTip or automation name when the action has no visible label."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Icon actions"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button
              Margin="0,0,8,0"
              AutomationProperties.Name="Refresh"
              Icon="&#xE72C;"
              ToolTip="Refresh"
              Variant="Text"
            />
            <flourish:Button
              Margin="0,0,8,0"
              AutomationProperties.Name="Search"
              Icon="&#xE8D4;"
              ToolTip="Search"
              Variant="Text"
            />
            <flourish:Button Content="Add item" Icon="&#xE710;" Variant="Filled" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="CardButton">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Content="Review generated reports."
          Icon="&#xE8A5;"
          Title="Open reports"
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Content="Use a compact horizontal layout."
          Icon="&#xE946;"
          IconPosition="Left"
          Title="View details"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="WindowCaptionButton">
      <flourish:Presenter
        Content="Use dedicated title-bar geometry and reserve Danger for close."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Caption actions"
      >
        <flourish:Presenter.Presentation>
          <Border
            Background="{DynamicResource FlourishControlBackgroundBrush}"
            BorderBrush="{DynamicResource FlourishControlStrokeBrush}"
            BorderThickness="1"
          >
            <StackPanel Orientation="Horizontal">
              <flourish:WindowCaptionButton AutomationProperties.Name="Minimize" Icon="&#xE921;" ToolTip="Minimize" Variant="Text" />
              <flourish:WindowCaptionButton AutomationProperties.Name="Maximize" Icon="&#xE922;" ToolTip="Maximize" Variant="Text" />
              <flourish:WindowCaptionButton AutomationProperties.Name="Close" Icon="&#xE8BB;" ToolTip="Close" Variant="Danger" />
            </StackPanel>
          </Border>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Hover feedback">
      <flourish:Presenter
        Content="HoverReveal supplies feedback and can be disabled for a local action."
        PresenterMode="Split"
        PresenterPosition="Right"
        Title="Pointer feedback"
      >
        <flourish:Presenter.Presentation>
          <WrapPanel>
            <flourish:Button Margin="0,0,8,0" Content="Default reveal" />
            <flourish:Button flourish:HoverReveal.IsEnabled="False" Content="Static feedback" />
          </WrapPanel>
        </flourish:Presenter.Presentation>
      </flourish:Presenter>
    </flourish:Chunk>

    <flourish:Chunk Title="Interaction contract">
      <flourish:Card
        Content="Every button type retains focus, keyboard activation, commands, disabled state, and automation behavior."
      />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:Document>
        <flourish:Paragraph
          Text="Handle Click for local behavior or bind Command and CommandParameter when the application owns the action."
        />
        <flourish:Paragraph
          Text="Use CardButton for an interactive card surface; Card remains display-only."
        />
      </flourish:Document>
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          AutomationProperties.Name="Flourish GitHub repository"
          Content="Repository link placeholder"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          AutomationProperties.Name="Button documentation"
          Content="Canonical documentation link placeholder"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="Button documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
