<Page
  x:Class="ArkheideSystem.Gallery.Views.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="Transparent"
  mc:Ignorable="d"
>
  <Grid>
    <flourish:Chunk
      Width="520"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      ChunkDescription="这里是设置页面占位内容，后续可在这里管理主题、偏好和应用配置。"
      ChunkMargin="0"
      ChunkTitle="设置"
    >
      <flourish:FlourishTextBlock
        HorizontalAlignment="Center"
        FontFamily="Segoe MDL2 Assets"
        FontSize="42"
        Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
        Text="&#xE713;"
      />
    </flourish:Chunk>
  </Grid>
</Page>
