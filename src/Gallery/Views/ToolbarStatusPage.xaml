<Page
  x:Class="ArkheideSystem.Gallery.Views.ToolbarStatusPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Edit toolbar, status, and custom shell regions at runtime."
        ChunkHeroTitle="Toolbar, status and shell regions"
      />

      <flourish:Chunk
        ChunkDescription="Manage this page's toolbar actions."
        ChunkTitle="Dynamic toolbar"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Toolbar item"
          Text="Add an action for this page, then use the shell toolbar above the page to execute its runtime command."
        >
          <flourish:Card.Body>
            <StackPanel>
              <WrapPanel>
                <flourish:Button Click="AddToolbarItem_Click" Content="Add / update action" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleToolbarItemEnabled_Click" Content="Enable / disable" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleToolbarItemVisible_Click" Content="Show / hide" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleIconOnly_Click" Content="Icon / icon + text" />
                <flourish:Button Margin="8,0,0,0" Click="MoveToolbarItem_Click" Content="Move action" />
                <flourish:Button Margin="8,0,0,0" Click="RemoveToolbarItem_Click" Content="Remove" />
              </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows toolbar state and command execution.">
            <flourish:Card.Body>
              <StackPanel>
                <flourish:FlourishTextBlock x:Name="ToolbarStateText" Role="Status" />
                <flourish:FlourishTextBlock x:Name="CommandLogText" Margin="0,8,0,0" FontFamily="Consolas" Role="Status" Text="The toolbar command has not run yet." />
              </StackPanel>
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage status items and indicators."
        ChunkTitle="Status bar"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Status controls"
          Text="Update persistent or timed items, shell indicators, and the visibility of the status bar."
        >
          <flourish:Card.Body>
            <StackPanel>
              <WrapPanel>
                <StackPanel Margin="0,0,10,0">
                  <flourish:FlourishTextBlock Role="FieldLabel" Text="Status text" />
                  <flourish:FlourishTextBox x:Name="StatusTextBox" Width="230" Text="Gallery runtime API is ready" />
                </StackPanel>
                <flourish:Button Margin="0,20,0,0" Click="UpsertStatus_Click" Content="Add / update" />
                <flourish:Button Margin="8,20,0,0" Click="ShowTimedStatus_Click" Content="Show for 4 seconds" />
                <flourish:Button Margin="8,20,0,0" Click="ToggleStatusVisible_Click" Content="Show / hide" />
                <flourish:Button Margin="8,20,0,0" Click="MoveStatus_Click" Content="Move item" />
                <flourish:Button Margin="8,20,0,0" Click="RemoveStatus_Click" Content="Remove" />
              </WrapPanel>
              <WrapPanel Margin="0,12,0,0">
                <flourish:Button Click="ToggleLan_Click" Content="Toggle LAN indicator" />
                <flourish:Button Margin="8,0,0,0" Click="TogglePower_Click" Content="Toggle power indicator" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleStatusBar_Click" Content="Enable / disable bar" />
              </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows status items, indicators, and bar state.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="StatusStateText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage content in a custom shell region."
        ChunkTitle="Custom shell region"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="ContentHeader registration"
          Text="Register a WPF element, then disable, reorder, replace, or remove it while the shell remains visible."
        >
          <flourish:Card.Body>
            <StackPanel>
              <WrapPanel>
                <flourish:Button Click="AddRegion_Click" Content="Add header content" />
                <flourish:Button Margin="8,0,0,0" Click="ToggleRegion_Click" Content="Enable / disable" />
                <flourish:Button Margin="8,0,0,0" Click="ReorderRegion_Click" Content="Change order" />
                <flourish:Button Margin="8,0,0,0" Click="RemoveRegion_Click" Content="Remove" />
              </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the current ContentHeader registration.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="RegionStateText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
