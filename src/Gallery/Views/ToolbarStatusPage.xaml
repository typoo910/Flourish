<Page
  x:Class="ArkheideSystem.Gallery.Views.ToolbarStatusPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,40">
      <TextBlock Style="{StaticResource GalleryPageTitleStyle}" Text="Toolbar, status and shell regions" />
      <TextBlock
        Style="{StaticResource GalleryPageSubtitleStyle}"
        Text="Every control below edits a live shell surface. Stable IDs make add, update, move, enable, hide and remove operations deterministic."
      />

      <Border Margin="0,24,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Dynamic toolbar" />
          <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="Add an action for this page, then use the actual shell toolbar button above the page to execute the runtime command." TextWrapping="Wrap" />
          <WrapPanel Margin="0,14,0,0">
            <Button Click="AddToolbarItem_Click" Content="Add / update action" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleToolbarItemEnabled_Click" Content="Enable / disable" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleToolbarItemVisible_Click" Content="Show / hide" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleIconOnly_Click" Content="Icon / icon + text" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="MoveToolbarItem_Click" Content="Move action" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="RemoveToolbarItem_Click" Content="Remove" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="ToolbarStateText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
          <TextBlock x:Name="CommandLogText" Margin="0,8,0,0" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" Text="The toolbar command has not run yet." TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Status bar" />
          <WrapPanel Margin="0,14,0,0">
            <StackPanel Margin="0,0,10,0">
              <TextBlock Style="{StaticResource GalleryFieldLabelStyle}" Text="Status text" />
              <TextBox x:Name="StatusTextBox" Width="230" Style="{StaticResource GalleryTextBoxStyle}" Text="Gallery runtime API is ready" />
            </StackPanel>
            <Button Margin="0,20,0,0" Click="UpsertStatus_Click" Content="Add / update" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,20,0,0" Click="ShowTimedStatus_Click" Content="Show for 4 seconds" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,20,0,0" Click="ToggleStatusVisible_Click" Content="Show / hide" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,20,0,0" Click="MoveStatus_Click" Content="Move item" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,20,0,0" Click="RemoveStatus_Click" Content="Remove" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <WrapPanel Margin="0,12,0,0">
            <Button Click="ToggleLan_Click" Content="Toggle LAN indicator" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="TogglePower_Click" Content="Toggle power indicator" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleStatusBar_Click" Content="Enable / disable bar" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="StatusStateText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Margin="0,16,0,0" Style="{StaticResource GalleryCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource GallerySectionTitleStyle}" Text="Custom shell region" />
          <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource MutedTextBrush}" Text="Register a WPF element in ContentHeader. The registration can be disabled, reordered, replaced or removed while the shell is visible." TextWrapping="Wrap" />
          <WrapPanel Margin="0,14,0,0">
            <Button Click="AddRegion_Click" Content="Add header content" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ToggleRegion_Click" Content="Enable / disable" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="ReorderRegion_Click" Content="Change order" Style="{StaticResource GalleryActionButtonStyle}" />
            <Button Margin="8,0,0,0" Click="RemoveRegion_Click" Content="Remove" Style="{StaticResource GalleryActionButtonStyle}" />
          </WrapPanel>
          <TextBlock x:Name="RegionStateText" Margin="0,12,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
