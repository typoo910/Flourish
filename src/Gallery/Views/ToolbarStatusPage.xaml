<Page
  x:Class="ArkheideSystem.Gallery.Views.ToolbarStatusPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Edit toolbar, status, and custom shell regions at runtime."
        ChunkHeroTitle="Toolbar, status and shell regions"
      />

      <flourish:Chunk
        ChunkDescription="Manage this page's toolbar actions."
        ChunkTitle="Dynamic toolbar"
      >
        <UniformGrid VerticalAlignment="Stretch" Columns="2">
          <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard Presenter="&#xE710;" Text="Add the Gallery runtime action or refresh its registration." Title="Toolbar action">
              <flourish:ListCard.Body>
                <flourish:Button Click="AddToolbarItem_Click" Content="Add / update" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8D7;" Text="Enable or disable command invocation." Title="Action availability">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleToolbarItemEnabled_Click" Content="Enable / disable" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE890;" Text="Show or hide the toolbar action." Title="Action visibility">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleToolbarItemVisible_Click" Content="Show / hide" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8A5;" Text="Switch between icon-only and icon-with-text presentation." Title="Action presentation">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleIconOnly_Click" Content="Toggle format" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8CB;" Text="Move the action within the toolbar order." Title="Action order">
              <flourish:ListCard.Body>
                <flourish:Button Click="MoveToolbarItem_Click" Content="Move action" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE74D;" Text="Remove the runtime toolbar action." Title="Toolbar action">
              <flourish:ListCard.Body>
                <flourish:Button Click="RemoveToolbarItem_Click" Content="Remove" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <StackPanel>
                <flourish:FlourishTextBlock x:Name="ToolbarStateText" Role="Status" />
                <flourish:FlourishTextBlock x:Name="CommandLogText" Margin="0,8,0,0" FontFamily="Consolas" Role="Status" Text="The toolbar command has not run yet." />
              </StackPanel>
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage status items and indicators."
        ChunkTitle="Status bar"
      >
        <UniformGrid VerticalAlignment="Stretch" Columns="2">
          <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard Presenter="&#xE8D2;" Text="Set the content used by persistent and timed status items." Title="Status text">
              <flourish:ListCard.Body>
                <flourish:FlourishTextBox x:Name="StatusTextBox" Width="230" Text="Gallery runtime API is ready" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE710;" Text="Add the persistent item or update its current text." Title="Persistent status">
              <flourish:ListCard.Body>
                <flourish:Button Click="UpsertStatus_Click" Content="Add / update" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE823;" Text="Show the current status text for four seconds." Title="Timed status">
              <flourish:ListCard.Body>
                <flourish:Button Click="ShowTimedStatus_Click" Content="Show for 4 seconds" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE890;" Text="Show or hide the registered status item." Title="Status visibility">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleStatusVisible_Click" Content="Show / hide" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8CB;" Text="Move the item within the status bar order." Title="Status order">
              <flourish:ListCard.Body>
                <flourish:Button Click="MoveStatus_Click" Content="Move item" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE74D;" Text="Remove the registered status item." Title="Persistent status">
              <flourish:ListCard.Body>
                <flourish:Button Click="RemoveStatus_Click" Content="Remove" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE968;" Text="Toggle the shell LAN indicator." Title="LAN indicator">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleLan_Click" Content="Toggle LAN" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE945;" Text="Toggle the shell power indicator." Title="Power indicator">
              <flourish:ListCard.Body>
                <flourish:Button Click="TogglePower_Click" Content="Toggle power" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE7E8;" Text="Enable or disable the complete status bar." Title="Status bar availability">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleStatusBar_Click" Content="Enable / disable" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="StatusStateText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage content in a custom shell region."
        ChunkTitle="Custom shell region"
      >
        <UniformGrid VerticalAlignment="Stretch" Columns="2">
          <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
            <flourish:ListCard Presenter="&#xE710;" Text="Register the demo WPF element in ContentHeader." Title="Header content">
              <flourish:ListCard.Body>
                <flourish:Button Click="AddRegion_Click" Content="Add content" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8D7;" Text="Enable or disable the custom shell region." Title="Region availability">
              <flourish:ListCard.Body>
                <flourish:Button Click="ToggleRegion_Click" Content="Enable / disable" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE8CB;" Text="Move the region within the shell order." Title="Region order">
              <flourish:ListCard.Body>
                <flourish:Button Click="ReorderRegion_Click" Content="Change order" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
            <flourish:ListCard Margin="{DynamicResource FlourishListCardPeerMargin}" Presenter="&#xE74D;" Text="Remove the ContentHeader registration." Title="Header content">
              <flourish:ListCard.Body>
                <flourish:Button Click="RemoveRegion_Click" Content="Remove" />
              </flourish:ListCard.Body>
            </flourish:ListCard>
          </StackPanel>
          <flourish:Card Margin="8,0,0,0" VerticalAlignment="Stretch" Title="Output">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="RegionStateText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
