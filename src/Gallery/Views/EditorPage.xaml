<Page
  x:Class="ArkheideSystem.Gallery.Views.EditorPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="Transparent"
  mc:Ignorable="d"
>
  <Grid>
    <flourish:Chunk
      VerticalAlignment="Center"
      ChunkDescription="预览编辑页面的占位状态。"
      ChunkMargin="0"
      ChunkTitle="编辑"
    >
      <flourish:Card
        MaxWidth="520"
        HorizontalAlignment="Center"
        ContentHorizontalAlignment="Center"
        Title="编辑工具"
        Text="此区域可用于承载图片裁剪、滤镜和标注工具。"
      >
        <flourish:Card.Body>
          <flourish:FlourishTextBlock
            HorizontalAlignment="Center"
            FontFamily="Segoe MDL2 Assets"
            FontSize="42"
            Foreground="{DynamicResource FlourishPrimaryForegroundBrush}"
            Text="&#xE70F;"
          />
        </flourish:Card.Body>
      </flourish:Card>
    </flourish:Chunk>
  </Grid>
</Page>
