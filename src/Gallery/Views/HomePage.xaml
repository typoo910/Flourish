<Page
  x:Class="ArkheideSystem.Gallery.Views.HomePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,40">
      <Border Padding="28" Background="{DynamicResource AccentSoftBrush}" CornerRadius="16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Style="{StaticResource GalleryPageTitleStyle}" Text="Flourish Gallery" />
            <TextBlock
              MaxWidth="720"
              Style="{StaticResource GalleryPageSubtitleStyle}"
              Text="Every page calls Flourish APIs directly. Change configuration, appearance, navigation, shell surfaces, commands, window behavior, and background work without restarting the application."
            />
          </StackPanel>
          <TextBlock
            Grid.Column="1"
            Margin="24,0,0,0"
            VerticalAlignment="Center"
            FontFamily="{DynamicResource FlourishIconFontFamily}"
            FontSize="48"
            Foreground="{DynamicResource AccentBrush}"
            Text="&#xE950;"
          />
        </Grid>
      </Border>

      <TextBlock
        Margin="0,28,0,14"
        Style="{StaticResource GallerySectionTitleStyle}"
        Text="Demos"
      />

      <WrapPanel ItemHeight="154" ItemWidth="250">
        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="Configuration"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE713;"
              />
              <TextBlock
                Margin="0,10,0,0"
                FontWeight="SemiBold"
                Text="Configuration &amp; locale"
              />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Read, edit, append, save, reload, and switch locale."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="Appearance"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE790;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Appearance &amp; motion" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Theme, fonts, tooltips, animation, and material effects."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="TitleBarRuntime"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE8A4;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Title bar &amp; search" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Identity, element visibility, shell features, and search handlers."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="NavigationRuntime"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE700;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Navigation" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Panel placement, sizing, routes, cache, and menu items."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="ToolbarStatus"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE945;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Toolbar &amp; status" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Dynamic actions, status messages, and custom shell regions."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="Commands"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE756;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Commands &amp; shortcuts" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Register, dispatch, disable, remove, and bind keyboard input."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="WindowRuntime"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE737;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Window &amp; profile" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Window, tray, close guards, profile, dialogs, and notifications."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>

        <Button
          Click="DemoCard_Click"
          Style="{StaticResource FlourishInteractiveButtonBaseStyle}"
          Tag="BackgroundTasks"
        >
          <Border
            Width="232"
            Height="136"
            Margin="0,0,14,14"
            Style="{StaticResource GalleryCardStyle}"
          >
            <StackPanel>
              <TextBlock
                FontFamily="{DynamicResource FlourishIconFontFamily}"
                FontSize="24"
                Foreground="{DynamicResource AccentBrush}"
                Text="&#xE895;"
              />
              <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Background tasks" />
              <TextBlock
                Margin="0,5,0,0"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="Queue work, observe progress, cancel, and capture results."
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </Button>
      </WrapPanel>
    </StackPanel>
  </ScrollViewer>
</Page>
