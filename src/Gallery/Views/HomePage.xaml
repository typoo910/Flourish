<Page
  x:Class="AckSS.Gallery.Views.HomePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="Transparent"
  mc:Ignorable="d"
>
  <Grid>
    <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">
      <Border
        Width="88"
        Height="88"
        HorizontalAlignment="Center"
        Background="{DynamicResource AccentSoftBrush}"
        CornerRadius="24"
      >
        <TextBlock
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontFamily="Segoe MDL2 Assets"
          FontSize="42"
          Foreground="{DynamicResource AccentBrush}"
          Text="&#xE80F;"
        />
      </Border>

      <TextBlock
        Margin="0,18,0,0"
        HorizontalAlignment="Center"
        FontSize="28"
        FontWeight="SemiBold"
        Foreground="{DynamicResource PrimaryTextBrush}"
        Text="欢迎使用 Flourish Gallery"
      />

      <TextBlock
        Margin="0,10,0,0"
        HorizontalAlignment="Center"
        Foreground="{DynamicResource MutedTextBrush}"
        Text="这里是首页占位内容。后续可以在这里展示最近项目、快速操作和图库概览。"
        TextAlignment="Center"
        TextWrapping="Wrap"
      />
    </StackPanel>
  </Grid>
</Page>
