<Page
  x:Class="ArkheideSystem.Gallery.Views.StatusBarConfigurationPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Title="Status bar"
      Content="Define persistent status items and optional system indicators shown by the shell."
      PresenterMode="Split"
      PresenterPosition="Right"
    />

    <flourish:Chunk Title="Status content">
      <UniformGrid Columns="2">
        <flourish:Card
          Margin="0,0,8,0"
          Icon="&#xE930;"
          Title="Application status"
          Content="AddStatusItem establishes text and a glyph during startup; runtime services can update it later."
        />
        <flourish:Card
          Margin="8,0,0,0"
          Icon="&#xE968;"
          Title="System indicators"
          Content="LAN connection and power status can share the consolidated system status surface."
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="builder&#10;    .ConfigureShell(shell =&gt; shell.UseStatusBar())&#10;    .ConfigureStatusBar(status =&gt; status&#10;        .AddStatusItem(&quot;Ready&quot;, &quot;\uE73E&quot;)&#10;        .ShowLANConnectionStatus()&#10;        .ShowPowerStatus());" />
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the canonical Flourish documentation." Icon="&#xE946;" IsEnabled="False" Title="Flourish documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
