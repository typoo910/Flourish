<Page
  x:Class="ArkheideSystem.Gallery.Views.CardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="A concise display-only surface with optional title, content, and one icon."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Card"
    />

    <flourish:Chunk Title="Variant">
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,8"
          Content="The default low-emphasis surface."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Standard"
        >
          <flourish:Presenter.Presentation>
            <Border MinHeight="220" Padding="16"><flourish:Card Content="Default card surface." Icon="&#xE8A5;" Title="Standard" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,8"
          Content="A quiet neutral surface for supporting information."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Tonal"
        >
          <flourish:Presenter.Presentation>
            <Border MinHeight="220" Padding="16"><flourish:Card Content="Tonal card surface." Icon="&#xE8A5;" Title="Tonal" Variant="Tonal" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="0,8,8,0"
          Content="A strong surface for prominent information."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Filled"
        >
          <flourish:Presenter.Presentation>
            <Border MinHeight="220" Padding="16"><flourish:Card Content="Filled card surface." Icon="&#xE8A5;" Title="Filled" Variant="Filled" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,8,0,0"
          Content="A raised surface for information above nearby content."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Elevated"
        >
          <flourish:Presenter.Presentation>
            <Border MinHeight="220" Padding="16"><flourish:Card Content="Elevated card surface." Icon="&#xE8A5;" Title="Elevated" Variant="Elevated" /></Border>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="CardMemberGrid"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        CanUserReorderColumns="False"
        FontWeight="Regular"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="PROPERTY" Width="224" />
          <DataGridTextColumn Binding="{Binding Description}" Header="PURPOSE" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Optional content">
      <UniformGrid Columns="2">
        <flourish:Card
          MinHeight="160"
          Margin="0,0,8,0"
          Content="Use Card when a title and one concise block of text are enough."
          Title="Title and content"
        />
        <flourish:Card
          MinHeight="160"
          Margin="8,0,0,0"
          Content="Omitting an optional region collapses both that region and its spacing."
          Icon="&#xE946;"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Alignment">
      <UniformGrid Columns="3">
        <flourish:Card
          MinHeight="176"
          Margin="0,0,8,0"
          ContentHorizontalAlignment="Left"
          Content="Copy aligns left."
          Title="Left"
        />
        <flourish:Card
          MinHeight="176"
          Margin="4,0"
          ContentHorizontalAlignment="Center"
          Content="Copy aligns center."
          Title="Center"
        />
        <flourish:Card
          MinHeight="176"
          Margin="8,0,0,0"
          ContentHorizontalAlignment="Right"
          Content="Copy aligns right."
          Title="Right"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Icon position">
      <UniformGrid Columns="2">
        <flourish:Card
          MinHeight="184"
          Margin="0,0,8,8"
          Icon="&#xE8A5;"
          IconPosition="Top"
          Content="The icon appears above the copy."
          Title="Top icon"
        />
        <flourish:Card
          MinHeight="184"
          Margin="8,0,0,8"
          Icon="&#xE8A5;"
          IconPosition="Left"
          Content="The icon appears before the copy."
          Title="Left icon"
        />
        <flourish:Card
          MinHeight="184"
          Margin="0,8,8,0"
          Icon="&#xE8A5;"
          IconPosition="Right"
          Content="The icon appears after the copy."
          Title="Right icon"
        />
        <flourish:Card
          MinHeight="184"
          Margin="8,8,0,0"
          Icon="&#xE8A5;"
          IconPosition="Bottom"
          Content="The icon appears below the copy."
          Title="Bottom icon"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:Card&#xA;  Title=&quot;Build complete&quot;&#xA;  Content=&quot;All projects compiled successfully.&quot;&#xA;  Icon=&quot;&amp;#xE73E;&quot;&#xA;  Variant=&quot;Tonal&quot; /&gt;" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          AutomationProperties.Name="Flourish GitHub repository"
          Content="Repository link placeholder"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          AutomationProperties.Name="Card documentation"
          Content="Canonical documentation link placeholder"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="Card documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
