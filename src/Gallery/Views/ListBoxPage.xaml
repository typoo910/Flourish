<Page
  x:Class="ArkheideSystem.Gallery.Views.ListBoxPage"
  x:Name="RootPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Select items through a Flourish-styled list that generates FlourishListBoxItem containers."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="FlourishListBox"
    />

    <flourish:Chunk
      Content="Both appearances use the same selection model and an equal-height demonstration surface."
      Title="Variant"
    >
      <UniformGrid Columns="2">
        <flourish:Presenter
          Margin="0,0,8,0"
          Content="A bordered list for ordinary selectable content."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Standard"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="190">
              <flourish:FlourishListBox
                Width="240"
                Height="132"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SelectedIndex="0"
              >
                <flourish:FlourishListBoxItem Content="Design" />
                <flourish:FlourishListBoxItem Content="Build" />
                <flourish:FlourishListBoxItem Content="Verify" />
              </flourish:FlourishListBox>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
        <flourish:Presenter
          Margin="8,0,0,0"
          Content="A borderless list for shell navigation items and group labels."
          PresenterMode="TopDown"
          PresenterPosition="Left"
          Title="Navigation"
        >
          <flourish:Presenter.Presentation>
            <Grid MinHeight="190">
              <flourish:FlourishListBox
                Width="240"
                Height="132"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Appearance="Navigation"
              >
                <flourish:FlourishListBoxItem Content="Workspace" IsGroupHeader="True" />
                <flourish:FlourishListBoxItem Content="Overview" IsSelected="True" />
                <flourish:FlourishListBoxItem Content="Settings" />
              </flourish:FlourishListBox>
            </Grid>
          </flourish:Presenter.Presentation>
        </flourish:Presenter>
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Table">
      <flourish:DataGrid ItemsSource="{Binding Properties, ElementName=RootPage}" AutoGenerateColumns="False" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Member" />
          <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Purpose" />
        </DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Bind ItemsSource for application data; the control creates FlourishListBoxItem containers automatically."
      Title="Selection"
    >
      <flourish:Card Title="State ownership" Content="Bind SelectedItem or SelectedValue to the view model. IsCompact affects navigation geometry without changing selection state." />
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="{Binding UsageCode, ElementName=RootPage}" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the FlourishListBox API reference." Icon="&#xE8A5;" IsEnabled="False" Title="FlourishListBox documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
