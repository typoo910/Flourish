<Page
  x:Class="ArkheideSystem.Gallery.Views.DataGridPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  SnapsToDevicePixels="True"
  UseLayoutRounding="True"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Present native WPF rows and columns on a Flourish surface."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="DataGrid"
    />

    <flourish:Chunk Title="Table">
      <flourish:DataGrid
        x:Name="MemberGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="Property" Width="224" />
          <DataGridTextColumn Binding="{Binding Description}" Header="Function" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Example">
      <flourish:DataGrid
        x:Name="ExampleGrid"
        AutoGenerateColumns="False"
        IsReadOnly="True"
      >
        <flourish:DataGrid.Columns>
          <DataGridTextColumn Binding="{Binding Name}" Header="Project" Width="2*" />
          <DataGridTextColumn Binding="{Binding Status}" Header="Status" Width="*" />
          <DataGridTextColumn Binding="{Binding Owner}" Header="Owner" Width="*" />
        </flourish:DataGrid.Columns>
      </flourish:DataGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Counts">
      <UniformGrid Columns="2">
        <flourish:Card
          Margin="0,0,8,0"
          Content="{Binding RowCount, ElementName=ExampleGrid}"
          Title="Rows"
        />
        <flourish:Card
          Margin="8,0,0,0"
          Content="{Binding ColumnCount, ElementName=ExampleGrid}"
          Title="Columns"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="&lt;flourish:DataGrid ItemsSource=&quot;{Binding Reports}&quot; AutoGenerateColumns=&quot;False&quot; IsReadOnly=&quot;True&quot;&gt;&#xA;  &lt;DataGrid.Columns&gt;&#xA;    &lt;DataGridTextColumn Header=&quot;Name&quot; Binding=&quot;{Binding Name}&quot; /&gt;&#xA;    &lt;DataGridTextColumn Header=&quot;Status&quot; Binding=&quot;{Binding Status}&quot; /&gt;&#xA;  &lt;/DataGrid.Columns&gt;&#xA;&lt;/flourish:DataGrid&gt;" />
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          AutomationProperties.Name="Flourish GitHub repository"
          Content="Repository link placeholder"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="GitHub repository"
          ToolTip="External navigation is not available in Gallery."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          AutomationProperties.Name="DataGrid documentation"
          Content="Canonical documentation link placeholder"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="DataGrid documentation"
          ToolTip="External navigation is not available in Gallery."
        />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
