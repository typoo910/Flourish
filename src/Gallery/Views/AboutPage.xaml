<Page
  x:Class="ArkheideSystem.Gallery.Views.AboutPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Title="About Flourish"
      Content="A WPF application framework for building consistent Windows desktop shells, navigation, surfaces, and controls."
      PresenterMode="Split"
      PresenterPosition="Right"
    />

    <flourish:Chunk Title="Project">
      <UniformGrid Columns="2">
        <flourish:CardButton
          Margin="0,0,8,0"
          Icon="&#xE943;"
          IsEnabled="False"
          Title="Repository"
          Content="Source, releases, issues, and contribution history are hosted on GitHub."
        />
        <flourish:CardButton
          Margin="8,0,0,0"
          Icon="&#xE8A5;"
          IsEnabled="False"
          Title="Documentation"
          Content="Concepts, guides, control contracts, and generated API references live with the repository."
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Review the project license in the source repository." Icon="&#xE8A5;" IsEnabled="False" Title="License" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Browse the generated public API reference." Icon="&#xE946;" IsEnabled="False" Title="API reference" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
