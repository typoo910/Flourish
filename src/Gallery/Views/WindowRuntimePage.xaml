<Page
  x:Class="ArkheideSystem.Gallery.Views.WindowRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:PageBody>
    <flourish:HeaderChunk
      Content="Control window, tray, profile, and notification behavior."
      PresenterMode="Split"
      PresenterPosition="Right"
      Title="Window, profile &amp; notifications"
    />

    <flourish:Chunk
      Content="Control the live shell window."
      Title="Shell window"
    >
      <UniformGrid VerticalAlignment="Stretch" Columns="2">
        <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard Icon="&#xE740;" Content="Resize the live shell to the Gallery demonstration size." Title="Window size">
            <flourish:ActionCard.Body>
              <flourish:Button Click="SetDemoSize_Click" Content="Set 1100 × 760" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xF2D9;" Content="Center the shell on its current display." Title="Window position">
            <flourish:ActionCard.Body>
              <flourish:Button Click="CenterWindow_Click" Content="Center" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE718;" Content="Toggle whether the shell stays above other windows." Title="Topmost">
            <flourish:ActionCard.Body>
              <flourish:Button Click="ToggleTopmost_Click" Content="Toggle topmost" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE7C9;" Content="Toggle whether the shell appears in the taskbar." Title="Taskbar visibility">
            <flourish:ActionCard.Body>
              <flourish:Button Click="ToggleTaskbar_Click" Content="Toggle taskbar" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE737;" Content="Minimize the live shell window." Title="Minimize window">
            <flourish:ActionCard.Body>
              <flourish:Button Click="MinimizeWindow_Click" Content="Minimize" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE739;" Content="Maximize the live shell window." Title="Maximize window">
            <flourish:ActionCard.Body>
              <flourish:Button Click="MaximizeWindow_Click" Content="Maximize" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE923;" Content="Restore the live shell to its normal state." Title="Restore window">
            <flourish:ActionCard.Body>
              <flourish:Button Click="RestoreWindow_Click" Content="Restore" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE890;" Content="Hide the shell briefly, then restore it automatically." Title="Temporary visibility">
            <flourish:ActionCard.Body>
              <flourish:Button Click="HideBriefly_Click" Content="Hide for 1 second" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="WindowOutput" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Manage the notification-area tray icon."
      Title="Notification-area tray"
    >
      <UniformGrid VerticalAlignment="Stretch" Columns="2">
        <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard Icon="&#xE7E8;" Content="Set the text shown for the notification-area icon." Title="Tray tooltip">
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox
                x:Name="TrayToolTipBox"
                Width="240"
                KeyDown="TrayToolTipBox_KeyDown"
                LostFocus="TrayToolTipBox_LostFocus"
                Text="Flourish Runtime Gallery"
              />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE7C9;" Content="Enable or disable the notification-area icon." Title="Tray availability">
            <flourish:ActionCard.Body>
              <flourish:Button x:Name="ToggleTrayButton" Click="ToggleTray_Click" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE7E8;" Content="Hide the shell while leaving it available from the tray." Title="Minimize to tray">
            <flourish:ActionCard.Body>
              <flourish:Button Click="MinimizeToTray_Click" Content="Minimize to tray" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE8F4;" Content="Restore the shell from its notification-area icon." Title="Restore from tray">
            <flourish:ActionCard.Body>
              <flourish:Button Click="RestoreFromTray_Click" Content="Restore from tray" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="TrayOutput" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Configure close policy and guards."
      Title="Close behavior"
    >
      <UniformGrid VerticalAlignment="Stretch" Columns="2">
        <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard Icon="&#xE8BB;" Content="Choose the shell's default close policy; changes apply immediately." Title="Close policy">
            <flourish:ActionCard.Body>
              <flourish:FlourishComboBox x:Name="CloseBehaviorBox" Width="220" SelectionChanged="CloseBehaviorBox_SelectionChanged" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE73E;" Content="Choose the decision returned by the demo guard." Title="Guard decision">
            <flourish:ActionCard.Body>
              <flourish:FlourishCheckBox x:Name="CloseGuardAllowsBox" VerticalAlignment="Center" Click="CloseGuardAllowsBox_Click" Content="Guard allows close" IsChecked="True" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE72E;" Content="Install the disposable close guard for this page." Title="Register guard">
            <flourish:ActionCard.Body>
              <flourish:Button Click="RegisterCloseGuard_Click" Content="Register guard" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE74D;" Content="Dispose the guard registered by this page." Title="Remove guard">
            <flourish:ActionCard.Body>
              <flourish:Button Click="RemoveCloseGuard_Click" Content="Remove guard" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE73E;" Content="Evaluate the active guards without closing the app." Title="Evaluate guards">
            <flourish:ActionCard.Body>
              <flourish:Button Click="EvaluateClose_Click" Content="Evaluate guards" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE8BB;" Content="Submit a close request through the configured policy." Title="Request app close">
            <flourish:ActionCard.Body>
              <flourish:Button Click="RequestClose_Click" Content="Request app close" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard x:Name="CloseOutput" Margin="8,0,0,0" VerticalAlignment="Stretch" />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk
      Content="Publish modal and non-modal messages."
      Title="Messages"
    >
      <UniformGrid VerticalAlignment="Stretch" Columns="2">
        <StackPanel Margin="0,0,8,0" VerticalAlignment="Stretch">
          <flourish:ActionCard Icon="&#xE715;" Content="Await a standard modal choice without blocking application logic." Title="Standard message">
            <flourish:ActionCard.Body>
              <flourish:Button Click="ShowMessage_Click" Content="Show async message" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE8BD;" Content="Await a modal message with custom choices." Title="Custom choices">
            <flourish:ActionCard.Body>
              <flourish:Button Click="ShowCustomMessage_Click" Content="Show custom choices" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE8EC;" Content="Choose the stable identifier used for notification operations." Title="Notification ID">
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="NotificationIdBox" Width="240" Text="gallery.runtime.notice" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE715;" Content="Enter the content published to the shell host." Title="Notification message">
            <flourish:ActionCard.Body>
              <flourish:FlourishTextBox x:Name="NotificationMessageBox" Width="240" Text="A runtime notification from the Gallery." />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE8BD;" Content="Publish a new non-modal notification." Title="Show notification">
            <flourish:ActionCard.Body>
              <flourish:Button Click="ShowNotification_Click" Content="Show" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE70F;" Content="Insert the notification or update its current content." Title="Upsert notification">
            <flourish:ActionCard.Body>
              <flourish:Button Click="UpsertNotification_Click" Content="Upsert" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE74D;" Content="Dismiss the notification with the selected identifier." Title="Dismiss notification">
            <flourish:ActionCard.Body>
              <flourish:Button Click="DismissNotification_Click" Content="Dismiss ID" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
          <flourish:ActionCard Margin="{DynamicResource FlourishActionCardPeerMargin}" Icon="&#xE738;" Content="Dismiss every notification in the shell host." Title="Dismiss all notifications">
            <flourish:ActionCard.Body>
              <flourish:Button Click="DismissAllNotifications_Click" Content="Dismiss all" />
            </flourish:ActionCard.Body>
          </flourish:ActionCard>
        </StackPanel>
        <flourish:OutputCard
          x:Name="MessageActivityOutput"
          Margin="8,0,0,0"
          AutomationProperties.Name="Message and notification output"
          VerticalAlignment="Stretch"
        />
      </UniformGrid>
    </flourish:Chunk>

    <flourish:Chunk Title="Usage">
      <flourish:CodeSpace Text="builder.ConfigureWindow(window =&gt; window&#xA;    .SetWindowSize(1100, 760)&#xA;    .SetWindowPosition(WindowStartupLocation.CenterScreen));&#xA;&#xA;windowService.SetTopmost(true);&#xA;await messageService.ShowAsync(&quot;Operation complete.&quot;, &quot;Reports&quot;);" />
    </flourish:Chunk>
    <flourish:Chunk Title="Reference">
      <UniformGrid Columns="2">
        <flourish:CardButton Margin="0,0,8,0" Content="Browse the Flourish source repository." Icon="&#xE943;" IsEnabled="False" Title="GitHub repository" ToolTip="External navigation is not available in Gallery." />
        <flourish:CardButton Margin="8,0,0,0" Content="Read the canonical Flourish documentation." Icon="&#xE946;" IsEnabled="False" Title="Flourish documentation" ToolTip="External navigation is not available in Gallery." />
      </UniformGrid>
    </flourish:Chunk>
  </flourish:PageBody>
</Page>
