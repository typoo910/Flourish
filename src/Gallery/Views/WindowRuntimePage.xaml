<Page
  x:Class="ArkheideSystem.Gallery.Views.WindowRuntimePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:flourish="http://schemas.arkheide.system/flourish"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <flourish:FlourishScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="{DynamicResource FlourishPageContentMargin}">
      <flourish:ChunkHero
        ChunkHeroDescription="Control window, tray, profile, and notification behavior."
        ChunkHeroTitle="Window, profile &amp; notifications"
      />

      <flourish:Chunk
        ChunkDescription="Control the live shell window."
        ChunkTitle="Shell window"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Window service"
          Text="Resize, position, activate, and change window flags through IWindowService."
        >
          <flourish:Card.Body>
            <StackPanel>
            <WrapPanel>
              <flourish:Button Margin="0,0,8,8" Click="SetDemoSize_Click" Content="Set 1100 × 760" />
              <flourish:Button Margin="0,0,8,8" Click="CenterWindow_Click" Content="Center" />
              <flourish:Button Margin="0,0,8,8" Click="ToggleTopmost_Click" Content="Toggle topmost" />
              <flourish:Button Margin="0,0,8,8" Click="ToggleTaskbar_Click" Content="Toggle taskbar" />
              <flourish:Button Margin="0,0,8,8" Click="MinimizeWindow_Click" Content="Minimize" />
              <flourish:Button Margin="0,0,8,8" Click="MaximizeWindow_Click" Content="Maximize" />
              <flourish:Button Margin="0,0,8,8" Click="RestoreWindow_Click" Content="Restore" />
              <flourish:Button Margin="0,0,8,8" Click="HideBriefly_Click" Content="Hide for 1 second" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows the current shell window state.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="WindowStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage the notification-area tray icon."
        ChunkTitle="Notification-area tray"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Tray service"
          Text="Enable the tray icon after startup and use it to restore a hidden shell window."
        >
          <flourish:Card.Body>
            <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <flourish:FlourishTextBox x:Name="TrayToolTipBox" Text="Flourish Runtime Gallery" />
              <flourish:Button Grid.Column="1" Margin="10,0,0,0" Click="ApplyTrayToolTip_Click" Content="Set tray tooltip" />
            </Grid>
            <WrapPanel Margin="0,14,0,0">
              <flourish:Button x:Name="ToggleTrayButton" Margin="0,0,8,0" Click="ToggleTray_Click" />
              <flourish:Button Margin="0,0,8,0" Click="MinimizeToTray_Click" Content="Minimize to tray" />
              <flourish:Button Click="RestoreFromTray_Click" Content="Restore from tray" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows tray availability and visibility.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="TrayStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Configure close policy and guards."
        ChunkTitle="Close behavior"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Close controls"
          Text="Choose the default policy and install a disposable guard whose decision can change at runtime."
        >
          <flourish:Card.Body>
            <StackPanel>
            <WrapPanel>
              <flourish:FlourishComboBox x:Name="CloseBehaviorBox" Width="220" />
              <flourish:Button Margin="10,0,0,0" Click="ApplyCloseBehavior_Click" Content="Apply behavior" />
              <flourish:FlourishCheckBox x:Name="CloseGuardAllowsBox" Margin="18,0,0,0" VerticalAlignment="Center" Content="Guard allows close" IsChecked="True" />
            </WrapPanel>
            <WrapPanel Margin="0,14,0,0">
              <flourish:Button Margin="0,0,8,0" Click="RegisterCloseGuard_Click" Content="Register guard" />
              <flourish:Button Margin="0,0,8,0" Click="RemoveCloseGuard_Click" Content="Remove guard" />
              <flourish:Button Margin="0,0,8,0" Click="EvaluateClose_Click" Content="Evaluate guards" />
              <flourish:Button Click="RequestClose_Click" Content="Request app close" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Result" Text="Shows close policy and guard evaluation.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="CloseStatusText" Role="Status" Text="No close guard registered by this page." />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Manage the profile surface."
        ChunkTitle="Profile flyout"
      >
        <UniformGrid Columns="2">
          <flourish:Card
          Margin="0,0,8,0"
          Title="Profile controls"
          Text="Enable and open the profile surface or replace its content page; restore returns to the startup page type."
        >
          <flourish:Card.Body>
            <StackPanel>
            <WrapPanel>
              <flourish:Button x:Name="ToggleProfileEnabledButton" Margin="0,0,8,0" Click="ToggleProfileEnabled_Click" />
              <flourish:Button Margin="0,0,8,0" Click="ToggleProfileFlyout_Click" Content="Toggle flyout" />
              <flourish:Button Margin="0,0,8,0" Click="UseConfigurationProfilePage_Click" Content="Use configuration page" />
              <flourish:Button Click="RestoreProfilePage_Click" Content="Restore profile page" />
            </WrapPanel>
            </StackPanel>
          </flourish:Card.Body>
        </flourish:Card>
          <flourish:Card Margin="8,0,0,0" Title="Output" Text="Shows profile availability, visibility, and content.">
            <flourish:Card.Body>
              <flourish:FlourishTextBlock x:Name="ProfileStatusText" Role="Status" />
            </flourish:Card.Body>
          </flourish:Card>
        </UniformGrid>
      </flourish:Chunk>

      <flourish:Chunk
        ChunkDescription="Publish modal and non-modal messages."
        ChunkTitle="Messages"
      >
        <StackPanel>
          <UniformGrid Columns="2">
            <flourish:Card
              Margin="0,0,8,0"
              Title="Modal messages"
              Text="Await a standard or custom choice without blocking application logic."
            >
              <flourish:Card.Body>
                <WrapPanel>
                  <flourish:Button Margin="0,0,8,8" Click="ShowMessage_Click" Content="Show async message" />
                  <flourish:Button Margin="0,0,8,8" Click="ShowCustomMessage_Click" Content="Show custom choices" />
                </WrapPanel>
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card Margin="8,0,0,0" Title="Message result" Text="Shows the selected modal choice.">
              <flourish:Card.Body>
                <flourish:FlourishTextBlock x:Name="MessageStatusText" Role="Status" />
              </flourish:Card.Body>
            </flourish:Card>
          </UniformGrid>
          <UniformGrid Margin="0,16,0,0" Columns="2">
            <flourish:Card
              Margin="0,0,8,0"
              Title="Notifications"
              Text="Publish, update, or dismiss non-modal notifications in the shell host."
            >
              <flourish:Card.Body>
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                      <flourish:FlourishTextBlock Role="FieldLabel" Text="Notification ID" />
                      <flourish:FlourishTextBox x:Name="NotificationIdBox" Text="gallery.runtime.notice" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                      <flourish:FlourishTextBlock Role="FieldLabel" Text="Message" />
                      <flourish:FlourishTextBox x:Name="NotificationMessageBox" Text="A runtime notification from the Gallery." />
                    </StackPanel>
                  </Grid>
                  <WrapPanel Margin="0,14,0,0">
                    <flourish:Button Margin="0,0,8,0" Click="ShowNotification_Click" Content="Show" />
                    <flourish:Button Margin="0,0,8,0" Click="UpsertNotification_Click" Content="Upsert" />
                    <flourish:Button Margin="0,0,8,0" Click="DismissNotification_Click" Content="Dismiss ID" />
                    <flourish:Button Click="DismissAllNotifications_Click" Content="Dismiss all" />
                  </WrapPanel>
                </StackPanel>
              </flourish:Card.Body>
            </flourish:Card>
            <flourish:Card Margin="8,0,0,0" Title="Notification result" Text="Shows the current notification operation.">
              <flourish:Card.Body>
                <flourish:FlourishTextBlock x:Name="NotificationStatusText" Role="Status" />
              </flourish:Card.Body>
            </flourish:Card>
          </UniformGrid>
        </StackPanel>
      </flourish:Chunk>
    </StackPanel>
  </flourish:FlourishScrollViewer>
</Page>
