{
  "$schema": "https://dotnet.github.io/docfx/schemas/v2/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/Flourish/Flourish.csproj"
          ]
        }
      ],
      "dest": "en-us/api",
      "properties": {
        "Configuration": "Release",
        "TargetFramework": "net10.0-windows"
      },
      "filter": "filterConfig.yml",
      "memberLayout": "samePage",
      "namespaceLayout": "nested"
    }
  ],
  "build": {
    "content": [
      {
        "src": "en-us",
        "files": [
          "index.md",
          "toc.yml",
          "articles/**/*.md",
          "articles/**/*.yml",
          "api/**/*.yml"
        ],
        "dest": "."
      }
    ],
    "output": "_site/en-us",
    "template": [
      "default",
      "modern",
      "material/material",
      "templates/flourish"
    ],
    "globalMetadata": {
      "_appTitle": "Flourish",
      "_appName": "Flourish",
      "_enableSearch": true,
      "_lang": "en-us",
      "_appFooter": "Flourish API documentation"
    }
  }
}
